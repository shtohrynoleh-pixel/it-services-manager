<% if (typeof user !== 'undefined' && user && typeof userRank !== 'undefined' && userRank) { %>
<style>
.xp-bar{display:flex;align-items:center;gap:8px;padding:8px 16px;border-top:1px solid var(--border);font-size:11px;}
.xp-rank-icon{font-size:18px;}
.xp-info{flex:1;min-width:0;}
.xp-rank-name{font-weight:800;font-size:11px;}
.xp-progress{height:4px;background:#e2e8f0;border-radius:4px;margin-top:3px;overflow:hidden;}
.xp-progress-fill{height:100%;border-radius:4px;transition:width 0.5s;}
.xp-total{font-size:10px;color:var(--muted);font-weight:700;}

/* XP celebration overlay */
.xp-celebrate{position:fixed;inset:0;z-index:3000;pointer-events:none;display:none;}
.xp-celebrate.show{display:block;}
.xp-celebrate canvas{position:absolute;inset:0;width:100%;height:100%;}
.xp-popup{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%) scale(0);z-index:3001;text-align:center;pointer-events:none;transition:transform 0.4s cubic-bezier(0.175,0.885,0.32,1.275);background:rgba(255,255,255,0.95);padding:32px 48px;border-radius:20px;box-shadow:0 20px 60px rgba(0,0,0,0.15);}
.xp-popup.show{transform:translate(-50%,-50%) scale(1);}
.xp-popup .xp-big{font-size:48px;font-weight:900;background:linear-gradient(135deg,#0891b2,#06b6d4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.xp-popup .xp-label{font-size:14px;font-weight:700;color:#475569;margin-top:4px;}
.xp-popup .xp-rank-up{font-size:16px;font-weight:900;margin-top:8px;padding:8px 16px;border-radius:10px;display:inline-block;}

/* Small toast for minor XP (1-5 points) */
.xp-mini{position:fixed;bottom:90px;right:24px;z-index:2000;padding:8px 16px;border-radius:10px;background:#0891b2;color:#fff;font-size:12px;font-weight:800;box-shadow:0 4px 16px rgba(8,145,178,0.3);display:none;}
.xp-mini.show{display:flex;align-items:center;gap:6px;animation:xpSlideUp 0.3s ease;}
@keyframes xpSlideUp{from{transform:translateY(20px);opacity:0;}to{transform:translateY(0);opacity:1;}}
</style>

<div class="xp-celebrate" id="xpCelebrate"><canvas id="confettiCanvas"></canvas></div>
<div class="xp-popup" id="xpPopup"><div class="xp-big" id="xpBigText">+20 XP</div><div class="xp-label" id="xpBigLabel">Task Completed!</div><div class="xp-rank-up" id="xpRankUp" style="display:none;"></div></div>
<div class="xp-mini" id="xpMini"></div>

<script>
(function(){
  // Confetti engine
  function launchConfetti(){
    var canvas=document.getElementById('confettiCanvas');
    var ctx=canvas.getContext('2d');
    canvas.width=window.innerWidth;
    canvas.height=window.innerHeight;
    var particles=[];
    var colors=['#0891b2','#06b6d4','#f59e0b','#10b981','#ef4444','#8b5cf6','#f97316','#ec4899','#fef08a','#a78bfa'];
    for(var i=0;i<150;i++){
      particles.push({
        x:canvas.width*0.5+Math.random()*200-100,
        y:canvas.height*0.4,
        vx:(Math.random()-0.5)*12,
        vy:Math.random()*-14-4,
        w:Math.random()*8+4,
        h:Math.random()*6+3,
        color:colors[Math.floor(Math.random()*colors.length)],
        rot:Math.random()*360,
        rv:(Math.random()-0.5)*10,
        life:1
      });
    }
    var frame=0;
    function draw(){
      ctx.clearRect(0,0,canvas.width,canvas.height);
      var alive=false;
      particles.forEach(function(p){
        if(p.life<=0)return;
        alive=true;
        p.x+=p.vx;
        p.vy+=0.3;
        p.y+=p.vy;
        p.rot+=p.rv;
        p.life-=0.008;
        p.vx*=0.99;
        ctx.save();
        ctx.translate(p.x,p.y);
        ctx.rotate(p.rot*Math.PI/180);
        ctx.globalAlpha=Math.max(0,p.life);
        ctx.fillStyle=p.color;
        ctx.fillRect(-p.w/2,-p.h/2,p.w,p.h);
        ctx.restore();
      });
      frame++;
      if(alive&&frame<200)requestAnimationFrame(draw);
      else{ctx.clearRect(0,0,canvas.width,canvas.height);document.getElementById('xpCelebrate').classList.remove('show');}
    }
    document.getElementById('xpCelebrate').classList.add('show');
    draw();
  }

  // Show big celebration (10+ XP)
  window.celebrateXP=function(amount,label,rankUp){
    var popup=document.getElementById('xpPopup');
    document.getElementById('xpBigText').textContent='+'+amount+' XP';
    document.getElementById('xpBigLabel').textContent=label||'Great job!';
    var ru=document.getElementById('xpRankUp');
    if(rankUp){
      ru.textContent='🎉 Rank Up: '+rankUp+'!';
      ru.style.display='inline-block';
      ru.style.background='linear-gradient(135deg,#fef08a,#fde68a)';
      ru.style.color='#92400e';
    }else{ru.style.display='none';}
    popup.classList.add('show');
    launchConfetti();
    setTimeout(function(){popup.classList.remove('show');},3000);
  };

  // Show mini toast (1-9 XP)
  window.miniXP=function(amount,label){
    var el=document.getElementById('xpMini');
    el.innerHTML='<span style="color:#fef08a;font-size:14px;">+'+amount+'</span> '+label;
    el.classList.add('show');
    setTimeout(function(){el.classList.remove('show');},2000);
  };

  // Auto-trigger from session flash
  <% if (typeof xpFlash !== 'undefined' && xpFlash) { %>
    setTimeout(function(){
      <% if (xpFlash.xp >= 10) { %>
        celebrateXP(<%= xpFlash.xp %>, '<%= xpFlash.label %>', '<%= xpFlash.rankUp || "" %>');
      <% } else { %>
        miniXP(<%= xpFlash.xp %>, '<%= xpFlash.label %>');
      <% } %>
    },600);
  <% } %>
})();
</script>
<% } %>
