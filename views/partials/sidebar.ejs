<div class="sb-backdrop" id="sbBackdrop" onclick="closeSidebar()"></div>
<div class="sidebar" id="sidebar">
  <div class="sb-brand">
    <h1><% if (settings.business_logo) { %><img src="<%= settings.business_logo %>" style="height:24px;vertical-align:middle;margin-right:4px;border-radius:4px;"><% } else { %><span>🖥️</span><% } %> <%= settings.business_name || 'IT Services' %></h1>
    <p style="display:flex;justify-content:space-between;align-items:center;">
      <span><%= user.role === 'admin' ? 'Admin Panel' : 'Client Portal' %></span>
      <% if (user.role === 'admin') { %><button onclick="toggleEditMode()" id="editModeBtn" style="background:none;border:none;font-size:11px;cursor:pointer;color:var(--muted);padding:2px 6px;" title="Reorder menus">⚙️</button><% } %>
    </p>
  </div>
  <div class="sb-nav" id="sbNav">
    <% if (user.role === 'admin') { %>
      <%
        // Define all menu items with their default groups
        const menuItems = [
          { id:'dashboard', icon:'ti ti-dashboard', label:'Dashboard', href:'/admin', group:'main' },
          { id:'companies', icon:'ti ti-building', label:'Companies', href:'/admin/companies', group:'main' },
          { id:'all-users', icon:'ti ti-users-group', label:'All Users', href:'/admin/all-users', group:'main' },
          { id:'services', icon:'ti ti-settings-cog', label:'Services', href:'/admin/services', group:'main' },
          { id:'billing', icon:'ti ti-file-invoice', label:'Billing', href:'/admin/billing', group:'main' },
          { id:'tasks', icon:'ti ti-checkbox', label:'Tasks', href:'/admin/tasks', group:'work' },
          { id:'projects', icon:'ti ti-folder', label:'Projects', href:'/admin/projects', group:'work' },
          { id:'schedule', icon:'ti ti-calendar-event', label:'Schedule', href:'/admin/schedule', group:'work' },
          { id:'chat', icon:'ti ti-message-circle', label:'Chat', href:'/admin/chat', group:'work' },
          { id:'policies', icon:'ti ti-shield-check', label:'Security Policies', href:'/admin/policies', group:'docs' },
          { id:'sops', icon:'ti ti-list-check', label:'SOPs', href:'/admin/sops', group:'docs' },
          { id:'flows', icon:'ti ti-git-branch', label:'Process Flows', href:'/admin/flows', group:'docs' },
          { id:'monitoring', icon:'ti ti-activity', label:'Monitoring', href:'/admin/monitoring', group:'monitor' },
          { id:'alerts-page', icon:'ti ti-bell', label:'Alerts', href:'/admin/alerts', group:'monitor' },
          { id:'vault', icon:'ti ti-key', label:'Password Vault', href:'/admin/vault', group:'system' },
          { id:'users-manage', icon:'ti ti-user-shield', label:'User Accounts', href:'/admin/users-manage', group:'system' },
          { id:'admins', icon:'ti ti-crown', label:'Admin Management', href:'/admin/admins', group:'system', superOnly:true },
          { id:'settings', icon:'ti ti-settings', label:'Settings', href:'/admin/settings', group:'system' },
          { id:'integrations', icon:'ti ti-plug', label:'Integrations', href:'/admin/integrations', group:'system' },
          { id:'roles', icon:'ti ti-user-check', label:'Roles', href:'/admin/roles', group:'system' },
          { id:'departments', icon:'ti ti-building-community', label:'Departments', href:'/admin/departments', group:'system' }
        ];
        const groups = [
          { id:'main', label:'Main' },
          { id:'work', label:'Work' },
          { id:'docs', label:'Documentation' },
          { id:'monitor', label:'Monitoring' },
          { id:'system', label:'System' }
        ];
      %>

      <% groups.forEach(g => { %>
        <% const items = menuItems.filter(m => m.group === g.id && (!m.superOnly || (user.is_super))); %>
        <div class="sb-section" data-group="<%= g.id %>">
          <div class="sb-section-head" onclick="toggleGroup('<%= g.id %>')">
            <span><%= g.label %><span class="sb-section-count"><%= items.length %></span></span>
            <span class="sb-arrow">▾</span>
          </div>
          <div class="sb-section-body" data-dropzone="<%= g.id %>">
            <% items.forEach(m => { %>
              <a class="sb-item <%= page === m.id ? 'active' : '' %>" href="<%= m.href %>" data-menu-id="<%= m.id %>" draggable="false">
                <i class="<%= m.icon %>" style="font-size:17px;width:20px;text-align:center;"></i> <%= m.label %>
                <span class="drag-handle" style="display:none;margin-left:auto;cursor:grab;font-size:14px;color:#94a3b8;" title="Drag to move">⠿</span>
              </a>
            <% }) %>
          </div>
        </div>
      <% }) %>

    <% } else { %>
      <div class="sb-section" data-group="myco">
        <div class="sb-section-head" onclick="toggleGroup('myco')"><span>My Company</span><span class="sb-arrow">▾</span></div>
        <div class="sb-section-body">
          <a class="sb-item <%= !tab || tab === 'dashboard' ? 'active' : '' %>" href="/client"><i class="ti ti-dashboard" style="font-size:17px;width:20px;text-align:center;"></i> Dashboard</a>
          <a class="sb-item <%= tab === 'users' ? 'active' : '' %>" href="/client?tab=users"><i class="ti ti-users-group" style="font-size:17px;width:20px;text-align:center;"></i> Team</a>
          <a class="sb-item <%= tab === 'servers' ? 'active' : '' %>" href="/client?tab=servers"><i class="ti ti-server" style="font-size:17px;width:20px;text-align:center;"></i> Servers</a>
          <a class="sb-item <%= tab === 'subscriptions' ? 'active' : '' %>" href="/client?tab=subscriptions"><i class="ti ti-package" style="font-size:17px;width:20px;text-align:center;"></i> Subscriptions</a>
          <a class="sb-item <%= tab === 'assets' ? 'active' : '' %>" href="/client?tab=assets"><i class="ti ti-world" style="font-size:17px;width:20px;text-align:center;"></i> Digital Assets</a>
          <a class="sb-item <%= tab === 'inventory' ? 'active' : '' %>" href="/client?tab=inventory"><i class="ti ti-device-desktop" style="font-size:17px;width:20px;text-align:center;"></i> Inventory</a>
          <a class="sb-item <%= tab === 'invoices' ? 'active' : '' %>" href="/client?tab=invoices"><i class="ti ti-file-invoice" style="font-size:17px;width:20px;text-align:center;"></i> Invoices</a>
          <a class="sb-item <%= tab === 'tasks' ? 'active' : '' %>" href="/client?tab=tasks"><i class="ti ti-ticket" style="font-size:17px;width:20px;text-align:center;"></i> Requests</a>
          <a class="sb-item <%= page === 'chat' ? 'active' : '' %>" href="/client/chat"><i class="ti ti-message-circle" style="font-size:17px;width:20px;text-align:center;"></i> Chat</a>
        </div>
      </div>
      <div class="sb-section" data-group="work">
        <div class="sb-section-head" onclick="toggleGroup('work')"><span>Work</span><span class="sb-arrow">▾</span></div>
        <div class="sb-section-body">
          <a class="sb-item <%= page === 'projects' ? 'active' : '' %>" href="/client/projects"><i class="ti ti-folder" style="font-size:17px;width:20px;text-align:center;"></i> Projects</a>
          <a class="sb-item <%= page === 'sops' ? 'active' : '' %>" href="/client/sops"><i class="ti ti-list-check" style="font-size:17px;width:20px;text-align:center;"></i> SOPs</a>
          <a class="sb-item <%= page === 'policies' ? 'active' : '' %>" href="/client/policies"><i class="ti ti-shield-check" style="font-size:17px;width:20px;text-align:center;"></i> Policies</a>
          <a class="sb-item <%= page === 'passwords' ? 'active' : '' %>" href="/client/passwords"><i class="ti ti-key" style="font-size:17px;width:20px;text-align:center;"></i> Passwords</a>
        </div>
      </div>
      <div class="sb-section" data-group="info">
        <div class="sb-section-head" onclick="toggleGroup('info')"><span>Info & Settings</span><span class="sb-arrow">▾</span></div>
        <div class="sb-section-body">
          <a class="sb-item <%= page === 'services' ? 'active' : '' %>" href="/client/services"><i class="ti ti-settings-cog" style="font-size:17px;width:20px;text-align:center;"></i> Available Services</a>
          <a class="sb-item <%= page === 'account' ? 'active' : '' %>" href="/client/account"><i class="ti ti-user-circle" style="font-size:17px;width:20px;text-align:center;"></i> My Account</a>
        </div>
      </div>
    <% } %>
  </div>
  <div class="sb-footer">
    <a class="sb-item" href="/logout"><i class="ti ti-logout" style="font-size:17px;width:20px;text-align:center;"></i> Logout</a>
    <div style="font-size:10px;color:var(--muted);padding:8px 20px 0">Logged in as <strong><%= user.full_name || user.username %></strong></div>
  </div>
</div>
<script>
function openSidebar(){document.getElementById('sidebar').classList.add('open');document.getElementById('sbBackdrop').classList.add('open');}
function closeSidebar(){document.getElementById('sidebar').classList.remove('open');document.getElementById('sbBackdrop').classList.remove('open');}

// === COLLAPSIBLE GROUPS ===
function toggleGroup(name){
  var el=document.querySelector('[data-group="'+name+'"]');
  if(!el)return;
  el.classList.toggle('collapsed');
  saveGroupState();
}
function saveGroupState(){
  var state={};
  document.querySelectorAll('.sb-section[data-group]').forEach(function(el){
    state[el.dataset.group]=el.classList.contains('collapsed');
  });
  try{localStorage.setItem('sb_groups',JSON.stringify(state));}catch(e){}
}
function loadGroupState(){
  try{
    var state=JSON.parse(localStorage.getItem('sb_groups')||'{}');
    Object.keys(state).forEach(function(k){
      if(state[k]){
        var el=document.querySelector('[data-group="'+k+'"]');
        if(el)el.classList.add('collapsed');
      }
    });
    var active=document.querySelector('.sb-item.active');
    if(active){var section=active.closest('.sb-section');if(section)section.classList.remove('collapsed');}
  }catch(e){}
}

// === DRAG & DROP MENU REORDER ===
var editMode=false;
var dragItem=null;

function toggleEditMode(){
  editMode=!editMode;
  var btn=document.getElementById('editModeBtn');
  var handles=document.querySelectorAll('.drag-handle');
  var items=document.querySelectorAll('.sb-item[data-menu-id]');
  if(editMode){
    btn.textContent='✅';
    btn.title='Done editing';
    handles.forEach(function(h){h.style.display='inline';});
    items.forEach(function(it){it.setAttribute('draggable','true');it.style.opacity='1';});
    // Expand all groups
    document.querySelectorAll('.sb-section').forEach(function(s){s.classList.remove('collapsed');});
  }else{
    btn.textContent='⚙️';
    btn.title='Reorder menus';
    handles.forEach(function(h){h.style.display='none';});
    items.forEach(function(it){it.setAttribute('draggable','false');it.style.opacity='1';});
    saveMenuOrder();
    loadGroupState();
  }
}

// Drag events
document.addEventListener('dragstart',function(e){
  if(!editMode)return;
  var item=e.target.closest('.sb-item[data-menu-id]');
  if(!item)return;
  dragItem=item;
  item.style.opacity='0.4';
  e.dataTransfer.effectAllowed='move';
  e.dataTransfer.setData('text/plain',item.dataset.menuId);
});

document.addEventListener('dragend',function(e){
  if(dragItem)dragItem.style.opacity='1';
  dragItem=null;
  document.querySelectorAll('.sb-section-body').forEach(function(z){z.style.background='';});
});

document.addEventListener('dragover',function(e){
  if(!editMode||!dragItem)return;
  e.preventDefault();
  e.dataTransfer.dropEffect='move';
  var zone=e.target.closest('.sb-section-body[data-dropzone]');
  if(zone)zone.style.background='rgba(8,145,178,0.06)';
});

document.addEventListener('dragleave',function(e){
  var zone=e.target.closest('.sb-section-body[data-dropzone]');
  if(zone)zone.style.background='';
});

document.addEventListener('drop',function(e){
  if(!editMode||!dragItem)return;
  e.preventDefault();
  var zone=e.target.closest('.sb-section-body[data-dropzone]');
  if(!zone)return;
  zone.style.background='';
  // Find the item we're dropping near
  var target=e.target.closest('.sb-item[data-menu-id]');
  if(target&&target!==dragItem){
    var rect=target.getBoundingClientRect();
    var mid=rect.top+rect.height/2;
    if(e.clientY<mid){zone.insertBefore(dragItem,target);}
    else{zone.insertBefore(dragItem,target.nextSibling);}
  }else{
    zone.appendChild(dragItem);
  }
  updateCounts();
  saveMenuOrder();
});

function updateCounts(){
  document.querySelectorAll('.sb-section[data-group]').forEach(function(sec){
    var count=sec.querySelectorAll('.sb-item[data-menu-id]').length;
    var badge=sec.querySelector('.sb-section-count');
    if(badge)badge.textContent=count;
  });
}

function saveMenuOrder(){
  var order={};
  document.querySelectorAll('.sb-section-body[data-dropzone]').forEach(function(zone){
    var group=zone.dataset.dropzone;
    var ids=[];
    zone.querySelectorAll('.sb-item[data-menu-id]').forEach(function(it){ids.push(it.dataset.menuId);});
    order[group]=ids;
  });
  try{localStorage.setItem('sb_menu_order',JSON.stringify(order));}catch(e){}
}

function loadMenuOrder(){
  try{
    var order=JSON.parse(localStorage.getItem('sb_menu_order')||'null');
    if(!order)return;
    Object.keys(order).forEach(function(group){
      var zone=document.querySelector('[data-dropzone="'+group+'"]');
      if(!zone)return;
      order[group].forEach(function(menuId){
        var item=document.querySelector('[data-menu-id="'+menuId+'"]');
        if(item)zone.appendChild(item);
      });
    });
    updateCounts();
  }catch(e){}
}

// Init
loadMenuOrder();
loadGroupState();
</script>
