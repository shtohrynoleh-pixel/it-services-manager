<%- include('../partials/head') %>
<div class="app-wrap">
  <%- include('../partials/sidebar', { settings, user, page, tab: '' }) %>
  <div class="main">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px;"><button class="mob-toggle" onclick="openSidebar()">☰</button><h2><i class="ti ti-calculator"></i> Fuel Calculator</h2></div>
    </div>
    <div class="content">
      <div class="tabs" style="margin-bottom:14px;">
        <a class="tab" href="/client/fuel"><i class="ti ti-dashboard"></i> Dashboard</a>
        <a class="tab" href="/client/fuel/history"><i class="ti ti-history"></i> History</a>
        <a class="tab active" href="/client/fuel/calculator"><i class="ti ti-calculator"></i> Calculator</a>
      </div>

      <div class="card">
        <h3><i class="ti ti-calculator"></i> What-If Calculator</h3>
        <p style="font-size:12px;color:var(--muted);margin-bottom:16px;">Estimate your potential fuel incentive payout. Adjust the numbers to see how improving MPG affects your earnings.</p>

        <div style="display:flex;gap:20px;flex-wrap:wrap;">
          <!-- Inputs -->
          <div style="flex:1;min-width:260px;">
            <div class="form-group"><label>Miles Driven</label><input type="number" id="calcMiles" value="3000" min="0" oninput="recalc()"></div>
            <div class="form-group"><label>Your MPG</label><input type="number" id="calcMpg" value="<%= defaults.baselineMpg + 0.5 %>" step="0.1" min="0" oninput="recalc()"></div>
            <div class="form-group"><label>Baseline MPG</label><input type="number" id="calcBaseline" value="<%= defaults.baselineMpg %>" step="0.1" min="0" oninput="recalc()"></div>
            <div class="form-group"><label>Target MPG</label><input type="number" id="calcTarget" value="<%= defaults.targetMpg %>" step="0.1" min="0" oninput="recalc()"></div>
            <div class="form-group"><label>Fuel Price ($/gallon)</label><input type="number" id="calcFuelPrice" value="<%= defaults.fuelPrice %>" step="0.01" min="0" oninput="recalc()"></div>
            <div class="form-group"><label>Your Share (%)</label><input type="number" id="calcDriverPct" value="<%= defaults.driverPct %>" min="0" max="100" oninput="recalc()"></div>
            <div class="form-group"><label>KPI Bonus ($/gallon saved)</label><input type="number" id="calcKpi" value="<%= defaults.kpiBonus %>" step="0.01" min="0" oninput="recalc()"></div>
          </div>

          <!-- Results -->
          <div style="flex:1;min-width:260px;">
            <div style="padding:24px;background:linear-gradient(135deg,#f0fdfa,#ecfeff);border-radius:14px;text-align:center;margin-bottom:16px;">
              <div style="font-size:12px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:1px;">Your Estimated Payout</div>
              <div id="resultPayout" style="font-size:42px;font-weight:900;color:var(--primary);line-height:1.1;margin:8px 0;">$0.00</div>
              <div id="resultKpiTag" style="display:none;font-size:11px;font-weight:700;color:var(--success);background:#d1fae5;padding:2px 10px;border-radius:4px;display:inline-block;">KPI Bonus Earned!</div>
            </div>

            <div style="background:#fff;border:1px solid var(--border);border-radius:10px;padding:16px;">
              <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #f1f5f9;font-size:12px;"><span style="color:var(--muted);">Gallons at Baseline</span><span id="resultGalBaseline" style="font-weight:700;">—</span></div>
              <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #f1f5f9;font-size:12px;"><span style="color:var(--muted);">Gallons at Your MPG</span><span id="resultGalActual" style="font-weight:700;">—</span></div>
              <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #f1f5f9;font-size:12px;"><span style="color:var(--success);font-weight:600;">Gallons Saved</span><span id="resultGalSaved" style="font-weight:700;color:var(--success);">—</span></div>
              <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #f1f5f9;font-size:12px;"><span style="color:var(--muted);">Fuel Savings ($)</span><span id="resultSavingsUsd" style="font-weight:700;">—</span></div>
              <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #f1f5f9;font-size:12px;"><span style="color:var(--muted);">Your Share</span><span id="resultDriverShare" style="font-weight:700;">—</span></div>
              <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #f1f5f9;font-size:12px;"><span style="color:var(--muted);">KPI Bonus</span><span id="resultKpiUsd" style="font-weight:700;">—</span></div>
              <div style="display:flex;justify-content:space-between;padding:8px 0;font-size:14px;font-weight:900;border-top:2px solid var(--border);"><span style="color:var(--primary);">Total Payout</span><span id="resultTotal" style="color:var(--primary);">—</span></div>
            </div>
          </div>
        </div>
      </div>

      <script>
      function recalc() {
        var miles = parseFloat(document.getElementById('calcMiles').value) || 0;
        var mpg = parseFloat(document.getElementById('calcMpg').value) || 0;
        var baseline = parseFloat(document.getElementById('calcBaseline').value) || 0;
        var target = parseFloat(document.getElementById('calcTarget').value) || 0;
        var fuelPrice = parseFloat(document.getElementById('calcFuelPrice').value) || 0;
        var driverPct = parseFloat(document.getElementById('calcDriverPct').value) || 0;
        var kpiRate = parseFloat(document.getElementById('calcKpi').value) || 0;

        var galBaseline = baseline > 0 ? miles / baseline : 0;
        var galActual = mpg > 0 ? miles / mpg : 0;
        var galSaved = Math.max(0, galBaseline - galActual);
        var savingsUsd = galSaved * fuelPrice;
        var driverShare = savingsUsd * driverPct / 100;

        var kpiEarned = mpg >= target && target > 0;
        var kpiUsd = kpiEarned ? galSaved * kpiRate : 0;
        var total = driverShare + kpiUsd;

        document.getElementById('resultGalBaseline').textContent = galBaseline.toFixed(1) + ' gal';
        document.getElementById('resultGalActual').textContent = galActual.toFixed(1) + ' gal';
        document.getElementById('resultGalSaved').textContent = galSaved.toFixed(1) + ' gal';
        document.getElementById('resultSavingsUsd').textContent = '$' + savingsUsd.toFixed(2);
        document.getElementById('resultDriverShare').textContent = '$' + driverShare.toFixed(2) + ' (' + driverPct + '%)';
        document.getElementById('resultKpiUsd').textContent = kpiEarned ? '$' + kpiUsd.toFixed(2) : '$0.00';
        document.getElementById('resultTotal').textContent = '$' + total.toFixed(2);
        document.getElementById('resultPayout').textContent = '$' + total.toFixed(2);

        var kpiTag = document.getElementById('resultKpiTag');
        kpiTag.style.display = kpiEarned ? 'inline-block' : 'none';

        // Color code payout
        document.getElementById('resultPayout').style.color = total > 0 ? 'var(--success)' : 'var(--muted)';
      }
      recalc();
      </script>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>
