<%- include('../partials/head') %>
<div class="app-wrap">
  <%- include('../partials/sidebar', { settings, user, page, tab: '' }) %>
  <div class="main">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px;"><button class="mob-toggle" onclick="openSidebar()">☰</button><h2>📋 Standard Operating Procedures</h2></div>
    </div>
    <div class="content">
      <% if (sops.length === 0) { %>
        <div class="empty"><span class="e-icon">📋</span><div class="e-text">No SOPs available</div></div>
      <% } else { %>
        <% sops.forEach(s => { %>
          <a href="/client/sops/<%= s.id %>" class="item-card" style="text-decoration:none;color:inherit;">
            <div class="ic-main">
              <div class="ic-name"><%= s.title %></div>
              <div class="ic-sub"><%= s.category || '' %><%= s.department ? ' · ' + s.department : '' %> · v<%= s.version %></div>
            </div>
            <span class="badge active">View</span>
          </a>
        <% }) %>
      <% } %>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>
