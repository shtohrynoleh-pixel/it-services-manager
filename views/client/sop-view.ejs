<%- include('../partials/head') %>
<div class="app-wrap">
  <%- include('../partials/sidebar', { settings, user, page, tab: '' }) %>
  <div class="main">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px;"><button class="mob-toggle" onclick="openSidebar()">☰</button><h2><a href="/client/sops" style="opacity:0.4;text-decoration:none;">📋</a> → <%= sop.title %></h2></div>
    </div>
    <div class="content">
      <div class="card">
        <h3><%= sop.title %></h3>
        <div style="font-size:12px;color:var(--muted);margin-bottom:16px;"><%= sop.category || '' %> · v<%= sop.version %><%= sop.department ? ' · ' + sop.department : '' %></div>
        <% if (sop.description) { %><p style="font-size:13px;margin-bottom:16px;"><%= sop.description %></p><% } %>
        <% if (sop.purpose) { %><div style="margin-bottom:12px;"><strong>Purpose:</strong> <%= sop.purpose %></div><% } %>
      </div>

      <% if (steps.length > 0) { %>
      <div class="card">
        <h3>Steps</h3>
        <% steps.forEach((st, i) => { %>
          <div style="display:flex;gap:12px;padding:12px 0;border-bottom:1px solid #f1f5f9;">
            <div style="width:28px;height:28px;border-radius:50%;background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;flex-shrink:0;"><%= st.step_number || i+1 %></div>
            <div>
              <div style="font-weight:700;font-size:13px;"><%= st.title %></div>
              <% if (st.description) { %><div style="font-size:12px;color:var(--muted);margin-top:2px;"><%= st.description %></div><% } %>
              <% if (st.responsible) { %><div style="font-size:11px;color:var(--primary);margin-top:2px;">Responsible: <%= st.responsible %></div><% } %>
              <% if (st.warning) { %><div style="font-size:11px;color:var(--danger);margin-top:2px;">⚠️ <%= st.warning %></div><% } %>
            </div>
          </div>
        <% }) %>
      </div>
      <% } %>

      <!-- Acknowledgment -->
      <div class="card">
        <% if (myAck) { %>
          <div style="text-align:center;padding:12px;">
            <div style="font-size:32px;margin-bottom:8px;">✅</div>
            <div style="font-weight:700;color:var(--success);">You acknowledged this SOP</div>
            <div style="font-size:12px;color:var(--muted);"><%= myAck.acknowledged_at %></div>
          </div>
        <% } else { %>
          <form method="POST" action="/client/sops/<%= sop.id %>/acknowledge" style="text-align:center;padding:12px;">
            <p style="font-size:13px;margin-bottom:12px;">I have read and understood this SOP.</p>
            <button type="submit" class="btn btn-primary">✅ Acknowledge</button>
          </form>
        <% } %>
      </div>

      <a href="/client/sops" class="btn btn-sm">← Back to SOPs</a>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>
