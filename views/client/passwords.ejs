<%- include('../partials/head') %>
<div class="app-wrap">
  <%- include('../partials/sidebar', { settings, user, page, tab: '' }) %>
  <div class="main">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px;"><button class="mob-toggle" onclick="openSidebar()">☰</button><h2>🔑 Shared Passwords</h2></div>
    </div>
    <div class="content">
      <% if (entries.length === 0) { %>
        <div class="empty"><span class="e-icon">🔑</span><div class="e-text">No shared passwords available</div><div style="font-size:12px;color:var(--muted);">Your IT admin can share passwords with your team.</div></div>
      <% } else { %>
        <input type="text" id="pwSearch" placeholder="Search..." oninput="filterPw()" style="margin-bottom:16px;padding:8px 12px;font-size:12px;width:100%;max-width:300px;">
        <% entries.forEach(e => { %>
          <div class="card pw-card" data-search="<%= [e.title,e.username,e.category].filter(Boolean).join(' ').toLowerCase() %>" style="margin-bottom:10px;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;">
              <div>
                <h3 style="margin-bottom:2px;font-size:14px;"><%= e.title %></h3>
                <div style="font-size:11px;color:var(--muted);"><%= e.category %><%= e.share_type === 'department' && e.share_dept ? ' · ' + e.share_dept : '' %></div>
              </div>
              <% if (e.url) { %><a href="<%= e.url %>" target="_blank" class="btn btn-sm">🔗 Open</a><% } %>
            </div>
            <div style="margin-top:10px;display:flex;gap:16px;flex-wrap:wrap;">
              <% if (e.username) { %>
                <div>
                  <div style="font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;">Username</div>
                  <div style="display:flex;align-items:center;gap:6px;margin-top:2px;">
                    <code style="font-size:12px;background:#f1f5f9;padding:2px 8px;border-radius:4px;"><%= e.username %></code>
                    <button onclick="navigator.clipboard.writeText('<%= e.username %>')" style="background:none;border:none;cursor:pointer;font-size:11px;" title="Copy">📋</button>
                  </div>
                </div>
              <% } %>
              <div>
                <div style="font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;">Password</div>
                <div style="display:flex;align-items:center;gap:6px;margin-top:2px;">
                  <code id="pw-<%= e.id %>" style="font-size:12px;background:#f1f5f9;padding:2px 8px;border-radius:4px;">••••••••</code>
                  <button onclick="var el=document.getElementById('pw-<%= e.id %>');el.textContent=el.textContent==='••••••••'?'<%= (e.password_enc||'').replace(/'/g,"\\'") %>':'••••••••'" style="background:none;border:none;cursor:pointer;font-size:11px;" title="Show/Hide">👁️</button>
                  <button onclick="navigator.clipboard.writeText('<%= (e.password_enc||'').replace(/'/g,"\\'") %>')" style="background:none;border:none;cursor:pointer;font-size:11px;" title="Copy">📋</button>
                </div>
              </div>
            </div>
            <% if (e.notes) { %><div style="font-size:11px;color:var(--muted);margin-top:8px;"><%= e.notes %></div><% } %>
          </div>
        <% }) %>
        <script>
        function filterPw(){
          var q=document.getElementById('pwSearch').value.toLowerCase();
          document.querySelectorAll('.pw-card').forEach(function(c){
            c.style.display=(!q||c.dataset.search.indexOf(q)>=0)?'':'none';
          });
        }
        </script>
      <% } %>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>
