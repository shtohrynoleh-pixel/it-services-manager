<%- include('../partials/head') %>
<div class="app-wrap">
  <%- include('../partials/sidebar', { settings, user, page, tab: '' }) %>
  <div class="main">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px;"><button class="mob-toggle" onclick="openSidebar()">☰</button><h2><i class="ti ti-key"></i> Shared Passwords</h2></div>
      <button class="btn btn-primary btn-sm" onclick="document.getElementById('addPwModal').classList.add('open')">+ Add Password</button>
    </div>
    <div class="content">
      <% if (entries.length === 0) { %>
        <div class="empty"><span class="e-icon"><i class="ti ti-key" style="font-size:40px;"></i></span><div class="e-text">No shared passwords</div><button class="btn btn-primary btn-sm" onclick="document.getElementById('addPwModal').classList.add('open')">+ Add First Password</button></div>
      <% } else { %>
        <input type="text" id="pwSearch" placeholder="Search..." oninput="filterPw()" style="margin-bottom:16px;padding:8px 12px;font-size:12px;width:100%;max-width:300px;">
        <% entries.forEach(e => { %>
          <div class="card pw-card" data-search="<%= [e.title,e.username,e.category].filter(Boolean).join(' ').toLowerCase() %>" style="margin-bottom:10px;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;">
              <div>
                <h3 style="margin-bottom:2px;font-size:14px;"><%= e.title %></h3>
                <div style="font-size:11px;color:var(--muted);"><%= e.category %></div>
              </div>
              <% if (e.url) { %><a href="<%= e.url %>" target="_blank" class="btn btn-sm"><i class="ti ti-external-link"></i> Open</a><% } %>
            </div>
            <div style="margin-top:10px;display:flex;gap:16px;flex-wrap:wrap;">
              <% if (e.username) { %>
                <div>
                  <div style="font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;">Username</div>
                  <div style="display:flex;align-items:center;gap:6px;margin-top:2px;">
                    <code style="font-size:12px;background:#f1f5f9;padding:2px 8px;border-radius:4px;"><%= e.username %></code>
                    <button onclick="navigator.clipboard.writeText('<%= e.username %>')" style="background:none;border:none;cursor:pointer;font-size:11px;" title="Copy"><i class="ti ti-copy"></i></button>
                  </div>
                </div>
              <% } %>
              <div>
                <div style="font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;">Password</div>
                <div style="display:flex;align-items:center;gap:6px;margin-top:2px;">
                  <code id="pw-<%= e.id %>" style="font-size:12px;background:#f1f5f9;padding:2px 8px;border-radius:4px;">••••••••</code>
                  <button onclick="var el=document.getElementById('pw-<%= e.id %>');el.textContent=el.textContent==='••••••••'?'<%= (e.password_enc||'').replace(/'/g,"\\'") %>':'••••••••'" style="background:none;border:none;cursor:pointer;font-size:11px;" title="Show/Hide"><i class="ti ti-eye"></i></button>
                  <button onclick="navigator.clipboard.writeText('<%= (e.password_enc||'').replace(/'/g,"\\'") %>')" style="background:none;border:none;cursor:pointer;font-size:11px;" title="Copy"><i class="ti ti-copy"></i></button>
                </div>
              </div>
            </div>
            <% if (e.notes) { %><div style="font-size:11px;color:var(--muted);margin-top:8px;"><%= e.notes %></div><% } %>
          </div>
        <% }) %>
        <script>function filterPw(){var q=document.getElementById('pwSearch').value.toLowerCase();document.querySelectorAll('.pw-card').forEach(function(c){c.style.display=(!q||c.dataset.search.indexOf(q)>=0)?'':'none';});}</script>
      <% } %>

      <div class="modal-bg" id="addPwModal" onclick="if(event.target===this)this.classList.remove('open')">
        <div class="modal">
          <h3>Add Shared Password</h3>
          <form method="POST" action="/client/passwords">
            <div class="form-row"><div class="form-group"><label>Title *</label><input type="text" name="title" required placeholder="e.g. Company WiFi, VPN Login..."></div><div class="form-group"><label>Category</label><select name="category"><option>General</option><option>WiFi</option><option>Email</option><option>VPN</option><option>Software</option><option>Server</option><option>Cloud</option><option>Other</option></select></div></div>
            <div class="form-row"><div class="form-group"><label>Username</label><input type="text" name="username" placeholder="admin@company.com"></div><div class="form-group"><label>Password</label><input type="text" name="password_val" placeholder="Enter password"></div></div>
            <div class="form-group"><label>URL</label><input type="text" name="url" placeholder="https://..."></div>
            <div class="form-group"><label>Notes</label><textarea name="notes" placeholder="Any extra info..."></textarea></div>
            <div class="form-actions"><button type="submit" class="btn btn-primary">Save</button><button type="button" class="btn" onclick="document.getElementById('addPwModal').classList.remove('open')">Cancel</button></div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>
