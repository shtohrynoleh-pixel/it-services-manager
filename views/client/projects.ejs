<%- include('../partials/head') %>
<div class="app-wrap">
  <%- include('../partials/sidebar', { settings, user, page, tab: '' }) %>
  <div class="main">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px;"><button class="mob-toggle" onclick="openSidebar()">☰</button><h2><i class="ti ti-folder"></i> Projects</h2></div>
      <button class="btn btn-primary btn-sm" onclick="document.getElementById('addProjectModal').classList.add('open')">+ New Project</button>
    </div>
    <div class="content">
      <% if (projects.length === 0) { %>
        <div class="empty"><span class="e-icon"><i class="ti ti-folder" style="font-size:40px;"></i></span><div class="e-text">No projects yet</div><button class="btn btn-primary btn-sm" onclick="document.getElementById('addProjectModal').classList.add('open')">+ Create First Project</button></div>
      <% } else { %>
        <% projects.forEach(p => {
          const pct = p.taskTotal > 0 ? Math.round(p.taskDone / p.taskTotal * 100) : 0;
          const st = statuses.find(s => s.name === p.status);
        %>
          <div class="card" style="margin-bottom:12px;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px;">
              <div>
                <h3 style="margin-bottom:4px;"><%= p.name %></h3>
                <div style="font-size:12px;color:var(--muted);"><%= p.description || '' %></div>
              </div>
              <span class="badge" style="background:<%= st ? st.color+'20' : '#f1f5f9' %>;color:<%= st ? st.color : '#64748b' %>;"><%= p.status %></span>
            </div>
            <div style="margin-top:10px;display:flex;gap:16px;font-size:12px;color:var(--muted);">
              <% if (p.due_date) { %><span>Due: <strong><%= p.due_date %></strong></span><% } %>
              <span>Tasks: <strong><%= p.taskDone %>/<%= p.taskTotal %></strong></span>
            </div>
            <% if (p.taskTotal > 0) { %>
              <div style="margin-top:8px;height:6px;background:#e2e8f0;border-radius:4px;overflow:hidden;">
                <div style="height:100%;width:<%= pct %>%;background:<%= pct >= 100 ? 'var(--success)' : 'var(--primary)' %>;border-radius:4px;"></div>
              </div>
              <div style="font-size:10px;color:var(--muted);margin-top:2px;"><%= pct %>% complete</div>
            <% } %>
          </div>
        <% }) %>
      <% } %>

      <div class="modal-bg" id="addProjectModal" onclick="if(event.target===this)this.classList.remove('open')">
        <div class="modal">
          <h3>New Project</h3>
          <form method="POST" action="/client/projects">
            <div class="form-group"><label>Project Name *</label><input type="text" name="name" required placeholder="e.g. Office Network Upgrade"></div>
            <div class="form-group"><label>Description</label><textarea name="description" placeholder="What needs to be done..."></textarea></div>
            <div class="form-group"><label>Target Date</label><input type="date" name="due_date"></div>
            <div class="form-actions"><button type="submit" class="btn btn-primary">Create</button><button type="button" class="btn" onclick="document.getElementById('addProjectModal').classList.remove('open')">Cancel</button></div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>
