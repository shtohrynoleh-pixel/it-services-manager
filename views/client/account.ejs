<%- include('../partials/head') %>
<div class="app-wrap">
  <%- include('../partials/sidebar', { settings, user, page, tab: '' }) %>
  <div class="main">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px;"><button class="mob-toggle" onclick="openSidebar()">☰</button><h2>👤 My Account</h2></div>
    </div>
    <div class="content">
      <div class="card">
        <h3>👤 Profile</h3>
        <form method="POST" action="/client/account/profile">
          <div class="form-row">
            <div class="form-group"><label>Username</label><input type="text" value="<%= currentUser.username %>" disabled style="background:#f1f5f9;"></div>
            <div class="form-group"><label>Display Name</label><input type="text" name="full_name" value="<%= currentUser.full_name || '' %>" placeholder="Your Name"></div>
          </div>
          <div class="form-row">
            <div class="form-group"><label>Email</label><input type="email" name="email" value="<%= currentUser.email || '' %>" placeholder="you@email.com"></div>
            <div class="form-group"><label>Phone</label><input type="text" name="phone" value="<%= currentUser.phone || '' %>" placeholder="+1 555-0100"></div>
          </div>
          <button type="submit" class="btn btn-primary">Save Profile</button>
        </form>
      </div>

      <div class="card">
        <h3>🔐 Change Password</h3>
        <form method="POST" action="/client/account/password">
          <div class="form-row">
            <div class="form-group"><label>Current Password</label><input type="password" name="current_password" required></div>
            <div class="form-group"><label>New Password</label><input type="password" name="new_password" required minlength="4" placeholder="Min 4 characters"></div>
          </div>
          <button type="submit" class="btn btn-primary">Update Password</button>
        </form>
      </div>

      <div class="card">
        <h3>🔐 Two-Factor Authentication</h3>
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;">
          <div style="width:40px;height:40px;border-radius:10px;background:<%= has2fa ? '#d1fae5' : '#fee2e2' %>;display:flex;align-items:center;justify-content:center;font-size:20px;"><%= has2fa ? '✅' : '❌' %></div>
          <div>
            <div style="font-weight:700;font-size:14px;"><%= has2fa ? '2FA is Enabled' : '2FA is Disabled' %></div>
            <div style="font-size:12px;color:var(--muted);"><%= has2fa ? 'Your account is secured with an authenticator app' : 'Add an extra layer of security to your login' %></div>
          </div>
        </div>
        <a href="/client/account/2fa-setup" class="btn btn-sm <%= has2fa ? '' : 'btn-primary' %>"><%= has2fa ? '⚙️ Manage 2FA' : '🔐 Set Up 2FA' %></a>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>
