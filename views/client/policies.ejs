<%- include('../partials/head') %>
<div class="app-wrap">
  <%- include('../partials/sidebar', { settings, user, page, tab: '' }) %>
  <div class="main">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px;"><button class="mob-toggle" onclick="openSidebar()">☰</button><h2><i class="ti ti-shield-check"></i> Security Policies</h2></div>
      <button class="btn btn-primary btn-sm" onclick="document.getElementById('addPolicyModal').classList.add('open')">+ Suggest Policy</button>
    </div>
    <div class="content">
      <% if (policies.length === 0) { %>
        <div class="empty"><span class="e-icon"><i class="ti ti-shield-check" style="font-size:40px;"></i></span><div class="e-text">No policies available</div></div>
      <% } else { %>
        <% policies.forEach(p => { %>
          <a href="/client/policies/<%= p.id %>" class="item-card" style="text-decoration:none;color:inherit;">
            <div class="ic-main">
              <div class="ic-name"><%= p.title %></div>
              <div class="ic-sub"><%= p.category || '' %> · v<%= p.version %></div>
            </div>
            <span class="badge <%= p.status === 'published' ? 'active' : 'draft' %>"><%= p.status %></span>
          </a>
        <% }) %>
      <% } %>

      <div class="modal-bg" id="addPolicyModal" onclick="if(event.target===this)this.classList.remove('open')">
        <div class="modal">
          <h3>Suggest Security Policy</h3>
          <p style="font-size:12px;color:var(--muted);margin-bottom:12px;">Submit a draft policy. Your IT admin will review and publish it.</p>
          <form method="POST" action="/client/policies">
            <div class="form-group"><label>Title *</label><input type="text" name="title" required placeholder="e.g. Bring Your Own Device Policy"></div>
            <div class="form-group"><label>Category</label><select name="category"><option>General</option><option>Security</option><option>Devices</option><option>Network</option><option>Data</option><option>Email</option><option>Remote Work</option></select></div>
            <div class="form-group"><label>Description</label><input type="text" name="description" placeholder="Brief summary..."></div>
            <div class="form-group"><label>Policy Content</label><textarea name="content" rows="6" placeholder="Write the policy text..."></textarea></div>
            <div class="form-actions"><button type="submit" class="btn btn-primary">Submit Draft</button><button type="button" class="btn" onclick="document.getElementById('addPolicyModal').classList.remove('open')">Cancel</button></div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>
