<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= settings.business_name || 'IT Forge' %> — IT Management for Growing Companies</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.40.0/dist/tabler-icons.min.css">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Inter',sans-serif;color:#0f172a;background:#fff;-webkit-font-smoothing:antialiased;}
a{color:#0891b2;text-decoration:none;}

nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:0 40px;height:64px;display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,0.95);backdrop-filter:blur(20px);border-bottom:1px solid rgba(0,0,0,0.06);}
.logo{display:flex;align-items:center;gap:10px;font-size:18px;font-weight:900;color:#0f172a;letter-spacing:-0.3px;}
.logo img{height:32px;border-radius:8px;}
.logo span{color:#0891b2;}
.nav-links{display:flex;gap:28px;align-items:center;}
.nav-links a{font-size:13px;font-weight:600;color:#475569;}
.nav-links a:hover{color:#0891b2;}
.nav-cta{padding:9px 22px;background:#0891b2;color:#fff !important;border-radius:8px;font-weight:700;font-size:13px;transition:all 0.15s;}
.nav-cta:hover{background:#0e7490;transform:translateY(-1px);box-shadow:0 4px 12px rgba(8,145,178,0.25);}

.hero{padding:150px 40px 80px;text-align:center;background:linear-gradient(180deg,#f0fdfa 0%,#fff 100%);position:relative;overflow:hidden;}
.hero::before{content:'';position:absolute;top:-200px;right:-200px;width:500px;height:500px;background:radial-gradient(circle,rgba(8,145,178,0.05) 0%,transparent 70%);border-radius:50%;}
.hero-inner{position:relative;z-index:1;max-width:680px;margin:0 auto;}
.hero-badge{display:inline-block;padding:6px 16px;background:rgba(8,145,178,0.08);color:#0891b2;border-radius:20px;font-size:12px;font-weight:700;margin-bottom:20px;}
.hero h1{font-size:clamp(30px,4.5vw,50px);font-weight:900;line-height:1.1;margin-bottom:18px;letter-spacing:-1px;}
.hero h1 span{background:linear-gradient(135deg,#0891b2,#06b6d4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.hero p{font-size:17px;color:#64748b;line-height:1.7;margin-bottom:32px;}
.hero-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;}
.btn-p{padding:14px 32px;background:#0891b2;color:#fff;border-radius:10px;font-size:15px;font-weight:700;box-shadow:0 4px 16px rgba(8,145,178,0.25);transition:all 0.2s;}
.btn-p:hover{background:#0e7490;transform:translateY(-2px);box-shadow:0 8px 24px rgba(8,145,178,0.3);}
.btn-o{padding:14px 32px;border:2px solid #e2e8f0;color:#475569;border-radius:10px;font-size:15px;font-weight:700;transition:all 0.2s;}
.btn-o:hover{border-color:#0891b2;color:#0891b2;}

.section{padding:72px 40px;max-width:1000px;margin:0 auto;}
.section-alt{background:#f8fafc;}
.s-label{font-size:12px;font-weight:700;color:#0891b2;text-transform:uppercase;letter-spacing:1.5px;text-align:center;margin-bottom:10px;}
.s-title{font-size:30px;font-weight:900;text-align:center;margin-bottom:10px;letter-spacing:-0.5px;}
.s-sub{font-size:15px;color:#64748b;text-align:center;max-width:560px;margin:0 auto 40px;line-height:1.6;}

/* What you get */
.offer-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.offer-card{padding:24px;border-radius:14px;background:#fff;border:1px solid #e2e8f0;transition:all 0.15s;}
.offer-card:hover{border-color:#0891b2;box-shadow:0 4px 20px rgba(8,145,178,0.06);transform:translateY(-2px);}
.offer-card i{font-size:28px;color:#0891b2;margin-bottom:10px;display:block;}
.offer-card h3{font-size:15px;font-weight:800;margin-bottom:4px;}
.offer-card p{font-size:12px;color:#64748b;line-height:1.6;}

/* Platform */
.plat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;}
.plat-item{padding:16px;background:#fff;border:1px solid #e2e8f0;border-radius:10px;text-align:center;}
.plat-item i{font-size:24px;color:#0891b2;margin-bottom:6px;display:block;}
.plat-item h4{font-size:12px;font-weight:800;margin-bottom:2px;}
.plat-item p{font-size:10px;color:#64748b;}

/* How */
.how-steps{display:flex;gap:0;counter-reset:step;}
.how-step{flex:1;text-align:center;padding:24px 16px;position:relative;}
.how-step::after{content:'';position:absolute;top:32px;right:-12px;width:24px;height:2px;background:#e2e8f0;}
.how-step:last-child::after{display:none;}
.how-num{width:36px;height:36px;border-radius:50%;background:#0891b2;color:#fff;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:900;margin:0 auto 10px;}
.how-step h3{font-size:13px;font-weight:800;margin-bottom:4px;}
.how-step p{font-size:11px;color:#64748b;line-height:1.5;}

/* Services */
<% if (services.length === 0) { %>.svc-sec{display:none;}<% } %>
.svc-list{display:flex;flex-direction:column;gap:10px;}
.svc-row{display:flex;align-items:center;gap:14px;padding:16px 20px;background:#fff;border:1px solid #e2e8f0;border-radius:10px;transition:all 0.12s;}
.svc-row:hover{border-color:#0891b2;box-shadow:0 2px 12px rgba(8,145,178,0.05);}
.svc-row i{font-size:22px;color:#0891b2;flex-shrink:0;}
.svc-row-info{flex:1;}
.svc-row h3{font-size:14px;font-weight:800;}
.svc-row p{font-size:11px;color:#64748b;margin-top:1px;}
.svc-row-price{text-align:right;flex-shrink:0;}
.svc-row-price .amt{font-size:18px;font-weight:900;color:#0891b2;}
.svc-row-price .per{font-size:10px;color:#94a3b8;}

/* Contact */
.contact{padding:72px 40px;background:#f8fafc;}
.contact-inner{max-width:1000px;margin:0 auto;display:flex;gap:40px;}
.contact-left{flex:1;}
.contact-left h2{font-size:28px;font-weight:900;margin-bottom:10px;letter-spacing:-0.5px;}
.contact-left p{font-size:14px;color:#64748b;line-height:1.7;margin-bottom:20px;}
.contact-detail{display:flex;align-items:center;gap:10px;font-size:13px;color:#475569;margin-bottom:8px;}
.contact-detail i{font-size:18px;color:#0891b2;}
.contact-right{flex:1.1;background:#fff;border:1px solid #e2e8f0;border-radius:16px;padding:28px;box-shadow:0 4px 20px rgba(0,0,0,0.03);}
.contact-right label{display:block;font-size:10px;font-weight:700;color:#475569;margin-bottom:3px;margin-top:12px;text-transform:uppercase;letter-spacing:0.3px;}
.contact-right input,.contact-right textarea{width:100%;padding:10px 12px;border:1px solid #e2e8f0;border-radius:8px;font-size:13px;font-family:inherit;outline:none;}
.contact-right input:focus,.contact-right textarea:focus{border-color:#0891b2;box-shadow:0 0 0 3px rgba(8,145,178,0.06);}
.contact-right textarea{resize:vertical;min-height:80px;}
.contact-right button{margin-top:16px;width:100%;padding:13px;background:#0891b2;color:#fff;border:none;border-radius:10px;font-size:14px;font-weight:700;cursor:pointer;font-family:inherit;transition:all 0.15s;}
.contact-right button:hover{background:#0e7490;}

footer{padding:40px;background:#0f172a;color:#94a3b8;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;}
.f-brand{font-size:15px;font-weight:800;color:#fff;}
.f-links{display:flex;gap:20px;}
.f-links a{font-size:12px;color:#64748b;font-weight:600;}
.f-links a:hover{color:#22d3ee;}
.f-copy{width:100%;text-align:center;padding-top:20px;border-top:1px solid #1e293b;font-size:11px;margin-top:8px;}

@media(max-width:768px){
  nav{padding:0 16px;}.nav-links a:not(.nav-cta){display:none;}
  .hero{padding:110px 20px 60px;}
  .section,.contact{padding:48px 20px;}
  .offer-grid{grid-template-columns:1fr;}
  .plat-grid{grid-template-columns:1fr 1fr;}
  .how-steps{flex-direction:column;gap:0;}.how-step::after{display:none;}
  .contact-inner{flex-direction:column;}
  footer{padding:24px 16px;flex-direction:column;text-align:center;}.f-links{justify-content:center;}
}
</style>
</head>
<body>

<nav>
  <div class="logo">
    <% if (settings.business_logo) { %><img src="<%= settings.business_logo %>"><% } else { %><i class="ti ti-hammer" style="font-size:24px;color:#0891b2;"></i><% } %>
    IT <span>Forge</span>
  </div>
  <div class="nav-links">
    <a href="#what">What You Get</a>
    <a href="#platform">Platform</a>
    <a href="#contact">Contact</a>
    <a href="/login" class="nav-cta">Client Portal</a>
  </div>
</nav>

<div class="hero">
  <div class="hero-inner">
    <div class="hero-badge">IT Management + Platform + Guidance</div>
    <h1>Your IT Partner.<br><span>Not Just a Vendor.</span></h1>
    <p>I work directly with your team to manage your technology, build your processes, and keep everything running — while giving you a platform to see it all in one place.</p>
    <div class="hero-btns">
      <a href="#contact" class="btn-p">Let's Talk</a>
      <a href="#what" class="btn-o">See How It Works</a>
    </div>
  </div>
</div>

<!-- What you get -->
<div class="section" id="what">
  <div class="s-label">What You Get</div>
  <div class="s-title">Hands-On IT Management</div>
  <div class="s-sub">I don't just fix things when they break. I work with your team to build solid IT foundations — then I manage them day to day so you don't have to.</div>
  <div class="offer-grid">
    <div class="offer-card"><i class="ti ti-headset"></i><h3>Direct Support</h3><p>One point of contact who knows your setup inside out. No call centers, no ticket queues — you reach me directly. Response within hours on business days.</p></div>
    <div class="offer-card"><i class="ti ti-activity"></i><h3>Monitoring & Alerts</h3><p>I set up 24/7 automated monitoring for your servers, websites, and network. If something goes down overnight, I see it first thing and fix it.</p></div>
    <div class="offer-card"><i class="ti ti-shield-lock"></i><h3>Security & Policies</h3><p>Antivirus, email filtering, password policies, 2FA setup, security documentation — I build it with your team and make sure everyone follows it.</p></div>
    <div class="offer-card"><i class="ti ti-users-group"></i><h3>Team Guidance</h3><p>I work alongside your people — training them on best practices, helping them document procedures, and building SOPs they'll actually use.</p></div>
    <div class="offer-card"><i class="ti ti-device-desktop"></i><h3>Asset & Inventory Tracking</h3><p>Every computer, subscription, license, and piece of equipment tracked in one place. Know exactly what you have, what it costs, and who's using it.</p></div>
    <div class="offer-card"><i class="ti ti-arrows-sort"></i><h3>Process Building</h3><p>I help your team create and visualize their workflows — onboarding, offboarding, incident response, change management — so nothing falls through the cracks.</p></div>
  </div>
</div>

<!-- Platform -->
<div class="section section-alt" id="platform">
  <div class="s-label">Your Dashboard</div>
  <div class="s-title">A Platform Built for Your Team</div>
  <div class="s-sub">Every client gets access to a dedicated portal where you and your team can see everything, submit requests, chat, and stay organized.</div>
  <div class="plat-grid">
    <div class="plat-item"><i class="ti ti-dashboard"></i><h4>Company Dashboard</h4><p>Users, servers, subscriptions, invoices — all in one view</p></div>
    <div class="plat-item"><i class="ti ti-ticket"></i><h4>Support Tickets</h4><p>Submit requests and track status from any screen</p></div>
    <div class="plat-item"><i class="ti ti-message-circle"></i><h4>Team Chat</h4><p>Real-time messaging with your team and IT admin</p></div>
    <div class="plat-item"><i class="ti ti-activity"></i><h4>Live Monitoring</h4><p>See uptime, response times, and alerts in real-time</p></div>
    <div class="plat-item"><i class="ti ti-folder"></i><h4>File Management</h4><p>Shared folders with access controls and storage quotas</p></div>
    <div class="plat-item"><i class="ti ti-list-check"></i><h4>SOPs & Policies</h4><p>Build, publish, and track acknowledgment of procedures</p></div>
    <div class="plat-item"><i class="ti ti-git-branch"></i><h4>Process Flows</h4><p>Visual flowcharts for any business process</p></div>
    <div class="plat-item"><i class="ti ti-key"></i><h4>Password Vault</h4><p>Shared credentials with show/hide and access control</p></div>
    <div class="plat-item"><i class="ti ti-trophy"></i><h4>Gamification</h4><p>XP points, ranks, and leaderboard to keep teams engaged</p></div>
  </div>
</div>

<!-- How it works -->
<div class="section">
  <div class="s-label">Getting Started</div>
  <div class="s-title">Simple as 1-2-3</div>
  <div class="how-steps">
    <div class="how-step"><div class="how-num">1</div><h3>Free Consultation</h3><p>We talk about your setup, your pain points, and what you actually need. No sales pitch.</p></div>
    <div class="how-step"><div class="how-num">2</div><h3>Custom Plan</h3><p>I propose a service plan that fits your team size and budget. You only pay for what you need.</p></div>
    <div class="how-step"><div class="how-num">3</div><h3>Onboarding</h3><p>I set up monitoring, security, and your portal. Your team gets access and training within a week.</p></div>
    <div class="how-step"><div class="how-num">4</div><h3>Ongoing Partnership</h3><p>I manage your IT week to week. You focus on your business. We grow together.</p></div>
  </div>
</div>

<!-- Services -->
<% if (services.length > 0) { %>
<div class="section section-alt svc-sec" id="services">
  <div class="s-label">Services</div>
  <div class="s-title">What I Can Do for You</div>
  <div class="s-sub">Pick individual services or combine them into a monthly plan that works for your budget.</div>
  <%
    var svcIcons = {'Bundle':'ti ti-package','Managed IT':'ti ti-headset','Monitoring':'ti ti-activity','Email':'ti ti-mail','Backup':'ti ti-database','Security':'ti ti-shield-lock','Hardware':'ti ti-device-desktop','Cloud':'ti ti-cloud','Consulting':'ti ti-bulb','Web':'ti ti-world','Communication':'ti ti-phone','HR-IT':'ti ti-user-plus'};
  %>
  <div class="svc-list">
    <% services.forEach(s => { %>
      <div class="svc-row">
        <i class="<%= svcIcons[s.category] || 'ti ti-settings' %>"></i>
        <div class="svc-row-info">
          <h3><%= s.name %></h3>
          <p><%= (s.description || '').split('\n')[0].substring(0, 100) %><%= (s.description || '').length > 100 ? '...' : '' %></p>
        </div>
        <div class="svc-row-price">
          <% if (s.base_price > 0) { %>
            <div class="amt">$<%= s.base_price.toLocaleString() %></div>
            <div class="per"><%= s.price_type === 'monthly' ? '/month' : s.price_type === 'per-user' ? '/user/mo' : s.price_type === 'hourly' ? '/hour' : 'one-time' %></div>
          <% } else { %>
            <div class="amt">Custom</div>
          <% } %>
        </div>
      </div>
    <% }) %>
  </div>
</div>
<% } %>

<!-- Contact -->
<div class="contact" id="contact">
  <div class="contact-inner">
    <div class="contact-left">
      <div class="s-label" style="text-align:left;">Get in Touch</div>
      <h2>Let's Figure Out What You Need</h2>
      <p>Tell me a bit about your company and I'll get back to you within a business day with some ideas. No commitment, no pressure — just an honest conversation about your IT.</p>
      <div style="padding:14px;background:#fff;border:1px solid #e2e8f0;border-radius:10px;margin-bottom:20px;">
        <div style="font-size:12px;font-weight:700;margin-bottom:6px;">Availability</div>
        <div style="font-size:12px;color:#64748b;line-height:1.6;">
          <strong>Monday – Friday</strong> · Business hours<br>
          Monitoring runs 24/7 with automated alerts<br>
          Emergency support available for critical issues
        </div>
      </div>
      <% if (settings.business_email) { %><div class="contact-detail"><i class="ti ti-mail"></i> <%= settings.business_email %></div><% } %>
      <% if (settings.business_phone) { %><div class="contact-detail"><i class="ti ti-phone"></i> <%= settings.business_phone %></div><% } %>
      <% if (settings.business_address) { %><div class="contact-detail"><i class="ti ti-map-pin"></i> <%= settings.business_address %></div><% } %>
    </div>
    <div class="contact-right">
      <% if (typeof submitted !== 'undefined' && submitted) { %>
        <div style="text-align:center;padding:32px 16px;">
          <div style="width:56px;height:56px;border-radius:50%;background:#d1fae5;display:flex;align-items:center;justify-content:center;margin:0 auto 14px;"><i class="ti ti-check" style="font-size:28px;color:#059669;"></i></div>
          <h3 style="margin-bottom:6px;">Message Received</h3>
          <p style="font-size:13px;color:#64748b;">I'll review your message and get back to you within one business day. Talk soon!</p>
        </div>
      <% } else { %>
        <form method="POST" action="/contact">
          <div style="display:flex;gap:10px;">
            <div style="flex:1;"><label>Name *</label><input type="text" name="name" required placeholder="Your name"></div>
            <div style="flex:1;"><label>Company</label><input type="text" name="company" placeholder="Company name"></div>
          </div>
          <div style="display:flex;gap:10px;">
            <div style="flex:1;"><label>Email *</label><input type="email" name="email" required placeholder="you@company.com"></div>
            <div style="flex:1;"><label>Phone</label><input type="text" name="phone" placeholder="(555) 000-0000"></div>
          </div>
          <label>What's going on with your IT?</label>
          <textarea name="message" rows="4" placeholder="How many people on your team? What tech do you use? What's your biggest headache right now?"></textarea>
          <button type="submit"><i class="ti ti-send" style="margin-right:6px;"></i>Send Message</button>
        </form>
      <% } %>
    </div>
  </div>
</div>

<footer>
  <div class="f-brand"><% if (settings.business_logo) { %><img src="<%= settings.business_logo %>" style="height:20px;vertical-align:middle;margin-right:6px;border-radius:4px;"><% } %>IT Forge</div>
  <div class="f-links">
    <a href="#what">Services</a>
    <a href="#contact">Contact</a>
    <a href="/login">Client Portal</a>
  </div>
  <div class="f-copy">&copy; <%= new Date().getFullYear() %> <%= settings.business_name || 'IT Forge' %>. All rights reserved.</div>
</footer>

</body>
</html>
