<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= settings.business_name || 'IT Forge' %> — Managed IT Services for Business</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.40.0/dist/tabler-icons.min.css">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Inter',sans-serif;color:#0f172a;background:#fff;-webkit-font-smoothing:antialiased;}
a{color:#0891b2;text-decoration:none;}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:0 40px;height:64px;display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,0.95);backdrop-filter:blur(20px);border-bottom:1px solid rgba(0,0,0,0.06);}
.logo{display:flex;align-items:center;gap:10px;font-size:18px;font-weight:900;color:#0f172a;letter-spacing:-0.3px;}
.logo img{height:32px;border-radius:8px;}
.logo span{color:#0891b2;}
.nav-links{display:flex;gap:32px;align-items:center;}
.nav-links a{font-size:13px;font-weight:600;color:#475569;transition:color 0.15s;}
.nav-links a:hover{color:#0891b2;}
.nav-cta{padding:9px 22px;background:#0891b2;color:#fff !important;border-radius:8px;font-weight:700;font-size:13px;transition:all 0.15s;}
.nav-cta:hover{background:#0e7490;transform:translateY(-1px);box-shadow:0 4px 12px rgba(8,145,178,0.25);}

/* HERO */
.hero{padding:160px 40px 100px;text-align:center;background:linear-gradient(180deg,#f0fdfa 0%,#ffffff 100%);position:relative;overflow:hidden;}
.hero::before{content:'';position:absolute;top:-200px;right:-200px;width:600px;height:600px;background:radial-gradient(circle,rgba(8,145,178,0.06) 0%,transparent 70%);border-radius:50%;}
.hero::after{content:'';position:absolute;bottom:-100px;left:-100px;width:400px;height:400px;background:radial-gradient(circle,rgba(8,145,178,0.04) 0%,transparent 70%);border-radius:50%;}
.hero-inner{position:relative;z-index:1;}
.hero-badge{display:inline-block;padding:6px 16px;background:rgba(8,145,178,0.08);color:#0891b2;border-radius:20px;font-size:12px;font-weight:700;margin-bottom:20px;letter-spacing:0.3px;}
.hero h1{font-size:clamp(32px,5vw,56px);font-weight:900;line-height:1.08;max-width:720px;margin:0 auto 20px;letter-spacing:-1px;}
.hero h1 span{background:linear-gradient(135deg,#0891b2,#06b6d4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.hero p{font-size:18px;color:#64748b;max-width:540px;margin:0 auto 36px;line-height:1.7;}
.hero-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;}
.btn-primary{padding:14px 36px;background:#0891b2;color:#fff;border-radius:10px;font-size:15px;font-weight:700;box-shadow:0 4px 16px rgba(8,145,178,0.3);transition:all 0.2s;}
.btn-primary:hover{background:#0e7490;transform:translateY(-2px);box-shadow:0 8px 24px rgba(8,145,178,0.35);}
.btn-outline{padding:14px 36px;border:2px solid #e2e8f0;color:#475569;border-radius:10px;font-size:15px;font-weight:700;transition:all 0.2s;}
.btn-outline:hover{border-color:#0891b2;color:#0891b2;transform:translateY(-2px);}

/* TRUST */
.trust{display:flex;justify-content:center;gap:0;padding:0;border-bottom:1px solid #f1f5f9;background:#fff;}
.trust-item{flex:1;max-width:220px;text-align:center;padding:28px 20px;border-right:1px solid #f1f5f9;}
.trust-item:last-child{border-right:none;}
.trust-num{font-size:32px;font-weight:900;color:#0891b2;letter-spacing:-1px;}
.trust-label{font-size:11px;color:#94a3b8;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-top:2px;}

/* SECTION */
.section{padding:80px 40px;}
.section-inner{max-width:1000px;margin:0 auto;}
.section-label{font-size:12px;font-weight:700;color:#0891b2;text-transform:uppercase;letter-spacing:1.5px;text-align:center;margin-bottom:12px;}
.section-title{font-size:32px;font-weight:900;text-align:center;margin-bottom:12px;letter-spacing:-0.5px;}
.section-sub{font-size:15px;color:#64748b;text-align:center;max-width:560px;margin:0 auto 48px;line-height:1.6;}
.section-alt{background:#f8fafc;}
.section-dark{background:#0f172a;color:#fff;}

/* SERVICES */
.svc-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px;}
.svc-card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:28px;transition:all 0.2s;position:relative;overflow:hidden;}
.svc-card:hover{border-color:#0891b2;box-shadow:0 8px 32px rgba(8,145,178,0.08);transform:translateY(-3px);}
.svc-card-icon{width:48px;height:48px;border-radius:12px;background:linear-gradient(135deg,#ecfeff,#cffafe);display:flex;align-items:center;justify-content:center;margin-bottom:16px;}
.svc-card-icon i{font-size:24px;color:#0891b2;}
.svc-card h3{font-size:16px;font-weight:800;margin-bottom:6px;}
.svc-card p{font-size:13px;color:#64748b;line-height:1.6;margin-bottom:16px;}
.svc-card-price{display:flex;align-items:baseline;gap:4px;}
.svc-card-price .amount{font-size:24px;font-weight:900;color:#0891b2;}
.svc-card-price .period{font-size:12px;color:#94a3b8;font-weight:600;}

/* FEATURES */
.feat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;}
.feat{display:flex;gap:16px;align-items:flex-start;}
.feat-icon{width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,#ecfeff,#cffafe);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.feat-icon i{font-size:22px;color:#0891b2;}
.feat h3{font-size:14px;font-weight:800;margin-bottom:4px;}
.feat p{font-size:12px;color:#64748b;line-height:1.6;}

/* PROCESS */
.process{display:flex;gap:0;justify-content:center;flex-wrap:wrap;}
.process-step{flex:1;min-width:200px;max-width:280px;text-align:center;padding:32px 24px;position:relative;}
.process-step::after{content:'→';position:absolute;right:-8px;top:50%;transform:translateY(-50%);font-size:20px;color:#cbd5e1;font-weight:900;}
.process-step:last-child::after{display:none;}
.process-num{width:40px;height:40px;border-radius:50%;background:#0891b2;color:#fff;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:900;margin:0 auto 12px;}
.process-step h3{font-size:14px;font-weight:800;margin-bottom:4px;}
.process-step p{font-size:12px;color:#64748b;line-height:1.5;}

/* CONTACT */
.contact{padding:80px 40px;background:#f8fafc;}
.contact-inner{max-width:1000px;margin:0 auto;display:flex;gap:48px;align-items:flex-start;}
.contact-text{flex:1;min-width:280px;}
.contact-text h2{font-size:32px;font-weight:900;margin-bottom:12px;letter-spacing:-0.5px;}
.contact-text p{font-size:15px;color:#64748b;line-height:1.7;margin-bottom:24px;}
.contact-info{display:flex;flex-direction:column;gap:12px;}
.contact-info-item{display:flex;align-items:center;gap:12px;font-size:14px;color:#475569;}
.contact-info-item i{font-size:20px;color:#0891b2;width:24px;text-align:center;}
.contact-form{flex:1.2;background:#fff;border:1px solid #e2e8f0;border-radius:16px;padding:32px;box-shadow:0 4px 24px rgba(0,0,0,0.04);}
.contact-form label{display:block;font-size:11px;font-weight:700;color:#475569;margin-bottom:4px;margin-top:14px;text-transform:uppercase;letter-spacing:0.3px;}
.contact-form label:first-child{margin-top:0;}
.contact-form input,.contact-form textarea{width:100%;padding:10px 14px;border:1px solid #e2e8f0;border-radius:8px;font-size:14px;font-family:inherit;outline:none;transition:all 0.15s;}
.contact-form input:focus,.contact-form textarea:focus{border-color:#0891b2;box-shadow:0 0 0 3px rgba(8,145,178,0.08);}
.contact-form textarea{resize:vertical;min-height:100px;}
.contact-form button{margin-top:20px;width:100%;padding:14px;background:#0891b2;color:#fff;border:none;border-radius:10px;font-size:15px;font-weight:700;cursor:pointer;font-family:inherit;transition:all 0.2s;}
.contact-form button:hover{background:#0e7490;transform:translateY(-1px);box-shadow:0 4px 16px rgba(8,145,178,0.25);}

/* FOOTER */
footer{padding:48px 40px;background:#0f172a;color:#94a3b8;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px;}
footer .f-brand{font-size:15px;font-weight:800;color:#fff;}
footer .f-links{display:flex;gap:24px;}
footer .f-links a{font-size:12px;color:#64748b;font-weight:600;}
footer .f-links a:hover{color:#22d3ee;}
footer .f-copy{font-size:11px;width:100%;text-align:center;padding-top:24px;border-top:1px solid #1e293b;margin-top:8px;}

@media(max-width:768px){
  nav{padding:0 16px;height:56px;}
  .nav-links{gap:16px;}
  .nav-links a:not(.nav-cta){display:none;}
  .hero{padding:120px 20px 60px;}
  .section{padding:60px 20px;}
  .trust{flex-wrap:wrap;}.trust-item{min-width:140px;border-right:none;border-bottom:1px solid #f1f5f9;padding:20px;}
  .svc-grid{grid-template-columns:1fr;}
  .feat-grid{grid-template-columns:1fr;}
  .feat{padding:16px;background:#fff;border-radius:12px;border:1px solid #e2e8f0;}
  .process-step::after{display:none;}
  .contact{padding:60px 20px;}
  .contact-inner{flex-direction:column;}
  footer{padding:32px 20px;flex-direction:column;text-align:center;}
  footer .f-links{justify-content:center;}
}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="logo">
    <% if (settings.business_logo) { %><img src="<%= settings.business_logo %>"><% } else { %><i class="ti ti-hammer" style="font-size:24px;color:#0891b2;"></i><% } %>
    IT <span>Forge</span>
  </div>
  <div class="nav-links">
    <a href="#services">Services</a>
    <a href="#how">How It Works</a>
    <a href="#contact">Contact</a>
    <a href="/login" class="nav-cta">Client Portal</a>
  </div>
</nav>

<!-- HERO -->
<div class="hero">
  <div class="hero-inner">
    <div class="hero-badge">Trusted IT Partner for Growing Businesses</div>
    <h1>Technology That Works.<br><span>Managed by Experts.</span></h1>
    <p>We provide complete IT infrastructure management — so your team stays productive, your data stays secure, and your technology just works.</p>
    <div class="hero-btns">
      <a href="#contact" class="btn-primary">Schedule a Consultation</a>
      <a href="#services" class="btn-outline">Explore Services</a>
    </div>
  </div>
</div>

<!-- TRUST BAR -->
<div class="trust">
  <div class="trust-item"><div class="trust-num">24/7</div><div class="trust-label">Monitoring</div></div>
  <div class="trust-item"><div class="trust-num">&lt;1hr</div><div class="trust-label">Response Time</div></div>
  <div class="trust-item"><div class="trust-num">99.9%</div><div class="trust-label">Uptime SLA</div></div>
  <div class="trust-item"><div class="trust-num">10+</div><div class="trust-label">Years Experience</div></div>
</div>

<!-- SERVICES -->
<% if (services.length > 0) { %>
<div class="section section-alt" id="services">
  <div class="section-inner">
    <div class="section-label">What We Offer</div>
    <div class="section-title">Services Built for Your Business</div>
    <div class="section-sub">From day-to-day support to complete infrastructure management — choose what fits your needs or let us build a custom plan.</div>
    <%
      var svcIcons = {'Bundle':'ti ti-package','Managed IT':'ti ti-headset','Monitoring':'ti ti-activity','Email':'ti ti-mail','Backup':'ti ti-database','Security':'ti ti-shield-lock','Hardware':'ti ti-device-desktop','Cloud':'ti ti-cloud','Consulting':'ti ti-bulb','Web':'ti ti-world','Communication':'ti ti-phone','HR-IT':'ti ti-user-plus'};
    %>
    <div class="svc-grid">
      <% services.forEach(s => { %>
        <div class="svc-card">
          <div class="svc-card-icon"><i class="<%= svcIcons[s.category] || 'ti ti-settings' %>"></i></div>
          <h3><%= s.name %></h3>
          <p><%= (s.description || '').split('\n')[0].substring(0, 140) %><%= (s.description || '').length > 140 ? '...' : '' %></p>
          <div class="svc-card-price">
            <% if (s.base_price > 0) { %>
              <span class="amount">$<%= s.base_price.toLocaleString() %></span>
              <span class="period"><%= s.price_type === 'monthly' ? '/month' : s.price_type === 'per-user' ? '/user/mo' : s.price_type === 'hourly' ? '/hour' : 'one-time' %></span>
            <% } else { %>
              <span class="amount">Custom Pricing</span>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</div>
<% } %>

<!-- FEATURES -->
<div class="section">
  <div class="section-inner">
    <div class="section-label">Why IT Forge</div>
    <div class="section-title">Enterprise-Grade IT for Every Business</div>
    <div class="section-sub">We deliver the same level of IT expertise that large corporations have — at a price that makes sense for you.</div>
    <div class="feat-grid">
      <div class="feat"><div class="feat-icon"><i class="ti ti-headset"></i></div><div><h3>Responsive Support</h3><p>Remote and on-site help within 1 hour. Phone, email, or ticket — your choice, our priority.</p></div></div>
      <div class="feat"><div class="feat-icon"><i class="ti ti-activity"></i></div><div><h3>Proactive Monitoring</h3><p>24/7 infrastructure monitoring with automated alerts. We fix issues before they impact your business.</p></div></div>
      <div class="feat"><div class="feat-icon"><i class="ti ti-shield-lock"></i></div><div><h3>Security & Compliance</h3><p>Endpoint protection, email filtering, access policies, and compliance documentation — all managed.</p></div></div>
      <div class="feat"><div class="feat-icon"><i class="ti ti-database"></i></div><div><h3>Backup & Recovery</h3><p>Automated daily backups with verified monthly restores. Your data is always protected and recoverable.</p></div></div>
      <div class="feat"><div class="feat-icon"><i class="ti ti-chart-bar"></i></div><div><h3>Client Dashboard</h3><p>Real-time visibility into your IT assets, invoices, tickets, and team — all in one secure portal.</p></div></div>
      <div class="feat"><div class="feat-icon"><i class="ti ti-trending-up"></i></div><div><h3>Scales With You</h3><p>New hires, new offices, new software — we grow your IT infrastructure as your business expands.</p></div></div>
    </div>
  </div>
</div>

<!-- HOW IT WORKS -->
<div class="section section-alt" id="how">
  <div class="section-inner">
    <div class="section-label">How It Works</div>
    <div class="section-title">Getting Started Is Simple</div>
    <div class="process">
      <div class="process-step"><div class="process-num">1</div><h3>Consultation</h3><p>We audit your current setup and understand your needs — completely free.</p></div>
      <div class="process-step"><div class="process-num">2</div><h3>Custom Plan</h3><p>We design a service package that fits your business size and budget.</p></div>
      <div class="process-step"><div class="process-num">3</div><h3>Onboarding</h3><p>We set up monitoring, security, and your client portal — usually within one week.</p></div>
      <div class="process-step"><div class="process-num">4</div><h3>Ongoing Care</h3><p>We manage your IT day-to-day. You focus on running your business.</p></div>
    </div>
  </div>
</div>

<!-- CONTACT -->
<div class="contact" id="contact">
  <div class="contact-inner">
    <div class="contact-text">
      <div class="section-label" style="text-align:left;">Get In Touch</div>
      <h2>Let's Build Your IT Foundation</h2>
      <p>Tell us about your business and we'll schedule a free 30-minute consultation to review your current IT setup and recommend next steps.</p>
      <div class="contact-info">
        <% if (settings.business_email) { %><div class="contact-info-item"><i class="ti ti-mail"></i> <%= settings.business_email %></div><% } %>
        <% if (settings.business_phone) { %><div class="contact-info-item"><i class="ti ti-phone"></i> <%= settings.business_phone %></div><% } %>
        <% if (settings.business_address) { %><div class="contact-info-item"><i class="ti ti-map-pin"></i> <%= settings.business_address %></div><% } %>
      </div>
    </div>
    <div class="contact-form">
      <% if (typeof submitted !== 'undefined' && submitted) { %>
        <div style="text-align:center;padding:40px 20px;">
          <div style="width:56px;height:56px;border-radius:50%;background:#d1fae5;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;"><i class="ti ti-check" style="font-size:28px;color:#059669;"></i></div>
          <h3 style="margin-bottom:8px;">Message Sent</h3>
          <p style="font-size:14px;color:#64748b;">Thank you for reaching out. We'll get back to you within 24 hours.</p>
        </div>
      <% } else { %>
        <form method="POST" action="/contact">
          <div style="display:flex;gap:12px;">
            <div style="flex:1;"><label>Full Name *</label><input type="text" name="name" required placeholder="John Smith"></div>
            <div style="flex:1;"><label>Company</label><input type="text" name="company" placeholder="Your company"></div>
          </div>
          <div style="display:flex;gap:12px;">
            <div style="flex:1;"><label>Email *</label><input type="email" name="email" required placeholder="john@company.com"></div>
            <div style="flex:1;"><label>Phone</label><input type="text" name="phone" placeholder="(555) 000-0000"></div>
          </div>
          <label>How can we help?</label>
          <textarea name="message" rows="4" placeholder="Tell us about your business, number of employees, current IT challenges, and what you're looking for..."></textarea>
          <button type="submit"><i class="ti ti-send" style="margin-right:6px;"></i>Send Message</button>
        </form>
      <% } %>
    </div>
  </div>
</div>

<!-- FOOTER -->
<footer>
  <div class="f-brand"><% if (settings.business_logo) { %><img src="<%= settings.business_logo %>" style="height:20px;vertical-align:middle;margin-right:6px;border-radius:4px;"><% } %>IT Forge</div>
  <div class="f-links">
    <a href="#services">Services</a>
    <a href="#contact">Contact</a>
    <a href="/login">Client Portal</a>
    <a href="/public/services">Full Service List</a>
  </div>
  <div class="f-copy">&copy; <%= new Date().getFullYear() %> <%= settings.business_name || 'IT Forge' %>. All rights reserved.</div>
</footer>

</body>
</html>
