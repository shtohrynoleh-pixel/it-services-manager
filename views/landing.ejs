<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= settings.business_name || 'IT Services Pro' %> — Managed IT Services</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Inter',sans-serif;color:#0f172a;overflow-x:hidden;}
a{color:#0891b2;text-decoration:none;}
a:hover{text-decoration:underline;}

/* NAV */
.nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:16px 40px;display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,0.9);backdrop-filter:blur(12px);border-bottom:1px solid rgba(0,0,0,0.06);}
.nav-brand{display:flex;align-items:center;gap:10px;font-size:18px;font-weight:800;color:#0e7490;}
.nav-brand img{height:32px;border-radius:6px;}
.nav-links{display:flex;gap:24px;align-items:center;}
.nav-links a{font-size:13px;font-weight:600;color:#475569;text-decoration:none;}
.nav-links a:hover{color:#0891b2;}
.nav-cta{padding:8px 20px;background:#0891b2;color:#fff !important;border-radius:8px;font-weight:700;font-size:13px;}
.nav-cta:hover{background:#0e7490;text-decoration:none;}

/* HERO */
.hero{padding:140px 40px 80px;text-align:center;background:linear-gradient(180deg,#ecfeff 0%,#fff 100%);}
.hero h1{font-size:clamp(32px,5vw,56px);font-weight:900;line-height:1.1;color:#0f172a;max-width:800px;margin:0 auto 20px;}
.hero h1 span{color:#0891b2;}
.hero p{font-size:18px;color:#64748b;max-width:600px;margin:0 auto 32px;line-height:1.6;}
.hero-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;}
.hero-btns a{padding:14px 32px;border-radius:10px;font-size:15px;font-weight:700;text-decoration:none;}
.btn-fill{background:#0891b2;color:#fff !important;box-shadow:0 4px 16px rgba(8,145,178,0.3);}
.btn-fill:hover{background:#0e7490;text-decoration:none;}
.btn-outline{border:2px solid #0891b2;color:#0891b2 !important;}
.btn-outline:hover{background:#ecfeff;text-decoration:none;}

/* STATS */
.stats{display:flex;justify-content:center;gap:48px;padding:40px;flex-wrap:wrap;}
.stat{text-align:center;}
.stat-num{font-size:36px;font-weight:900;color:#0891b2;}
.stat-label{font-size:12px;font-weight:600;color:#64748b;margin-top:2px;text-transform:uppercase;letter-spacing:0.5px;}

/* SECTIONS */
.section{padding:80px 40px;max-width:1100px;margin:0 auto;}
.section-title{font-size:32px;font-weight:900;text-align:center;margin-bottom:12px;}
.section-sub{font-size:16px;color:#64748b;text-align:center;max-width:600px;margin:0 auto 48px;line-height:1.6;}
.section-alt{background:#f8fafc;}

/* SERVICES GRID */
.svc-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:20px;}
.svc-card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:28px;transition:all 0.2s;}
.svc-card:hover{border-color:#0891b2;box-shadow:0 8px 24px rgba(8,145,178,0.08);transform:translateY(-2px);}
.svc-card.featured{border-color:#0891b2;background:linear-gradient(135deg,#ecfeff,#fff);position:relative;overflow:hidden;}
.svc-card.featured::before{content:'MOST POPULAR';position:absolute;top:16px;right:-28px;background:#0891b2;color:#fff;font-size:9px;font-weight:800;padding:4px 32px;transform:rotate(45deg);letter-spacing:1px;}
.svc-name{font-size:17px;font-weight:800;margin-bottom:4px;}
.svc-cat{font-size:11px;font-weight:700;color:#0891b2;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:10px;}
.svc-desc{font-size:13px;color:#475569;line-height:1.6;margin-bottom:16px;}
.svc-price{display:flex;align-items:baseline;gap:4px;}
.svc-amount{font-size:28px;font-weight:900;color:#0f172a;}
.svc-period{font-size:13px;color:#64748b;}

/* FEATURES */
.feat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:24px;}
.feat-card{padding:24px;border-radius:14px;background:#fff;border:1px solid #e2e8f0;}
.feat-icon{font-size:32px;margin-bottom:12px;}
.feat-title{font-size:15px;font-weight:800;margin-bottom:6px;}
.feat-desc{font-size:13px;color:#64748b;line-height:1.6;}

/* CTA */
.cta-section{padding:80px 40px;text-align:center;background:linear-gradient(135deg,#0891b2,#0e7490);color:#fff;}
.cta-section h2{font-size:36px;font-weight:900;margin-bottom:12px;}
.cta-section p{font-size:16px;opacity:0.8;margin-bottom:32px;}
.cta-btn{display:inline-block;padding:16px 40px;background:#fff;color:#0891b2 !important;border-radius:10px;font-size:16px;font-weight:800;text-decoration:none;}
.cta-btn:hover{background:#ecfeff;text-decoration:none;}

/* FOOTER */
.footer{padding:40px;text-align:center;background:#0f172a;color:#94a3b8;font-size:12px;line-height:1.8;}
.footer a{color:#22d3ee;}

/* RESPONSIVE */
@media(max-width:768px){
  .nav{padding:12px 20px;}
  .nav-links{gap:12px;}
  .hero{padding:120px 20px 60px;}
  .section{padding:60px 20px;}
  .stats{gap:24px;}
  .svc-grid,.feat-grid{grid-template-columns:1fr;}
}
</style>
</head>
<body>

<!-- NAV -->
<div class="nav">
  <div class="nav-brand">
    <% if (settings.business_logo) { %><img src="<%= settings.business_logo %>"><% } else { %>🖥️<% } %>
    <%= settings.business_name || 'IT Services Pro' %>
  </div>
  <div class="nav-links">
    <a href="#services">Services</a>
    <a href="#features">Features</a>
    <a href="#contact">Contact</a>
    <a href="/login" class="nav-cta">Client Login</a>
  </div>
</div>

<!-- HERO -->
<div class="hero">
  <h1>Your Complete <span>IT Department</span> for a Fraction of the Cost</h1>
  <p>We manage your technology so you can focus on your business. Remote support, on-site visits, monitoring, security — all in one flat monthly fee.</p>
  <div class="hero-btns">
    <a href="#services" class="btn-fill">View Our Services</a>
    <a href="/login" class="btn-outline">Client Portal</a>
  </div>
</div>

<!-- STATS -->
<div class="stats">
  <div class="stat"><div class="stat-num">24/7</div><div class="stat-label">Monitoring</div></div>
  <div class="stat"><div class="stat-num">&lt;1hr</div><div class="stat-label">Response Time</div></div>
  <div class="stat"><div class="stat-num">99.9%</div><div class="stat-label">Uptime SLA</div></div>
  <div class="stat"><div class="stat-num">10+</div><div class="stat-label">Years Experience</div></div>
</div>

<!-- SERVICES -->
<div class="section-alt" id="services">
  <div class="section">
    <div class="section-title">Our Services</div>
    <div class="section-sub">From helpdesk support to cloud migration — we handle all your IT needs so you can focus on running your business.</div>
    <div class="svc-grid">
      <% services.forEach((s, i) => { %>
        <div class="svc-card <%= i === 0 ? 'featured' : '' %>">
          <div class="svc-cat"><%= s.category %></div>
          <div class="svc-name"><%= s.name %></div>
          <div class="svc-desc"><%= (s.description || '').split('\n')[0].substring(0, 160) %><%= (s.description || '').length > 160 ? '...' : '' %></div>
          <div class="svc-price">
            <% if (s.base_price > 0) { %>
              <div class="svc-amount">$<%= s.base_price.toLocaleString() %></div>
              <div class="svc-period">/<%= s.price_type === 'monthly' ? 'mo' : s.price_type === 'per-user' ? 'user/mo' : s.price_type === 'hourly' ? 'hr' : 'project' %></div>
            <% } else { %>
              <div class="svc-amount">Custom</div>
              <div class="svc-period">pricing</div>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</div>

<!-- FEATURES -->
<div class="section" id="features">
  <div class="section-title">Why Choose Us</div>
  <div class="section-sub">We're not just a vendor — we're your IT team. Here's what makes us different.</div>
  <div class="feat-grid">
    <div class="feat-card"><div class="feat-icon">🎧</div><div class="feat-title">Remote & On-Site Support</div><div class="feat-desc">Phone, email, and remote desktop support plus scheduled on-site visits. We're always available when you need us.</div></div>
    <div class="feat-card"><div class="feat-icon">📡</div><div class="feat-title">24/7 Monitoring</div><div class="feat-desc">We watch your servers, network, and websites around the clock. If something goes down, we know before you do.</div></div>
    <div class="feat-card"><div class="feat-icon">🔒</div><div class="feat-title">Security & Compliance</div><div class="feat-desc">Antivirus, firewalls, email filtering, security policies, and compliance documentation — all managed for you.</div></div>
    <div class="feat-card"><div class="feat-icon">💾</div><div class="feat-title">Backup & Recovery</div><div class="feat-desc">Automated daily backups with monthly restore testing. Your data is always safe and recoverable.</div></div>
    <div class="feat-card"><div class="feat-icon">📊</div><div class="feat-title">Client Portal</div><div class="feat-desc">Track your assets, subscriptions, invoices, and support requests in real-time through your own dashboard.</div></div>
    <div class="feat-card"><div class="feat-icon">💰</div><div class="feat-title">Predictable Pricing</div><div class="feat-desc">One flat monthly fee covers everything. No surprise bills, no hidden charges, no hourly rates for basic support.</div></div>
  </div>
</div>

<!-- CTA -->
<div class="cta-section" id="contact">
  <h2>Ready to Simplify Your IT?</h2>
  <p>Get a free consultation and see how much time and money you can save.</p>
  <div style="margin-bottom:16px;">
    <% if (settings.business_email) { %><a href="mailto:<%= settings.business_email %>" class="cta-btn">📧 Email Us</a><% } %>
    <% if (settings.business_phone) { %><a href="tel:<%= settings.business_phone %>" class="cta-btn" style="margin-left:12px;">📞 Call Us</a><% } %>
    <% if (!settings.business_email && !settings.business_phone) { %><a href="/login" class="cta-btn">Get Started</a><% } %>
  </div>
  <div style="font-size:13px;opacity:0.7;">
    <% if (settings.business_email) { %><%= settings.business_email %><% } %>
    <% if (settings.business_phone) { %> · <%= settings.business_phone %><% } %>
    <% if (settings.business_address) { %><br><%= settings.business_address %><% } %>
  </div>
</div>

<!-- FOOTER -->
<div class="footer">
  &copy; <%= new Date().getFullYear() %> <%= settings.business_name || 'IT Services Pro' %>. All rights reserved.<br>
  <a href="/login">Client Portal</a> · <a href="/public/services">Full Services List</a>
</div>

</body>
</html>
