<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= settings.business_name || 'IT Forge' %> — Run Your Fleet. Not Your IT.</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.40.0/dist/tabler-icons.min.css">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Inter',sans-serif;color:#0f172a;background:#fff;-webkit-font-smoothing:antialiased;}
a{color:#0891b2;text-decoration:none;}

nav{position:fixed;top:0;left:0;right:0;z-index:100;height:60px;padding:0 32px;display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,0.96);backdrop-filter:blur(16px);border-bottom:1px solid rgba(0,0,0,0.05);}
.logo{display:flex;align-items:center;gap:8px;font-size:17px;font-weight:900;color:#0f172a;letter-spacing:-0.3px;}
.logo img{height:28px;border-radius:6px;}.logo span{color:#0891b2;}
.nav-r{display:flex;gap:20px;align-items:center;}
.nav-r a{font-size:13px;font-weight:600;color:#475569;}.nav-r a:hover{color:#0891b2;}
.nav-btn{padding:8px 20px;background:#0891b2;color:#fff !important;border-radius:8px;font-weight:700;font-size:13px;}
.nav-btn:hover{background:#0e7490;}

/* HERO */
.hero{padding:140px 32px 80px;text-align:center;background:linear-gradient(180deg,#f0fdfa 0%,#fff 100%);position:relative;}
.hero h1{font-size:clamp(30px,4.5vw,52px);font-weight:900;line-height:1.08;max-width:720px;margin:0 auto 18px;letter-spacing:-1px;}
.hero h1 span{background:linear-gradient(135deg,#0891b2,#06b6d4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.hero p{font-size:17px;color:#64748b;max-width:520px;margin:0 auto 32px;line-height:1.7;}
.hero-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;}
.b1{padding:14px 36px;background:#0891b2;color:#fff;border-radius:10px;font-size:15px;font-weight:700;box-shadow:0 4px 16px rgba(8,145,178,0.25);}
.b1:hover{background:#0e7490;transform:translateY(-1px);}
.b2{padding:14px 36px;border:2px solid #e2e8f0;color:#475569;border-radius:10px;font-size:15px;font-weight:700;}
.b2:hover{border-color:#0891b2;color:#0891b2;}

.sec{padding:72px 32px;max-width:960px;margin:0 auto;}
.sec-alt{background:#f8fafc;}
.sl{font-size:11px;font-weight:700;color:#0891b2;text-transform:uppercase;letter-spacing:1.5px;text-align:center;margin-bottom:8px;}
.st{font-size:28px;font-weight:900;text-align:center;margin-bottom:8px;letter-spacing:-0.5px;}
.ss{font-size:14px;color:#64748b;text-align:center;max-width:500px;margin:0 auto 40px;line-height:1.6;}

/* Problem/Solution */
.ps-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;}
.ps-card{padding:28px;border-radius:14px;border:1px solid #e2e8f0;}
.ps-card.problem{background:#fef2f2;border-color:#fca5a5;}
.ps-card.solution{background:#f0fdfa;border-color:#a7f3d0;}
.ps-card h3{font-size:15px;font-weight:800;margin-bottom:8px;display:flex;align-items:center;gap:8px;}
.ps-card ul{font-size:13px;color:#475569;line-height:2;list-style:none;padding:0;}
.ps-card ul li::before{content:'';display:inline-block;width:6px;height:6px;border-radius:50%;margin-right:8px;vertical-align:middle;}
.ps-card.problem ul li::before{background:#ef4444;}
.ps-card.solution ul li::before{background:#10b981;}

/* Features */
.feat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
.feat{padding:20px;border-radius:12px;border:1px solid #e2e8f0;background:#fff;transition:all 0.15s;}
.feat:hover{border-color:#0891b2;box-shadow:0 4px 16px rgba(8,145,178,0.06);transform:translateY(-2px);}
.feat i{font-size:24px;color:#0891b2;margin-bottom:8px;display:block;}
.feat h3{font-size:13px;font-weight:800;margin-bottom:3px;}
.feat p{font-size:11px;color:#64748b;line-height:1.5;}

/* Signup */
.signup{padding:72px 32px;background:linear-gradient(135deg,#0f172a,#1e293b);color:#fff;}
.signup-inner{max-width:960px;margin:0 auto;display:flex;gap:40px;align-items:center;}
.signup-left{flex:1;}
.signup-left h2{font-size:32px;font-weight:900;margin-bottom:10px;letter-spacing:-0.5px;}
.signup-left p{font-size:15px;opacity:0.7;line-height:1.7;margin-bottom:16px;}
.signup-left ul{list-style:none;padding:0;font-size:13px;opacity:0.8;line-height:2.2;}
.signup-left ul li i{color:#22d3ee;margin-right:6px;}
.signup-form{flex:1;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:16px;padding:28px;backdrop-filter:blur(8px);}
.signup-form label{display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;opacity:0.6;margin-bottom:3px;margin-top:12px;}
.signup-form input{width:100%;padding:10px 12px;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);border-radius:8px;color:#fff;font-size:13px;font-family:inherit;outline:none;}
.signup-form input:focus{border-color:#22d3ee;background:rgba(255,255,255,0.12);}
.signup-form input::placeholder{color:rgba(255,255,255,0.3);}
.signup-form button{margin-top:18px;width:100%;padding:14px;background:#0891b2;color:#fff;border:none;border-radius:10px;font-size:15px;font-weight:800;cursor:pointer;font-family:inherit;transition:all 0.15s;}
.signup-form button:hover{background:#06b6d4;transform:translateY(-1px);}
.signup-form .sf-note{font-size:10px;opacity:0.4;margin-top:8px;text-align:center;}

/* Success */
.signup-ok{text-align:center;padding:40px 20px;}
.signup-ok i{font-size:48px;color:#22d3ee;display:block;margin-bottom:12px;}

footer{padding:32px;background:#0f172a;color:#475569;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;font-size:11px;}
footer a{color:#64748b;}.footer a:hover{color:#22d3ee;}

@media(max-width:768px){
  nav{padding:0 16px;}.nav-r a:not(.nav-btn){display:none;}
  .hero{padding:110px 20px 60px;}
  .sec{padding:48px 20px;}
  .ps-grid,.feat-grid{grid-template-columns:1fr;}
  .signup{padding:48px 20px;}.signup-inner{flex-direction:column;}
  footer{flex-direction:column;text-align:center;padding:24px 16px;}
}
</style>
</head>
<body>

<nav>
  <div class="logo"><% if (settings.business_logo) { %><img src="<%= settings.business_logo %>"><% } else { %><i class="ti ti-hammer" style="font-size:22px;color:#0891b2;"></i><% } %> IT <span>Forge</span></div>
  <div class="nav-r">
    <a href="#features">Features</a>
    <a href="#signup">Try Free</a>
    <a href="/login" class="nav-btn">Sign In</a>
  </div>
</nav>

<!-- HERO -->
<div class="hero">
  <h1>Run Your Fleet.<br><span>Not Your IT.</span></h1>
  <p>One platform to manage your trucks, drivers, dispatch, fuel, IT, and everything in between. Built for trucking companies that want to stop juggling spreadsheets.</p>
  <div class="hero-btns">
    <a href="#signup" class="b1">Start Free Trial</a>
    <a href="#features" class="b2">See Features</a>
  </div>
</div>

<!-- PROBLEM / SOLUTION -->
<div class="sec">
  <div class="ps-grid">
    <div class="ps-card problem">
      <h3><i class="ti ti-alert-triangle" style="color:#ef4444;"></i> The Problem</h3>
      <ul>
        <li>Driver info in one spreadsheet, trucks in another</li>
        <li>No visibility into fleet costs or fuel efficiency</li>
        <li>IT issues reported via text messages and forgotten</li>
        <li>No standard procedures — everyone does it differently</li>
        <li>Paying for 5 different tools that don't talk to each other</li>
      </ul>
    </div>
    <div class="ps-card solution">
      <h3><i class="ti ti-check" style="color:#10b981;"></i> IT Forge</h3>
      <ul>
        <li>All your people, trucks, trailers in one place</li>
        <li>Real-time GPS, fuel tracking, and MPG incentives</li>
        <li>Ticket system + chat — nothing gets lost</li>
        <li>SOPs, policies, and process flows your team actually uses</li>
        <li>One platform. One login. Everything connected.</li>
      </ul>
    </div>
  </div>
</div>

<!-- FEATURES -->
<div class="sec sec-alt" id="features">
  <div class="sl">Everything You Need</div>
  <div class="st">Built for Trucking. Used by Everyone.</div>
  <div class="ss">From dispatch to driver pay, IT support to fuel savings — all in one place.</div>
  <div class="feat-grid">
    <div class="feat"><i class="ti ti-route"></i><h3>Dispatch & TMS</h3><p>Load board, multi-stop trips, rate confirmations, driver assignments — the full dispatch workflow.</p></div>
    <div class="feat"><i class="ti ti-truck"></i><h3>Fleet Management</h3><p>Trucks, trailers, maintenance logs, fuel tracking. Know your costs per mile.</p></div>
    <div class="feat"><i class="ti ti-map-2"></i><h3>Live GPS Tracking</h3><p>Connect Samsara or Motive. See every truck on a real-time map.</p></div>
    <div class="feat"><i class="ti ti-gas-station"></i><h3>Fuel Incentive</h3><p>Reward drivers for fuel efficiency. Auto-calculate savings, baselines, and payouts.</p></div>
    <div class="feat"><i class="ti ti-cash"></i><h3>Driver Pay</h3><p>Per-mile, percentage, or flat rate. Auto-generate settlements from delivered loads.</p></div>
    <div class="feat"><i class="ti ti-ticket"></i><h3>Support Tickets</h3><p>Your team submits requests. You track SLA response and resolution times.</p></div>
    <div class="feat"><i class="ti ti-message-circle"></i><h3>Team Chat</h3><p>Channels, direct messages, file sharing. Everyone stays connected.</p></div>
    <div class="feat"><i class="ti ti-list-check"></i><h3>SOPs & Policies</h3><p>Build procedures, track who read them, stay compliant.</p></div>
    <div class="feat"><i class="ti ti-folder"></i><h3>File Management</h3><p>Shared folders, access control, storage quotas. Every document in one place.</p></div>
    <div class="feat"><i class="ti ti-activity"></i><h3>IT Monitoring</h3><p>Watch servers, websites, and network 24/7. Get alerts before things break.</p></div>
    <div class="feat"><i class="ti ti-shield-check"></i><h3>Security</h3><p>2FA, password vault, email security tracking, domain management.</p></div>
    <div class="feat"><i class="ti ti-trophy"></i><h3>Gamification</h3><p>XP points, ranks, leaderboard. Make using the platform fun.</p></div>
  </div>
</div>

<!-- SIGNUP -->
<div class="signup" id="signup">
  <div class="signup-inner">
    <div class="signup-left">
      <h2>Try It Free</h2>
      <p>Create your company account in 30 seconds. No credit card. No commitments. Just sign up and start using it.</p>
      <ul>
        <li><i class="ti ti-check"></i> Full access to all features</li>
        <li><i class="ti ti-check"></i> Add your team, trucks, and trailers</li>
        <li><i class="ti ti-check"></i> Connect Samsara or Motive for GPS</li>
        <li><i class="ti ti-check"></i> Submit tickets, chat, share files</li>
        <li><i class="ti ti-check"></i> No setup fee. Cancel anytime.</li>
      </ul>
    </div>
    <div class="signup-form">
      <% if (typeof signedUp !== 'undefined' && signedUp) { %>
        <div class="signup-ok">
          <i class="ti ti-circle-check"></i>
          <h3 style="margin-bottom:8px;">You're In!</h3>
          <p style="font-size:13px;opacity:0.7;margin-bottom:16px;">Your account is ready. Sign in with:</p>
          <div style="background:rgba(255,255,255,0.1);padding:12px;border-radius:8px;margin-bottom:16px;">
            <div style="font-size:12px;opacity:0.5;">Username</div>
            <div style="font-size:18px;font-weight:900;font-family:monospace;"><%= typeof newUsername !== 'undefined' ? newUsername : '' %></div>
          </div>
          <a href="/login" style="display:inline-block;padding:12px 32px;background:#0891b2;color:#fff;border-radius:8px;font-weight:800;font-size:14px;">Sign In →</a>
        </div>
      <% } else { %>
        <form method="POST" action="/signup">
          <label>Company Name *</label>
          <input type="text" name="company_name" required placeholder="Your company name">
          <div style="display:flex;gap:10px;">
            <div style="flex:1;"><label>Your Name *</label><input type="text" name="full_name" required placeholder="Full name"></div>
            <div style="flex:1;"><label>Phone</label><input type="text" name="phone" placeholder="(555) 000-0000"></div>
          </div>
          <label>Email *</label>
          <input type="email" name="email" required placeholder="you@company.com">
          <label>Password *</label>
          <input type="password" name="password" required minlength="4" placeholder="Min 4 characters">
          <button type="submit"><i class="ti ti-rocket" style="margin-right:6px;"></i>Create Account</button>
          <div class="sf-note">Free to start. Your username will be your email prefix.</div>
        </form>
      <% } %>
    </div>
  </div>
</div>

<!-- CONTACT (simple) -->
<div class="sec">
  <div style="text-align:center;max-width:500px;margin:0 auto;">
    <div class="st">Questions?</div>
    <p style="font-size:14px;color:#64748b;margin-bottom:20px;">Not sure if IT Forge is right for you? Let's talk.</p>
    <% if (settings.business_email) { %><a href="mailto:<%= settings.business_email %>" style="display:inline-block;padding:12px 28px;background:#0891b2;color:#fff;border-radius:10px;font-weight:700;font-size:14px;"><i class="ti ti-mail" style="margin-right:4px;"></i> <%= settings.business_email %></a><% } %>
    <% if (settings.business_phone) { %><div style="margin-top:10px;font-size:13px;color:#64748b;"><i class="ti ti-phone"></i> <%= settings.business_phone %></div><% } %>
  </div>
</div>

<footer>
  <div style="font-weight:800;color:#94a3b8;"><% if (settings.business_logo) { %><img src="<%= settings.business_logo %>" style="height:18px;vertical-align:middle;margin-right:4px;border-radius:3px;"><% } %>IT Forge</div>
  <div style="display:flex;gap:16px;"><a href="#features">Features</a><a href="#signup">Sign Up</a><a href="/login">Sign In</a></div>
  <div>&copy; <%= new Date().getFullYear() %> <%= settings.business_name || 'IT Forge' %></div>
</footer>

</body>
</html>
