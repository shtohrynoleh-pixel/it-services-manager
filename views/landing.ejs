<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= settings.business_name || 'IT Services' %></title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Inter',sans-serif;color:#0f172a;background:#fff;}
a{color:#0891b2;text-decoration:none;}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:14px 32px;display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,0.92);backdrop-filter:blur(16px);border-bottom:1px solid rgba(0,0,0,0.05);}
.logo{display:flex;align-items:center;gap:8px;font-size:17px;font-weight:800;color:#0e7490;}
.logo img{height:28px;border-radius:6px;}
nav a.login{padding:8px 20px;background:#0891b2;color:#fff;border-radius:8px;font-size:13px;font-weight:700;}
nav a.login:hover{background:#0e7490;}

/* HERO */
.hero{padding:130px 32px 70px;text-align:center;background:linear-gradient(180deg,#f0fdfa 0%,#fff 100%);}
.hero h1{font-size:clamp(28px,4.5vw,48px);font-weight:900;line-height:1.15;max-width:700px;margin:0 auto 16px;}
.hero h1 em{font-style:normal;color:#0891b2;}
.hero p{font-size:16px;color:#64748b;max-width:520px;margin:0 auto 28px;line-height:1.6;}
.hero-btn{display:inline-block;padding:13px 32px;background:#0891b2;color:#fff;border-radius:10px;font-size:15px;font-weight:700;box-shadow:0 4px 16px rgba(8,145,178,0.25);}
.hero-btn:hover{background:#0e7490;}

/* TRUST */
.trust{display:flex;justify-content:center;gap:40px;padding:32px;flex-wrap:wrap;border-bottom:1px solid #f1f5f9;}
.trust-item{text-align:center;}
.trust-num{font-size:28px;font-weight:900;color:#0891b2;}
.trust-label{font-size:11px;color:#94a3b8;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;}

/* SERVICES */
.svc-section{padding:64px 32px;max-width:960px;margin:0 auto;}
.svc-section h2{font-size:28px;font-weight:900;text-align:center;margin-bottom:8px;}
.svc-section p.sub{font-size:14px;color:#64748b;text-align:center;margin-bottom:36px;}
.svc-list{display:flex;flex-direction:column;gap:12px;}
.svc{display:flex;align-items:center;gap:16px;padding:20px 24px;background:#fff;border:1px solid #e2e8f0;border-radius:12px;transition:all 0.15s;}
.svc:hover{border-color:#0891b2;box-shadow:0 4px 16px rgba(8,145,178,0.06);}
.svc-icon{width:44px;height:44px;border-radius:10px;background:linear-gradient(135deg,#ecfeff,#cffafe);display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;}
.svc-info{flex:1;min-width:0;}
.svc-name{font-size:15px;font-weight:800;}
.svc-desc{font-size:12px;color:#64748b;margin-top:2px;line-height:1.4;}
.svc-price{text-align:right;flex-shrink:0;}
.svc-amount{font-size:20px;font-weight:900;color:#0891b2;}
.svc-period{font-size:10px;color:#94a3b8;}

<% if (services.length === 0) { %>
.svc-section{display:none;}
<% } %>

/* WHY */
.why{padding:64px 32px;background:#f8fafc;}
.why-inner{max-width:960px;margin:0 auto;}
.why h2{font-size:28px;font-weight:900;text-align:center;margin-bottom:36px;}
.why-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:16px;}
.why-card{padding:20px;background:#fff;border-radius:12px;border:1px solid #e2e8f0;}
.why-card h3{font-size:14px;font-weight:800;margin-bottom:4px;display:flex;align-items:center;gap:8px;}
.why-card p{font-size:12px;color:#64748b;line-height:1.6;}

/* CTA */
.cta{padding:64px 32px;text-align:center;background:linear-gradient(135deg,#0891b2,#0e7490);color:#fff;}
.cta h2{font-size:28px;font-weight:900;margin-bottom:8px;}
.cta p{font-size:14px;opacity:0.8;margin-bottom:24px;}
.cta-btn{display:inline-block;padding:13px 32px;background:#fff;color:#0891b2;border-radius:10px;font-size:15px;font-weight:800;}
.cta-btn:hover{background:#ecfeff;}
.cta-contact{margin-top:16px;font-size:13px;opacity:0.7;}

/* CONTACT */
.contact{padding:64px 32px;background:#f8fafc;}
.contact-inner{max-width:960px;margin:0 auto;display:flex;gap:40px;align-items:flex-start;}
.contact-text{flex:1;min-width:200px;}
.contact-text h2{font-size:28px;font-weight:900;margin-bottom:8px;}
.contact-text p{font-size:14px;color:#64748b;line-height:1.6;margin-bottom:20px;}
.contact-line{font-size:13px;color:#475569;margin-bottom:6px;display:flex;align-items:center;gap:6px;}
.contact-form{flex:1.2;background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:28px;}
.contact-form label{display:block;font-size:11px;font-weight:700;color:#475569;margin-bottom:3px;margin-top:12px;}
.contact-form input,.contact-form textarea{width:100%;padding:9px 12px;border:1px solid #e2e8f0;border-radius:8px;font-size:13px;font-family:inherit;outline:none;}
.contact-form input:focus,.contact-form textarea:focus{border-color:#0891b2;box-shadow:0 0 0 3px rgba(8,145,178,0.08);}
.contact-form textarea{resize:vertical;min-height:80px;}
.contact-form button{margin-top:16px;width:100%;padding:12px;background:#0891b2;color:#fff;border:none;border-radius:8px;font-size:14px;font-weight:700;cursor:pointer;font-family:inherit;}
.contact-form button:hover{background:#0e7490;}

/* FOOTER */
footer{padding:32px;text-align:center;font-size:11px;color:#94a3b8;background:#0f172a;}
footer a{color:#22d3ee;}

@media(max-width:600px){
  nav{padding:10px 16px;}
  .hero{padding:100px 16px 50px;}
  .svc-section,.why,.contact{padding:48px 16px;}
  .contact-inner{flex-direction:column;}
  .svc{flex-direction:column;align-items:flex-start;gap:10px;}
  .svc-price{text-align:left;}
  .trust{gap:20px;}
}
</style>
</head>
<body>

<nav>
  <div class="logo">
    <% if (settings.business_logo) { %><img src="<%= settings.business_logo %>"><% } %>
    <%= settings.business_name || 'IT Services' %>
  </div>
  <a href="/login" class="login">Sign In</a>
</nav>

<div class="hero">
  <h1>Your IT. <em>Forged</em> to Perfection.</h1>
  <p>Professional IT management, monitoring, and support — one team, one flat rate, zero headaches.</p>
  <a href="#contact" class="hero-btn">Get a Free Consultation</a>
</div>

<div class="trust">
  <div class="trust-item"><div class="trust-num">24/7</div><div class="trust-label">Monitoring</div></div>
  <div class="trust-item"><div class="trust-num">&lt;1hr</div><div class="trust-label">Response</div></div>
  <div class="trust-item"><div class="trust-num">99.9%</div><div class="trust-label">Uptime</div></div>
  <div class="trust-item"><div class="trust-num">10+</div><div class="trust-label">Years</div></div>
</div>

<% if (services.length > 0) { %>
<div class="svc-section" id="services">
  <h2>Services</h2>
  <p class="sub">Choose what you need — or get everything in one package.</p>
  <div class="svc-list">
    <%
      var icons = {'Bundle':'🖥️','Managed IT':'🎧','Monitoring':'📡','Email':'📧','Backup':'💾','Security':'🔒','Hardware':'🔧','Cloud':'☁️','Consulting':'💡','Web':'🌐','Communication':'📞','HR-IT':'👤'};
    %>
    <% services.forEach(s => { %>
      <div class="svc">
        <div class="svc-icon"><%= icons[s.category] || '⚙️' %></div>
        <div class="svc-info">
          <div class="svc-name"><%= s.name %></div>
          <div class="svc-desc"><%= (s.description || '').split('\n')[0].substring(0, 120) %><%= (s.description || '').length > 120 ? '...' : '' %></div>
        </div>
        <div class="svc-price">
          <% if (s.base_price > 0) { %>
            <div class="svc-amount">$<%= s.base_price.toLocaleString() %></div>
            <div class="svc-period"><%= s.price_type === 'monthly' ? '/month' : s.price_type === 'per-user' ? '/user/mo' : s.price_type === 'hourly' ? '/hour' : 'one-time' %></div>
          <% } else { %>
            <div class="svc-amount">Custom</div>
          <% } %>
        </div>
      </div>
    <% }) %>
  </div>
</div>
<% } %>

<div class="why">
  <div class="why-inner">
    <h2>Why Work With Us</h2>
    <div class="why-grid">
      <div class="why-card"><h3>🎧 Always Available</h3><p>Remote and on-site support when you need it. Call, email, or submit a ticket — we respond fast.</p></div>
      <div class="why-card"><h3>📡 Proactive Monitoring</h3><p>We catch problems before they affect your business. 24/7 server and network monitoring with instant alerts.</p></div>
      <div class="why-card"><h3>🔒 Security First</h3><p>Antivirus, firewalls, email filtering, 2FA, security policies — we keep your data safe and your business compliant.</p></div>
      <div class="why-card"><h3>💰 Flat Monthly Rate</h3><p>No surprise bills. One predictable fee covers everything. Budget with confidence.</p></div>
      <div class="why-card"><h3>📊 Your Own Portal</h3><p>Track assets, subscriptions, invoices, and requests through a real-time client dashboard.</p></div>
      <div class="why-card"><h3>🚀 Grow Without Limits</h3><p>New hires, new offices, new software — we scale your IT as your business grows.</p></div>
    </div>
  </div>
</div>

<div class="contact" id="contact">
  <div class="contact-inner">
    <div class="contact-text">
      <h2>Ready to Simplify Your IT?</h2>
      <p>Fill out the form and we'll get back to you within 24 hours with a free consultation.</p>
      <% if (settings.business_email) { %><div class="contact-line">📧 <%= settings.business_email %></div><% } %>
      <% if (settings.business_phone) { %><div class="contact-line">📞 <%= settings.business_phone %></div><% } %>
      <% if (settings.business_address) { %><div class="contact-line">📍 <%= settings.business_address %></div><% } %>
    </div>
    <div class="contact-form">
      <% if (typeof submitted !== 'undefined' && submitted) { %>
        <div style="text-align:center;padding:32px;">
          <div style="font-size:48px;margin-bottom:12px;">✅</div>
          <h3 style="margin-bottom:8px;">Thank You!</h3>
          <p style="font-size:13px;color:#64748b;">We received your message and will get back to you shortly.</p>
        </div>
      <% } else { %>
        <form method="POST" action="/contact">
          <div style="display:flex;gap:10px;">
            <div style="flex:1;"><label>Name *</label><input type="text" name="name" required placeholder="Your name"></div>
            <div style="flex:1;"><label>Company</label><input type="text" name="company" placeholder="Company name"></div>
          </div>
          <div style="display:flex;gap:10px;">
            <div style="flex:1;"><label>Email *</label><input type="email" name="email" required placeholder="you@company.com"></div>
            <div style="flex:1;"><label>Phone</label><input type="text" name="phone" placeholder="+1 555-0100"></div>
          </div>
          <div><label>How can we help? *</label><textarea name="message" required rows="4" placeholder="Tell us about your IT needs, number of employees, current setup..."></textarea></div>
          <button type="submit">Send Message</button>
        </form>
      <% } %>
    </div>
  </div>
</div>

<footer>
  &copy; <%= new Date().getFullYear() %> <%= settings.business_name || 'IT Services' %>. All rights reserved.
  &nbsp;·&nbsp; <a href="/login">Client Portal</a>
</footer>

</body>
</html>
