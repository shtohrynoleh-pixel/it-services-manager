<%- include('../partials/head') %>
<div class="app-wrap">
  <%- include('../partials/sidebar', { settings, user, page, tab: '' }) %>
  <div class="main">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px;"><button class="mob-toggle" onclick="openSidebar()">☰</button><h2><a href="/admin/companies/<%= company.id %>?tab=<%= table %>" style="opacity:0.4;text-decoration:none;">🏢</a> → Edit <%= table.charAt(0).toUpperCase() + table.slice(1).replace('_',' ') %></h2></div>
      <%- include('../partials/notif-bell') %>
    </div>
    <div class="content">
      <div class="card">
        <h3>Edit Record — <%= company.name %></h3>
        <form method="POST" action="/admin/companies/<%= company.id %>/<%= table %>/<%= item.id %>/edit">

          <% if (dbTable === 'contacts') { %>
            <div class="form-row"><div class="form-group"><label>Name</label><input type="text" name="name" value="<%= item.name || '' %>" required></div><div class="form-group"><label>Role</label><input type="text" name="role" value="<%= item.role || '' %>"></div></div>
            <div class="form-row"><div class="form-group"><label>Email</label><input type="email" name="email" value="<%= item.email || '' %>"></div><div class="form-group"><label>Phone</label><input type="text" name="phone" value="<%= item.phone || '' %>"></div></div>
            <div class="form-check"><input type="checkbox" name="is_primary" value="1" <%= item.is_primary ? 'checked' : '' %>> Primary contact</div>

          <% } else if (dbTable === 'company_users') { %>
            <div class="form-row"><div class="form-group"><label>Full Name *</label><input type="text" name="name" value="<%= item.name || '' %>" required></div><div class="form-group"><label>Job Title</label><input type="text" name="title" value="<%= item.title || '' %>" placeholder="e.g. Senior Dispatcher"></div></div>
            <div class="form-row"><div class="form-group"><label>Personal Email</label><input type="email" name="email" value="<%= item.email || '' %>"></div><div class="form-group"><label>Phone</label><input type="text" name="phone" value="<%= item.phone || '' %>"></div></div>
            <div class="form-row"><div class="form-group"><label>Department</label><select name="department"><option value="">— Select —</option><% (depts||[]).forEach(d => { %><option <%= item.department === d.name ? 'selected' : '' %>><%= d.name %></option><% }) %></select></div><div class="form-group"><label>Role</label><select name="role"><option value="">— Select —</option><% (roles||[]).forEach(r => { %><option <%= item.role === r.name ? 'selected' : '' %>><%= r.name %></option><% }) %></select></div></div>
            <div class="form-row"><div class="form-group"><label>Company Email</label><input type="email" name="email_account" value="<%= item.email_account || '' %>"></div><div class="form-group"><label>Reports To</label><select name="manager_id"><option value="">— No manager —</option><% (companyUsers||[]).forEach(u => { if (u.id !== item.id) { %><option value="<%= u.id %>" <%= item.manager_id === u.id ? 'selected' : '' %>><%= u.name %></option><% } }) %></select></div></div>
            <div class="form-row"><div class="form-group"><label>Hire Date</label><input type="date" name="hire_date" value="<%= item.hire_date || '' %>"></div><div class="form-group"><label>Photo URL</label><input type="text" name="photo_url" value="<%= item.photo_url || '' %>" placeholder="https://..."></div></div>
            <div class="form-check"><input type="checkbox" name="is_active" value="1" <%= item.is_active ? 'checked' : '' %>> Active employee</div>
            <div style="margin-top:8px;"><a href="/admin/companies/<%= company.id %>/users/<%= item.id %>/profile" class="btn btn-sm">👤 View Full Profile</a></div>

          <% } else if (dbTable === 'servers') { %>
            <div class="form-row"><div class="form-group"><label>Name *</label><input type="text" name="name" value="<%= item.name || '' %>" required></div><div class="form-group"><label>Type</label><select name="type"><% ['Physical','Virtual','Cloud'].forEach(t => { %><option <%= item.type === t ? 'selected' : '' %>><%= t %></option><% }) %></select></div></div>
            <div class="form-row"><div class="form-group"><label>IP</label><input type="text" name="ip" value="<%= item.ip || '' %>"></div><div class="form-group"><label>OS</label><input type="text" name="os" value="<%= item.os || '' %>"></div></div>
            <div class="form-group"><label>Purpose</label><input type="text" name="purpose" value="<%= item.purpose || '' %>"></div>
            <div class="form-group"><label>Location</label><select name="location"><% ['On-premises','AWS','Azure','Google Cloud','Other'].forEach(l => { %><option <%= item.location === l ? 'selected' : '' %>><%= l %></option><% }) %></select></div>
            <div class="form-check"><input type="checkbox" name="is_active" value="1" <%= item.is_active ? 'checked' : '' %>> Active</div>
            <div class="form-group"><label>Notes</label><textarea name="notes"><%= item.notes || '' %></textarea></div>

          <% } else if (dbTable === 'subscriptions') { %>
            <div class="form-row"><div class="form-group"><label>Name *</label><input type="text" name="name" value="<%= item.name || '' %>" required></div><div class="form-group"><label>Vendor</label><input type="text" name="vendor" value="<%= item.vendor || '' %>"></div></div>
            <div class="form-row"><div class="form-group"><label>Type</label><input type="text" name="type" value="<%= item.type || '' %>"></div><div class="form-group"><label>Seats</label><input type="number" name="seats" value="<%= item.seats || 1 %>"></div></div>
            <div class="form-row"><div class="form-group"><label>Cost per Unit ($)</label><input type="number" name="cost_per_unit" step="0.01" value="<%= item.cost_per_unit || 0 %>"></div><div class="form-group"><label>Billing Cycle</label><select name="billing_cycle"><% ['Monthly','Yearly'].forEach(b => { %><option <%= item.billing_cycle === b ? 'selected' : '' %>><%= b %></option><% }) %></select></div></div>
            <div class="form-group"><label>Renewal Date</label><input type="date" name="renewal_date" value="<%= item.renewal_date || '' %>"></div>
            <div class="form-check"><input type="checkbox" name="auto_renew" value="1" <%= item.auto_renew ? 'checked' : '' %>> Auto-renew</div>
            <div class="form-group"><label>Notes</label><textarea name="notes"><%= item.notes || '' %></textarea></div>

          <% } else if (dbTable === 'assets') { %>
            <div class="form-row"><div class="form-group"><label>Name *</label><input type="text" name="name" value="<%= item.name || '' %>" required></div><div class="form-group"><label>Type</label><select name="type"><% ['Domain','Website','SSL Certificate','Email Account','Cloud Account','Social Media','Other'].forEach(t => { %><option <%= item.type === t ? 'selected' : '' %>><%= t %></option><% }) %></select></div></div>
            <div class="form-row"><div class="form-group"><label>Provider</label><input type="text" name="provider" value="<%= item.provider || '' %>"></div><div class="form-group"><label>Expires</label><input type="date" name="expires_at" value="<%= item.expires_at || '' %>"></div></div>
            <div class="form-group"><label>Login URL</label><input type="text" name="login_url" value="<%= item.login_url || '' %>"></div>
            <div class="form-group"><label>Notes</label><textarea name="notes"><%= item.notes || '' %></textarea></div>

          <% } else if (dbTable === 'inventory') { %>
            <div class="form-row"><div class="form-group"><label>Name *</label><input type="text" name="name" value="<%= item.name || '' %>" required></div><div class="form-group"><label>Type</label><select name="type"><% ['Desktop','Laptop','Monitor','Printer','Router','Switch','Firewall','UPS','Phone','Tablet','Server','Cable','Accessory','Other'].forEach(t => { %><option <%= item.type === t ? 'selected' : '' %>><%= t %></option><% }) %></select></div></div>
            <div class="form-row"><div class="form-group"><label>Manufacturer</label><input type="text" name="manufacturer" value="<%= item.manufacturer || '' %>" placeholder="Dell, HP, Lenovo..."></div><div class="form-group"><label>Model</label><input type="text" name="model" value="<%= item.model || '' %>"></div></div>
            <div class="form-row"><div class="form-group"><label>Serial #</label><input type="text" name="serial_number" value="<%= item.serial_number || '' %>"></div><div class="form-group"><label>Condition</label><select name="condition"><% ['New','Good','Fair','Needs Repair','Retired'].forEach(c => { %><option <%= item.condition === c ? 'selected' : '' %>><%= c %></option><% }) %></select></div></div>
            <div class="form-row-3"><div class="form-group"><label>Quantity</label><input type="number" name="quantity" value="<%= item.quantity || 1 %>" min="1"></div><div class="form-group"><label>Unit Cost ($)</label><input type="number" name="cost" step="0.01" value="<%= item.cost || 0 %>"></div><div class="form-group"><label>Location</label><select name="location_id"><option value="">— No Location —</option><% (locations||[]).forEach(l => { %><option value="<%= l.id %>" <%= item.location_id === l.id ? 'selected' : '' %>><%= l.name %></option><% }) %></select></div></div>
            <div class="form-row"><div class="form-group"><label>Purchase Date</label><input type="date" name="purchase_date" value="<%= item.purchase_date || '' %>"></div><div class="form-group"><label>Warranty Expires</label><input type="date" name="warranty_expires" value="<%= item.warranty_expires || '' %>"></div></div>
            <div class="form-group"><label>Assigned To</label><select name="assigned_to"><option value="">— Unassigned —</option><% (companyUsers||[]).forEach(u => { %><option value="<%= u.name %>" <%= item.assigned_to === u.name ? 'selected' : '' %>><%= u.name %></option><% }) %></select></div>
            <div class="form-group"><label>Notes</label><textarea name="notes"><%= item.notes || '' %></textarea></div>
          <% } %>

          <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a href="/admin/companies/<%= company.id %>?tab=<%= table %>" class="btn">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>
