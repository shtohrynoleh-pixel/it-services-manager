<%- include('../partials/head') %>
<div class="app-wrap">
  <%- include('../partials/sidebar', { settings, user, page, tab: '' }) %>
  <div class="main">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px;"><button class="mob-toggle" onclick="openSidebar()">☰</button><h2><a href="/admin/companies/<%= company.id %>?tab=users" style="opacity:0.4;text-decoration:none;">👥</a> → <%= usr.name %></h2></div>
      <div style="display:flex;align-items:center;gap:8px;"><span class="badge <%= usr.is_active ? 'active' : 'inactive' %>"><%= usr.is_active ? 'Active' : 'Inactive' %></span><%- include('../partials/notif-bell') %></div>
    </div>
    <div class="content">
      <!-- Profile header -->
      <div class="card" style="display:flex;gap:20px;align-items:flex-start;flex-wrap:wrap;">
        <% if (usr.photo_url) { %>
          <img src="<%= usr.photo_url %>" style="width:80px;height:80px;border-radius:50%;object-fit:cover;border:3px solid var(--border);">
        <% } else { %>
          <div style="width:80px;height:80px;border-radius:50%;background:var(--primary-light);display:flex;align-items:center;justify-content:center;font-size:28px;font-weight:900;color:var(--primary);flex-shrink:0;"><%= usr.name.charAt(0).toUpperCase() %></div>
        <% } %>
        <div style="flex:1;min-width:200px;">
          <h3 style="margin-bottom:2px;font-size:20px;"><%= usr.name %></h3>
          <% if (usr.title) { %><div style="font-size:13px;color:var(--muted);margin-bottom:6px;"><%= usr.title %></div><% } %>
          <div style="display:flex;gap:6px;flex-wrap:wrap;">
            <% if (usr.role) { %><span class="badge active"><%= usr.role %></span><% } %>
            <% if (usr.department) { %><span class="badge prospect"><%= usr.department %></span><% } %>
          </div>
        </div>
        <a href="/admin/companies/<%= company.id %>/users/<%= usr.id %>/edit" class="btn btn-sm">✏️ Edit</a>
      </div>

      <!-- Contact info -->
      <div class="card">
        <h3><i class="ti ti-address-book"></i> Contact Info</h3>
        <div class="card-row"><span class="label">Company</span><span class="value"><a href="/admin/companies/<%= company.id %>"><%= company.name %></a></span></div>
        <div class="card-row"><span class="label">Primary Email</span><span class="value"><%= usr.email || '—' %></span></div>
        <div class="card-row"><span class="label">Company Email</span><span class="value" style="color:var(--primary);font-weight:700;"><%= usr.email_account || '—' %></span></div>
        <div class="card-row"><span class="label">Primary Phone</span><span class="value"><%= usr.phone || '—' %></span></div>
        <div class="card-row"><span class="label">Hire Date</span><span class="value"><%= usr.hire_date || '—' %></span></div>
        <% if (manager) { %><div class="card-row"><span class="label">Reports To</span><span class="value"><a href="/admin/companies/<%= company.id %>/users/<%= manager.id %>/profile"><%= manager.name %></a><% if (manager.title) { %> (<%= manager.title %>)<% } %></span></div><% } %>
      </div>

      <!-- Additional Emails -->
      <div class="card">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
          <h3 style="margin:0;"><i class="ti ti-mail"></i> Emails (<%= userEmails.length %>)</h3>
          <button class="btn btn-sm" onclick="document.getElementById('add-email').style.display=document.getElementById('add-email').style.display==='none'?'':'none'"><i class="ti ti-plus"></i></button>
        </div>
        <div id="add-email" style="display:none;margin-bottom:10px;padding:10px;background:#f8fafc;border-radius:8px;border:1px solid var(--border);">
          <form method="POST" action="/admin/companies/<%= company.id %>/users/<%= usr.id %>/emails" style="display:flex;flex-wrap:wrap;gap:6px;align-items:flex-end;">
            <div class="form-group" style="flex:1;margin-bottom:0;min-width:180px;"><label>Email *</label><input type="email" name="email" required placeholder="user@company.com"></div>
            <div class="form-group" style="margin-bottom:0;"><label>Type</label><select name="type"><option value="work">Work</option><option value="personal">Personal</option><option value="other">Other</option></select></div>
            <label style="font-size:12px;display:flex;align-items:center;gap:4px;"><input type="checkbox" name="is_primary" value="1" style="width:auto;"> Primary</label>
            <div class="form-group" style="margin-bottom:0;"><label>Notes</label><input type="text" name="notes" placeholder="Optional" style="width:120px;"></div>
            <button type="submit" class="btn btn-sm btn-primary"><i class="ti ti-check"></i></button>
          </form>
        </div>
        <% if (userEmails.length > 0) { %>
          <% userEmails.forEach(em => { %>
            <div style="display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid #f1f5f9;font-size:13px;">
              <span style="flex:1;font-weight:<%= em.is_primary ? '700' : '400' %>;"><%= em.email %></span>
              <span class="badge" style="font-size:9px;"><%= em.type %></span>
              <% if (em.is_primary) { %><span style="font-size:9px;color:#16a34a;font-weight:700;">PRIMARY</span><% } else { %>
                <form method="POST" action="/admin/companies/<%= company.id %>/users/<%= usr.id %>/emails/<%= em.id %>/primary" style="display:inline;"><button type="submit" class="btn btn-sm" style="padding:1px 4px;font-size:9px;" title="Set primary"><i class="ti ti-star"></i></button></form>
              <% } %>
              <% if (em.notes) { %><span style="font-size:10px;color:var(--muted);" title="<%= em.notes %>"><i class="ti ti-note"></i></span><% } %>
              <form method="POST" action="/admin/companies/<%= company.id %>/users/<%= usr.id %>/emails/<%= em.id %>/delete" style="display:inline;" onsubmit="return confirm('Remove?')"><button type="submit" class="btn btn-sm" style="padding:1px 4px;color:#ef4444;"><i class="ti ti-x"></i></button></form>
            </div>
          <% }) %>
        <% } else { %>
          <div style="font-size:12px;color:var(--muted);">No additional emails. Click + to add.</div>
        <% } %>
      </div>

      <!-- Additional Phones -->
      <div class="card">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
          <h3 style="margin:0;"><i class="ti ti-phone"></i> Phones (<%= userPhones.length %>)</h3>
          <button class="btn btn-sm" onclick="document.getElementById('add-phone').style.display=document.getElementById('add-phone').style.display==='none'?'':'none'"><i class="ti ti-plus"></i></button>
        </div>
        <div id="add-phone" style="display:none;margin-bottom:10px;padding:10px;background:#f8fafc;border-radius:8px;border:1px solid var(--border);">
          <form method="POST" action="/admin/companies/<%= company.id %>/users/<%= usr.id %>/phones" style="display:flex;flex-wrap:wrap;gap:6px;align-items:flex-end;">
            <div class="form-group" style="flex:1;margin-bottom:0;min-width:140px;"><label>Phone *</label><input type="text" name="phone" required placeholder="555-0100"></div>
            <div class="form-group" style="margin-bottom:0;"><label>Ext</label><input type="text" name="ext" placeholder="1234" style="width:70px;"></div>
            <div class="form-group" style="margin-bottom:0;"><label>Type</label><select name="type"><option value="work">Work</option><option value="mobile">Mobile</option><option value="home">Home</option><option value="fax">Fax</option><option value="other">Other</option></select></div>
            <label style="font-size:12px;display:flex;align-items:center;gap:4px;"><input type="checkbox" name="is_primary" value="1" style="width:auto;"> Primary</label>
            <div class="form-group" style="margin-bottom:0;"><label>Notes</label><input type="text" name="notes" placeholder="Optional" style="width:120px;"></div>
            <button type="submit" class="btn btn-sm btn-primary"><i class="ti ti-check"></i></button>
          </form>
        </div>
        <% if (userPhones.length > 0) { %>
          <% userPhones.forEach(ph => { %>
            <div style="display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid #f1f5f9;font-size:13px;">
              <span style="flex:1;font-weight:<%= ph.is_primary ? '700' : '400' %>;"><%= ph.phone %><% if (ph.ext) { %> <span style="font-size:11px;color:var(--muted);">x<%= ph.ext %></span><% } %></span>
              <span class="badge" style="font-size:9px;"><%= ph.type %></span>
              <% if (ph.is_primary) { %><span style="font-size:9px;color:#16a34a;font-weight:700;">PRIMARY</span><% } else { %>
                <form method="POST" action="/admin/companies/<%= company.id %>/users/<%= usr.id %>/phones/<%= ph.id %>/primary" style="display:inline;"><button type="submit" class="btn btn-sm" style="padding:1px 4px;font-size:9px;" title="Set primary"><i class="ti ti-star"></i></button></form>
              <% } %>
              <% if (ph.notes) { %><span style="font-size:10px;color:var(--muted);" title="<%= ph.notes %>"><i class="ti ti-note"></i></span><% } %>
              <form method="POST" action="/admin/companies/<%= company.id %>/users/<%= usr.id %>/phones/<%= ph.id %>/delete" style="display:inline;" onsubmit="return confirm('Remove?')"><button type="submit" class="btn btn-sm" style="padding:1px 4px;color:#ef4444;"><i class="ti ti-x"></i></button></form>
            </div>
          <% }) %>
        <% } else { %>
          <div style="font-size:12px;color:var(--muted);">No additional phones. Click + to add.</div>
        <% } %>
      </div>

      <!-- Divisions -->
      <div class="card">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
          <h3 style="margin:0;"><i class="ti ti-hierarchy-2"></i> Divisions (<%= userDivisions.length %>)</h3>
          <div style="display:flex;gap:4px;">
            <a href="/admin/companies/<%= company.id %>/divisions" class="btn btn-sm" title="Manage Divisions"><i class="ti ti-settings"></i></a>
            <button class="btn btn-sm" onclick="document.getElementById('add-div').style.display=document.getElementById('add-div').style.display==='none'?'':'none'"><i class="ti ti-plus"></i></button>
          </div>
        </div>
        <div id="add-div" style="display:none;margin-bottom:10px;padding:10px;background:#f8fafc;border-radius:8px;border:1px solid var(--border);">
          <form method="POST" action="/admin/companies/<%= company.id %>/users/<%= usr.id %>/divisions" style="display:flex;flex-wrap:wrap;gap:6px;align-items:flex-end;">
            <div class="form-group" style="flex:1;margin-bottom:0;min-width:160px;"><label>Division *</label><select name="division_id" required><option value="">— Select —</option><% allDivisions.forEach(d => { %><option value="<%= d.id %>"><%= d.name %><%= d.code ? ' (' + d.code + ')' : '' %></option><% }) %></select></div>
            <div class="form-group" style="margin-bottom:0;"><label>Role in Division</label><input type="text" name="role_in_division" placeholder="e.g. Lead, Member" style="width:140px;"></div>
            <label style="font-size:12px;display:flex;align-items:center;gap:4px;"><input type="checkbox" name="is_primary" value="1" style="width:auto;"> Primary</label>
            <button type="submit" class="btn btn-sm btn-primary"><i class="ti ti-check"></i></button>
          </form>
        </div>
        <% if (userDivisions.length > 0) { %>
          <% userDivisions.forEach(ud => { %>
            <div style="display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid #f1f5f9;font-size:13px;">
              <span style="flex:1;font-weight:700;"><%= ud.division_name %><% if (ud.division_code) { %> <span style="font-size:11px;color:var(--muted);">(<%= ud.division_code %>)</span><% } %></span>
              <% if (ud.role_in_division) { %><span class="badge" style="font-size:9px;"><%= ud.role_in_division %></span><% } %>
              <% if (ud.is_primary) { %><span style="font-size:9px;color:#16a34a;font-weight:700;">PRIMARY</span><% } %>
              <form method="POST" action="/admin/companies/<%= company.id %>/users/<%= usr.id %>/divisions/<%= ud.id %>/delete" style="display:inline;" onsubmit="return confirm('Remove from division?')"><button type="submit" class="btn btn-sm" style="padding:1px 4px;color:#ef4444;"><i class="ti ti-x"></i></button></form>
            </div>
          <% }) %>
        <% } else { %>
          <div style="font-size:12px;color:var(--muted);">Not assigned to any divisions. <% if (allDivisions.length === 0) { %><a href="/admin/companies/<%= company.id %>/divisions">Create divisions first</a>.<% } else { %>Click + to assign.<% } %></div>
        <% } %>
      </div>

      <!-- Manager assignment -->
      <div class="card">
        <h3>👤 Reporting Structure</h3>
        <form method="POST" action="/admin/companies/<%= company.id %>/users/<%= usr.id %>/set-manager" style="display:flex;gap:8px;align-items:flex-end;margin-bottom:12px;">
          <div class="form-group" style="flex:1;margin:0;"><label>Reports To</label><select name="manager_id"><option value="">— No manager —</option><% allUsers.forEach(u => { %><option value="<%= u.id %>" <%= usr.manager_id === u.id ? 'selected' : '' %>><%= u.name %><% if (u.title) { %> (<%= u.title %>)<% } %></option><% }) %></select></div>
          <button type="submit" class="btn btn-sm btn-primary">Save</button>
        </form>
        <% if (directReports.length > 0) { %>
          <div style="font-size:12px;font-weight:700;color:var(--muted);margin:12px 0 8px;">DIRECT REPORTS (<%= directReports.length %>)</div>
          <% directReports.forEach(dr => { %>
            <a href="/admin/companies/<%= company.id %>/users/<%= dr.id %>/profile" class="item-card" style="text-decoration:none;color:inherit;">
              <div class="ic-main"><div class="ic-name"><%= dr.name %></div><div class="ic-sub"><%= dr.title || '' %> · <%= dr.role || '' %> · <%= dr.department || '' %></div></div>
            </a>
          <% }) %>
        <% } %>
      </div>

      <!-- Assigned Equipment -->
      <div class="card">
        <h3>🔧 Assigned Equipment (<%= assignedEquip.length %>)</h3>
        <% if (assignedEquip.length === 0) { %>
          <div style="font-size:12px;color:var(--muted);margin-bottom:10px;">No equipment assigned</div>
        <% } else { %>
          <% assignedEquip.forEach(eq => { %>
            <div class="item-card" style="cursor:default;"><div class="ic-main"><div class="ic-name"><%= eq.name %></div><div class="ic-sub"><%= eq.type || '' %> · SN: <%= eq.serial_number || '—' %> · <span class="badge <%= eq.condition === 'Good' || eq.condition === 'New' ? 'active' : eq.condition === 'Needs Repair' ? 'overdue' : 'inactive' %>"><%= eq.condition %></span></div></div></div>
          <% }) %>
        <% } %>
        <details style="margin-top:10px;"><summary style="cursor:pointer;font-size:12px;font-weight:600;color:var(--primary);">+ Assign Equipment</summary>
          <form method="POST" action="/admin/companies/<%= company.id %>/users/<%= usr.id %>/assign-equipment" style="display:flex;gap:8px;margin-top:8px;">
            <select name="inventory_id" style="flex:1;">
              <option value="">Select equipment...</option>
              <% const inventory = assignedEquip; /* already have it */ %>
            </select>
            <button type="submit" class="btn btn-sm btn-primary">Assign</button>
          </form>
          <div style="font-size:10px;color:var(--muted);margin-top:4px;">Go to <a href="/admin/companies/<%= company.id %>?tab=inventory">Inventory tab</a> to assign equipment by setting "Assigned To" field to this user's name.</div>
        </details>
      </div>

      <!-- Assigned Software -->
      <div class="card">
        <h3>💻 Assigned Software (<%= assignedSoftware.length %>)</h3>
        <% if (assignedSoftware.length > 0) { %>
          <table class="tbl">
            <thead><tr><th>Software</th><th>Vendor</th><th>License Key</th><th>Cost</th><th></th></tr></thead>
            <tbody>
            <% assignedSoftware.forEach(sw => { %>
              <tr>
                <td><strong><%= sw.name %></strong></td>
                <td><%= sw.vendor || '—' %></td>
                <td style="font-family:monospace;font-size:11px;"><%= sw.license_key || '—' %></td>
                <td>$<%= (sw.cost||0).toFixed(2) %></td>
                <td><form method="POST" action="/admin/companies/<%= company.id %>/users/<%= usr.id %>/software/<%= sw.id %>/delete" style="display:inline"><button class="btn-ghost" onclick="return confirm('Remove?')">🗑️</button></form></td>
              </tr>
            <% }) %>
            </tbody>
          </table>
        <% } %>
        <details style="margin-top:10px;"><summary style="cursor:pointer;font-size:12px;font-weight:600;color:var(--primary);">+ Add Software License</summary>
          <form method="POST" action="/admin/companies/<%= company.id %>/users/<%= usr.id %>/assign-software" style="margin-top:8px;">
            <div class="form-row"><div class="form-group"><label>Software Name</label><input type="text" name="name" required placeholder="Microsoft Office, QuickBooks..."></div><div class="form-group"><label>Vendor</label><input type="text" name="vendor" placeholder="Microsoft"></div></div>
            <div class="form-row"><div class="form-group"><label>License Key</label><input type="text" name="license_key" placeholder="XXXX-XXXX-XXXX"></div><div class="form-group"><label>Monthly Cost ($)</label><input type="number" name="cost" step="0.01" placeholder="0.00"></div></div>
            <button type="submit" class="btn btn-sm btn-primary">Add Software</button>
          </form>
        </details>
      </div>

      <!-- User's tasks -->
      <% if (tasks.length > 0) { %>
      <div class="card">
        <h3>✅ Tasks (<%= tasks.length %>)</h3>
        <% tasks.forEach(t => { %>
          <div class="item-card" style="cursor:default;"><div class="ic-main"><div class="ic-name" style="<%= t.status === 'done' ? 'text-decoration:line-through;opacity:0.5;' : '' %>"><%= t.title %></div><div class="ic-sub"><span class="badge <%= t.status === 'done' ? 'paid' : t.status === 'in-progress' ? 'sent' : 'prospect' %>"><%= t.status %></span> · <span class="badge <%= t.priority === 'urgent' ? 'overdue' : t.priority === 'high' ? 'sent' : 'active' %>"><%= t.priority %></span><% if (t.due_date) { %> · 📅 <%= t.due_date %><% } %></div></div></div>
        <% }) %>
      </div>
      <% } %>

      <% if (usr.notes) { %>
      <div class="card"><h3>📝 Notes</h3><div style="font-size:13px;white-space:pre-wrap;"><%= usr.notes %></div></div>
      <% } %>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>
