<%- include('../partials/head') %>
<div class="app-wrap">
  <%- include('../partials/sidebar', { settings, user, page, tab: '' }) %>
  <div class="main">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px;"><button class="mob-toggle" onclick="openSidebar()">☰</button><h2><a href="/admin/companies/<%= company.id %>?tab=agreements" style="opacity:0.4;text-decoration:none;"><i class="ti ti-building"></i></a> → <i class="ti ti-file-check"></i> Agreement</h2></div>
      <%- include('../partials/notif-bell') %>
    </div>
    <div class="content">
      <div class="card">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:12px;">
          <div>
            <h3 style="margin-bottom:4px;"><%= agreement.title || agreement.service_name || 'Service Agreement' %></h3>
            <div style="font-size:13px;color:var(--muted);"><%= company.name %><%= agreement.service_name ? ' · ' + agreement.service_name : '' %></div>
          </div>
          <span class="badge <%= agreement.is_active ? 'active' : 'inactive' %>" style="font-size:12px;padding:4px 14px;"><%= agreement.is_active ? 'Active' : 'Inactive' %></span>
        </div>

        <div class="metrics" style="margin-top:16px;">
          <div class="metric hi"><div class="m-label">Price</div><div class="m-val pri">$<%= (agreement.custom_price || agreement.base_price || 0).toFixed(2) %></div></div>
          <div class="metric"><div class="m-label">Billing</div><div class="m-val"><%= agreement.billing_cycle || '—' %></div></div>
          <div class="metric"><div class="m-label">Start</div><div class="m-val" style="font-size:14px;"><%= agreement.start_date || '—' %></div></div>
          <div class="metric"><div class="m-label">End</div><div class="m-val" style="font-size:14px;"><%= agreement.end_date || 'Ongoing' %></div></div>
        </div>

        <% if (agreement.sla_response || agreement.sla_resolution) { %>
          <div style="margin-top:14px;padding:14px;background:#f0fdfa;border:1px solid #a7f3d0;border-radius:10px;">
            <div style="font-size:12px;font-weight:800;margin-bottom:6px;"><i class="ti ti-clock"></i> SLA</div>
            <div style="display:flex;gap:20px;">
              <% if (agreement.sla_response) { %><div style="font-size:12px;"><strong>Response:</strong> <%= agreement.sla_response %></div><% } %>
              <% if (agreement.sla_resolution) { %><div style="font-size:12px;"><strong>Resolution:</strong> <%= agreement.sla_resolution %></div><% } %>
            </div>
          </div>
        <% } %>

        <div style="margin-top:14px;">
          <div class="card-row"><span class="label">Auto-Renew</span><span class="value"><%= agreement.auto_renew ? 'Yes' : 'No' %></span></div>
          <% if (agreement.signed_by) { %><div class="card-row"><span class="label">Signed By</span><span class="value"><%= agreement.signed_by %><%= agreement.signed_date ? ' on ' + agreement.signed_date : '' %></span></div><% } %>
          <% if (agreement.scope) { %><div class="card-row"><span class="label">Scope</span><span class="value"><%= agreement.scope %></span></div><% } %>
          <% if (agreement.exclusions) { %><div class="card-row"><span class="label">Exclusions</span><span class="value"><%= agreement.exclusions %></span></div><% } %>
          <% if (agreement.notes) { %><div class="card-row"><span class="label">Notes</span><span class="value"><%= agreement.notes %></span></div><% } %>
        </div>

        <% if (agreement.terms) { %>
          <div style="margin-top:14px;">
            <div style="font-size:12px;font-weight:800;margin-bottom:6px;">Terms & Conditions</div>
            <div style="background:#f8fafc;border:1px solid var(--border);border-radius:8px;padding:16px;font-size:12px;white-space:pre-wrap;line-height:1.7;"><%= agreement.terms %></div>
          </div>
        <% } %>
      </div>

      <!-- Attachment -->
      <div class="card">
        <h3><i class="ti ti-paperclip"></i> Attachment</h3>
        <% if (agreement.attachment) { %>
          <div style="display:flex;align-items:center;gap:10px;padding:10px;background:var(--bg);border-radius:8px;margin-bottom:12px;">
            <i class="ti ti-file" style="font-size:24px;color:var(--primary);"></i>
            <div style="flex:1;"><div style="font-weight:700;font-size:12px;"><%= agreement.attachment_name %></div></div>
            <a href="/admin/companies/<%= company.id %>/agreements/<%= agreement.id %>/download" class="btn btn-sm"><i class="ti ti-download"></i> Download</a>
          </div>
        <% } else { %>
          <div style="font-size:12px;color:var(--muted);margin-bottom:12px;">No contract document attached.</div>
        <% } %>
        <form method="POST" action="/admin/companies/<%= company.id %>/agreements/<%= agreement.id %>/upload" enctype="multipart/form-data" style="display:flex;gap:8px;align-items:flex-end;">
          <div class="form-group" style="flex:1;margin:0;"><label>Upload Contract (PDF, DOC, etc.)</label><input type="file" name="file" required style="padding:6px;"></div>
          <button type="submit" class="btn btn-sm btn-primary"><i class="ti ti-upload"></i> Upload</button>
        </form>
      </div>

      <!-- Edit -->
      <details class="card">
        <summary style="cursor:pointer;font-weight:800;font-size:14px;"><i class="ti ti-edit"></i> Edit Agreement</summary>
        <form method="POST" action="/admin/companies/<%= company.id %>/agreements/<%= agreement.id %>/edit" style="margin-top:12px;">
          <div class="form-row"><div class="form-group"><label>Title</label><input type="text" name="title" value="<%= agreement.title || '' %>" placeholder="Agreement title"></div><div class="form-group"><label>Custom Price ($)</label><input type="number" name="custom_price" step="0.01" value="<%= agreement.custom_price || '' %>"></div></div>
          <div class="form-row"><div class="form-group"><label>Billing</label><select name="billing_cycle"><% ['Monthly','Yearly','Quarterly','One-time'].forEach(b => { %><option <%= agreement.billing_cycle===b?'selected':'' %>><%= b %></option><% }) %></select></div><div class="form-check" style="margin-top:20px;"><input type="checkbox" name="auto_renew" value="1" <%= agreement.auto_renew ? 'checked' : '' %>> Auto-renew</div></div>
          <div class="form-row"><div class="form-group"><label>Start Date</label><input type="date" name="start_date" value="<%= agreement.start_date || '' %>"></div><div class="form-group"><label>End Date</label><input type="date" name="end_date" value="<%= agreement.end_date || '' %>"></div></div>
          <div class="form-row"><div class="form-group"><label>SLA Response Time</label><input type="text" name="sla_response" value="<%= agreement.sla_response || '' %>" placeholder="e.g. 1 hour, 4 hours, same day"></div><div class="form-group"><label>SLA Resolution Time</label><input type="text" name="sla_resolution" value="<%= agreement.sla_resolution || '' %>" placeholder="e.g. 24 hours, 3 business days"></div></div>
          <div class="form-group"><label>Scope (what's included)</label><textarea name="scope" rows="3"><%= agreement.scope || '' %></textarea></div>
          <div class="form-group"><label>Exclusions (what's NOT included)</label><textarea name="exclusions" rows="2"><%= agreement.exclusions || '' %></textarea></div>
          <div class="form-row"><div class="form-group"><label>Signed By</label><input type="text" name="signed_by" value="<%= agreement.signed_by || '' %>"></div><div class="form-group"><label>Signed Date</label><input type="date" name="signed_date" value="<%= agreement.signed_date || '' %>"></div></div>
          <div class="form-group"><label>Terms & Conditions</label><textarea name="terms" rows="5"><%= agreement.terms || '' %></textarea></div>
          <div class="form-check"><input type="checkbox" name="is_active" value="1" <%= agreement.is_active ? 'checked' : '' %>> Active</div>
          <div class="form-group"><label>Notes</label><textarea name="notes"><%= agreement.notes || '' %></textarea></div>
          <div class="form-actions"><button type="submit" class="btn btn-primary">Save Changes</button></div>
        </form>
      </details>

      <div style="margin-top:12px;"><a href="/admin/companies/<%= company.id %>?tab=agreements" class="btn btn-sm">← Back to Agreements</a></div>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>
