<%- include('../partials/head') %>
<div class="app-wrap">
  <%- include('../partials/sidebar', { settings, user, page, tab: '' }) %>
  <div class="main">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px;"><button class="mob-toggle" onclick="openSidebar()">☰</button><h2><a href="/admin/companies/<%= company.id %>" style="opacity:0.4;text-decoration:none;"><i class="ti ti-building"></i></a> → <i class="ti ti-remote"></i> Remote Connections — <%= company.name %></h2></div>
      <%- include('../partials/notif-bell') %>
    </div>
    <div class="content">
      <div class="metrics">
        <div class="metric hi"><div class="m-label">Total</div><div class="m-val pri"><%= connections.length %></div></div>
        <div class="metric ok"><div class="m-label">Active</div><div class="m-val green"><%= connections.filter(c => c.is_active).length %></div></div>
        <div class="metric"><div class="m-label">RDP</div><div class="m-val"><%= connections.filter(c => c.type === 'rdp').length %></div></div>
        <div class="metric"><div class="m-label">SSH</div><div class="m-val"><%= connections.filter(c => c.type === 'ssh').length %></div></div>
      </div>

      <% connections.forEach(c => { %>
        <div class="card" style="margin-bottom:10px;">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px;">
            <div>
              <h3 style="margin-bottom:2px;font-size:14px;">
                <i class="ti ti-<%= c.type === 'ssh' ? 'terminal' : c.type === 'vnc' ? 'eye' : c.type === 'web' ? 'world' : 'remote' %>" style="color:var(--primary);"></i>
                <%= c.name %>
                <span class="badge <%= c.is_active ? 'active' : 'inactive' %>"><%= c.is_active ? 'Active' : 'Disabled' %></span>
                <span class="badge draft"><%= c.type.toUpperCase() %></span>
              </h3>
              <div style="font-size:12px;color:var(--muted);"><%= c.hostname %><%= c.port && c.port !== 3389 ? ':' + c.port : '' %><%= c.domain ? ' · Domain: ' + c.domain : '' %><%= c.os ? ' · ' + c.os : '' %></div>
            </div>
            <div style="display:flex;gap:4px;">
              <button class="btn btn-sm" onclick="document.getElementById('editRdp-<%= c.id %>').classList.add('open')"><i class="ti ti-edit"></i></button>
              <form method="POST" action="/admin/companies/<%= company.id %>/rdp/<%= c.id %>/delete" style="display:inline" onsubmit="return confirm('Delete?')"><button type="submit" class="btn btn-sm btn-danger"><i class="ti ti-trash"></i></button></form>
            </div>
          </div>
          <div style="margin-top:10px;display:flex;gap:16px;flex-wrap:wrap;">
            <div class="card-row" style="flex:1;min-width:200px;border:none;padding:0;">
              <div><div style="font-size:10px;color:var(--muted);font-weight:600;text-transform:uppercase;">Username</div><code style="font-size:12px;"><%= c.username || '—' %></code></div>
            </div>
            <div class="card-row" style="flex:1;min-width:200px;border:none;padding:0;">
              <div><div style="font-size:10px;color:var(--muted);font-weight:600;text-transform:uppercase;">Password</div>
                <div style="display:flex;align-items:center;gap:6px;">
                  <code id="rpw-<%= c.id %>" style="font-size:12px;">••••••••</code>
                  <button onclick="var el=document.getElementById('rpw-<%= c.id %>');el.textContent=el.textContent==='••••••••'?'<%= (c.password_enc||'').replace(/'/g,"\\'") %>':'••••••••'" style="background:none;border:none;cursor:pointer;font-size:11px;"><i class="ti ti-eye"></i></button>
                  <button onclick="navigator.clipboard.writeText('<%= (c.password_enc||'').replace(/'/g,"\\'") %>')" style="background:none;border:none;cursor:pointer;font-size:11px;"><i class="ti ti-copy"></i></button>
                </div>
              </div>
            </div>
          </div>
          <% if (c.purpose) { %><div style="font-size:11px;color:#475569;margin-top:6px;"><strong>Purpose:</strong> <%= c.purpose %></div><% } %>
          <% if (c.gateway) { %><div style="font-size:11px;color:var(--muted);margin-top:2px;">Gateway: <%= c.gateway %></div><% } %>
          <% if (c.assigned_to) { %><div style="font-size:11px;color:var(--muted);margin-top:2px;">Assigned: <%= c.assigned_to %></div><% } %>
          <% if (c.notes) { %><div style="font-size:11px;color:var(--muted);margin-top:2px;font-style:italic;"><%= c.notes %></div><% } %>

          <!-- Edit modal -->
          <div class="modal-bg" id="editRdp-<%= c.id %>" onclick="if(event.target===this)this.classList.remove('open')">
            <div class="modal">
              <h3>Edit Connection</h3>
              <form method="POST" action="/admin/companies/<%= company.id %>/rdp/<%= c.id %>/edit">
                <div class="form-row"><div class="form-group"><label>Name *</label><input type="text" name="name" value="<%= c.name %>" required></div><div class="form-group"><label>Type</label><select name="type"><% ['rdp','ssh','vnc','web','teamviewer','anydesk','other'].forEach(t => { %><option <%= c.type===t?'selected':'' %>><%= t %></option><% }) %></select></div></div>
                <div class="form-row"><div class="form-group"><label>Hostname/IP</label><input type="text" name="hostname" value="<%= c.hostname || '' %>"></div><div class="form-group"><label>Port</label><input type="number" name="port" value="<%= c.port || 3389 %>"></div></div>
                <div class="form-row"><div class="form-group"><label>Username</label><input type="text" name="username" value="<%= c.username || '' %>"></div><div class="form-group"><label>Password</label><input type="text" name="password_enc" value="<%= c.password_enc || '' %>"></div></div>
                <div class="form-row"><div class="form-group"><label>Domain</label><input type="text" name="domain" value="<%= c.domain || '' %>"></div><div class="form-group"><label>Gateway</label><input type="text" name="gateway" value="<%= c.gateway || '' %>"></div></div>
                <div class="form-row"><div class="form-group"><label>OS</label><input type="text" name="os" value="<%= c.os || '' %>"></div><div class="form-group"><label>Assigned To</label><input type="text" name="assigned_to" value="<%= c.assigned_to || '' %>"></div></div>
                <div class="form-group"><label>Purpose</label><input type="text" name="purpose" value="<%= c.purpose || '' %>"></div>
                <div class="form-check"><input type="checkbox" name="is_active" value="1" <%= c.is_active ? 'checked' : '' %>> Active</div>
                <div class="form-group"><label>Notes</label><textarea name="notes"><%= c.notes || '' %></textarea></div>
                <div class="form-actions"><button type="submit" class="btn btn-primary">Save</button><button type="button" class="btn" onclick="document.getElementById('editRdp-<%= c.id %>').classList.remove('open')">Cancel</button></div>
              </form>
            </div>
          </div>
        </div>
      <% }) %>

      <% if (connections.length === 0) { %>
        <div class="empty"><span class="e-icon"><i class="ti ti-remote" style="font-size:40px;"></i></span><div class="e-text">No remote connections</div></div>
      <% } %>

      <!-- Add new -->
      <div class="card">
        <h3><i class="ti ti-plus"></i> Add Connection</h3>
        <form method="POST" action="/admin/companies/<%= company.id %>/rdp">
          <div class="form-row"><div class="form-group"><label>Name *</label><input type="text" name="name" required placeholder="DC01, FileServer, etc."></div><div class="form-group"><label>Type</label><select name="type"><option value="rdp">RDP (Remote Desktop)</option><option value="ssh">SSH (Linux/Terminal)</option><option value="vnc">VNC</option><option value="teamviewer">TeamViewer</option><option value="anydesk">AnyDesk</option><option value="web">Web Console</option><option value="other">Other</option></select></div></div>
          <div class="form-row"><div class="form-group"><label>Hostname / IP</label><input type="text" name="hostname" placeholder="192.168.1.100 or server.company.com"></div><div class="form-group"><label>Port</label><input type="number" name="port" value="3389" placeholder="3389"></div></div>
          <div class="form-row"><div class="form-group"><label>Username</label><input type="text" name="username" placeholder="Administrator"></div><div class="form-group"><label>Password</label><input type="text" name="password_enc" placeholder="Password"></div></div>
          <div class="form-row"><div class="form-group"><label>Domain</label><input type="text" name="domain" placeholder="COMPANY"></div><div class="form-group"><label>Gateway</label><input type="text" name="gateway" placeholder="RD Gateway if used"></div></div>
          <div class="form-row"><div class="form-group"><label>OS</label><select name="os"><option>Windows Server 2022</option><option>Windows Server 2019</option><option>Windows Server 2016</option><option>Windows 11</option><option>Windows 10</option><option>Ubuntu</option><option>CentOS</option><option>Debian</option><option>macOS</option><option>Other</option></select></div><div class="form-group"><label>Assigned To</label><input type="text" name="assigned_to" placeholder="Who manages this"></div></div>
          <div class="form-group"><label>Purpose</label><input type="text" name="purpose" placeholder="Domain Controller, File Server, etc."></div>
          <div class="form-group"><label>Notes</label><textarea name="notes" placeholder="Access instructions, VPN required, etc."></textarea></div>
          <button type="submit" class="btn btn-primary">Add Connection</button>
        </form>
      </div>

      <div style="margin-top:12px;"><a href="/admin/companies/<%= company.id %>" class="btn btn-sm">← Back to <%= company.name %></a></div>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>
