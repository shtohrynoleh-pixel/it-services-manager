            <div class="metric hi"><div class="m-label">Total Users</div><div class="m-val pri"><%= allItems.length %></div></div>
            <div class="metric ok"><div class="m-label">Active</div><div class="m-val green"><%= allItems.filter(x => x.is_active).length %></div></div>
            <div class="metric"><div class="m-label">Portal Access</div><div class="m-val"><%= clientUsers.length %></div></div>
            <div class="metric"><div class="m-label">With Email</div><div class="m-val"><%= allItems.filter(x => x.email_account).length %></div></div>
          </div>
        <% } %>

        <% if (allItems.length === 0) { %>
          <div class="empty"><span class="e-icon">📭</span><div class="e-text">No <%= tab %> yet</div></div>
        <% } else { %>
          <div style="overflow-x:auto;">
          <table class="tbl" id="dataTable">
            <thead><tr><% cfg.cols.forEach(c => { %><th><%= c %></th><% }) %><th></th></tr></thead>
            <tbody>
            <% allItems.forEach(it => { %>
              <tr data-search="<%= cfg.fields.map(f => (it[f]||'')).join(' ').toLowerCase() %><%= it.manufacturer ? ' ' + it.manufacturer.toLowerCase() : '' %><%= it.model ? ' ' + it.model.toLowerCase() : '' %>" data-group="<%= (it[cfg.groupField]||'').toLowerCase() %>" <% if (cfg.extraGroups) { cfg.extraGroups.forEach(eg => { %>data-<%= eg.replace('_','-') %>="<%= (it[eg]||'').toString().toLowerCase() %>" <% }) } %>>
                <% cfg.fields.forEach((f, fi) => { %>
                  <td>
                    <% if (f === 'name' && tab === 'users') { %>
                      <a href="/admin/companies/<%= company.id %>/users/<%= it.id %>/profile" style="font-weight:700;"><%= it[f] || '—' %></a>
                      <% var hasPortal = clientUsers.find(cu => cu.full_name === it.name); %>
                      <% if (hasPortal) { %><span class="badge active" style="font-size:8px;margin-left:4px;">Portal</span><% } %>
                      <% if (it.title) { %><div style="font-size:10px;color:var(--muted);"><%= it.title %></div><% } %>
                    <% } else if (f === 'assigned_to' && it[f]) { %><% var assignedUser = users.find(u => u.name === it[f]); %><% if (assignedUser) { %><a href="/admin/companies/<%= company.id %>/users/<%= assignedUser.id %>/profile" style="font-weight:600;"><%= it[f] %></a><% } else { %><%= it[f] %><% } %>
                    <% } else if (f === 'cost_per_unit' || f === 'cost') { %><%= (it[f]||0) > 0 ? '$' + (it[f]||0).toFixed(2) : '—' %>
                    <% } else if (f === 'is_active') { %><span class="badge <%= it[f] ? 'active' : 'inactive' %>"><%= it[f] ? 'Active' : 'Inactive' %></span>
                    <% } else if (f === 'condition') { %><span class="badge <%= it[f]==='New'||it[f]==='Good'?'active':it[f]==='Needs Repair'?'overdue':it[f]==='Retired'?'inactive':'draft' %>"><%= it[f] || '—' %></span>
                    <% } else { %><%= it[f] || '—' %><% } %>
                  </td>
                <% }) %>
                <td style="white-space:nowrap;">
                  <% if (tab === 'users') { %>
                    <a href="/admin/companies/<%= company.id %>/users/<%= it.id %>/profile" class="btn-ghost" title="Profile">👤</a>
                    <% var userHasPortal = clientUsers.find(cu => cu.full_name === it.name); %>
                    <% if (!userHasPortal) { %><button class="btn-ghost" title="Grant Portal Access" onclick="event.stopPropagation();document.getElementById('grantModal-<%= it.id %>').classList.add('open')" style="color:var(--primary);">🔑</button><% } %>
                  <% } %>
                  <a href="/admin/companies/<%= company.id %>/<%= tab %>/<%= it.id %>/edit" class="btn-ghost" title="Edit">✏️</a><form method="POST" action="/admin/companies/<%= company.id %>/<%= cfg.dbTable %>/<%= it.id %>/delete" style="display:inline"><button type="submit" class="btn-ghost" onclick="return confirm('Delete?')">🗑️</button></form></td>
              </tr>
            <% }) %>
            </tbody>
          </table>
          </div>

          <!-- Grant portal access modals (one per user) -->
          <% if (tab === 'users') { allItems.forEach(it => { var uhp = clientUsers.find(cu => cu.full_name === it.name); if (!uhp) { %>
            <div class="modal-bg" id="grantModal-<%= it.id %>" onclick="if(event.target===this)this.classList.remove('open')">
              <div class="modal" style="max-width:400px;">
                <h3>🔑 Grant Portal Access</h3>
                <p style="font-size:13px;margin-bottom:14px;">Create a login for <strong><%= it.name %></strong> to access the client portal.</p>
                <form method="POST" action="/admin/companies/<%= company.id %>/grant-portal-access">
                  <input type="hidden" name="company_user_id" value="<%= it.id %>">
                  <div class="form-group"><label>Username *</label><input type="text" name="username" value="<%= (it.email_account || it.email || it.name.toLowerCase().replace(/\s+/g,'.')).split('@')[0] %>" required></div>
                  <div class="form-group"><label>Password *</label><input type="text" name="password" required placeholder="Set a password"></div>
                  <div style="font-size:11px;color:var(--muted);margin-bottom:12px;">
                    Name: <%= it.name %><br>
                    Email: <%= it.email_account || it.email || '—' %><br>
                    Dept: <%= it.department || '—' %> · Role: <%= it.role || '—' %>
                  </div>
                  <div class="form-actions"><button type="submit" class="btn btn-primary">Grant Access</button><button type="button" class="btn" onclick="document.getElementById('grantModal-<%= it.id %>').classList.remove('open')">Cancel</button></div>
                </form>
              </div>
            </div>
          <% } }) } %>

          <script>
          var currentGroupAttr = 'data-group';
          function changeGroupBy(){
            var sel = document.getElementById('groupByField');
            if (!sel) return;
            var field = sel.value;
            currentGroupAttr = field === '<%= cfg.groupField %>' ? 'data-group' : 'data-' + field.replace('_','-');
            // rebuild filter options
            var vals = new Set();
            document.querySelectorAll('#dataTable tbody tr').forEach(function(r){
              var v = r.getAttribute(currentGroupAttr);
              if (v) vals.add(v);
            });
            var gf = document.getElementById('groupField');
            gf.innerHTML = '<option value="">Filter: All</option>';
            Array.from(vals).sort().forEach(function(v){
              var o = document.createElement('option');
              o.value = v; o.textContent = v.charAt(0).toUpperCase() + v.slice(1);
              gf.appendChild(o);
            });
            filterTable();
          }
          function filterTable(){
            var search = (document.getElementById('searchField').value||'').toLowerCase();
            var group = (document.getElementById('groupField')||{value:''}).value.toLowerCase();
            var rows = document.querySelectorAll('#dataTable tbody tr');
            rows.forEach(function(row){
              var matchSearch = !search || row.getAttribute('data-search').indexOf(search) >= 0;
              var matchGroup = !group || row.getAttribute(currentGroupAttr) === group;
              row.style.display = (matchSearch && matchGroup) ? '' : 'none';
            });
          }
          </script>
        <% } %>

        <!-- Add item modal -->
        <div class="modal-bg" id="addItemModal" onclick="if(event.target===this)this.classList.remove('open')">
          <div class="modal">
            <h3>Add <%= tab.charAt(0).toUpperCase() + tab.slice(1).replace('_',' ') %></h3>
            <form method="POST" action="/admin/companies/<%= company.id %>/<%= cfg.dbTable %>">
              <% if (tab === 'contacts') { %>
                <div class="form-row"><div class="form-group"><label>Name</label><input type="text" name="name" required></div><div class="form-group"><label>Role</label><input type="text" name="role" placeholder="Owner, Dispatcher..."></div></div>
                <div class="form-row"><div class="form-group"><label>Email</label><input type="email" name="email"></div><div class="form-group"><label>Phone</label><input type="text" name="phone"></div></div>
              <% } else if (tab === 'users') { %>
                <div class="form-row"><div class="form-group"><label>Full Name *</label><input type="text" name="name" required placeholder="John Smith"></div><div class="form-group"><label>Job Title</label><input type="text" name="title" placeholder="e.g. Senior Dispatcher"></div></div>
                <div class="form-row"><div class="form-group"><label>Personal Email</label><input type="email" name="email" placeholder="john@gmail.com"></div><div class="form-group"><label>Phone</label><input type="text" name="phone" placeholder="555-0100"></div></div>
                <div class="form-row"><div class="form-group"><label>Department</label><select name="department"><option value="">— Select —</option><% (depts||[]).forEach(d => { %><option><%= d.name %></option><% }) %></select></div><div class="form-group"><label>Role</label><select name="role"><option value="">— Select —</option><% (roles||[]).forEach(r => { %><option><%= r.name %></option><% }) %></select></div></div>
                <div class="form-row"><div class="form-group"><label>Company Email</label><input type="email" name="email_account" placeholder="john@company.com"></div><div class="form-group"><label>Reports To</label><select name="manager_id"><option value="">— None —</option><% (allItems||[]).forEach(u => { %><option value="<%= u.id %>"><%= u.name %></option><% }) %></select></div></div>
                <div class="form-group"><label>Hire Date</label><input type="date" name="hire_date"></div>
              <% } else if (tab === 'servers') { %>
                <div class="form-row"><div class="form-group"><label>Server Name</label><input type="text" name="name" required placeholder="DC01"></div><div class="form-group"><label>Type</label><select name="type"><option>Physical</option><option>Virtual</option><option>Cloud</option></select></div></div>
                <div class="form-row"><div class="form-group"><label>IP Address</label><input type="text" name="ip" placeholder="192.168.1.10"></div><div class="form-group"><label>OS</label><input type="text" name="os" placeholder="Windows Server 2022"></div></div>
                <div class="form-group"><label>Purpose</label><input type="text" name="purpose" placeholder="Domain Controller, File Server..."></div>
                <div class="form-group"><label>Location</label><select name="location"><option>On-premises</option><option>AWS</option><option>Azure</option><option>Google Cloud</option><option>Other</option></select></div>
              <% } else if (tab === 'subscriptions') { %>
                <div class="form-row"><div class="form-group"><label>Name</label><input type="text" name="name" required placeholder="Microsoft 365"></div><div class="form-group"><label>Vendor</label><input type="text" name="vendor" placeholder="Microsoft"></div></div>
                <div class="form-row-3"><div class="form-group"><label>Seats</label><input type="number" name="seats" value="1"></div><div class="form-group"><label>Cost/Unit</label><input type="number" name="cost_per_unit" step="0.01" placeholder="22.00"></div><div class="form-group"><label>Billing</label><select name="billing_cycle"><option>Monthly</option><option>Yearly</option></select></div></div>
                <div class="form-group"><label>Renewal Date</label><input type="date" name="renewal_date"></div>
              <% } else if (tab === 'assets') { %>
                <div class="form-row"><div class="form-group"><label>Name</label><input type="text" name="name" required placeholder="example.com"></div><div class="form-group"><label>Type</label><select name="type"><option>Domain</option><option>Website</option><option>SSL Certificate</option><option>Email Account</option><option>Cloud Account</option><option>Social Media</option><option>Other</option></select></div></div>
                <div class="form-row"><div class="form-group"><label>Provider</label><input type="text" name="provider" placeholder="GoDaddy, Cloudflare..."></div><div class="form-group"><label>Expires</label><input type="date" name="expires_at"></div></div>
                <div class="form-group"><label>Login URL</label><input type="text" name="login_url" placeholder="https://..."></div>
              <% } else if (tab === 'inventory') { %>
                <div class="form-row"><div class="form-group"><label>Name *</label><input type="text" name="name" required placeholder="Dell OptiPlex 7090"></div><div class="form-group"><label>Type</label><select name="type"><option>Desktop</option><option>Laptop</option><option>Monitor</option><option>Printer</option><option>Router</option><option>Switch</option><option>Firewall</option><option>UPS</option><option>Phone</option><option>Tablet</option><option>Server</option><option>Cable</option><option>Accessory</option><option>Other</option></select></div></div>
                <div class="form-row"><div class="form-group"><label>Manufacturer</label><input type="text" name="manufacturer" placeholder="Dell, HP, Lenovo..."></div><div class="form-group"><label>Model</label><input type="text" name="model" placeholder="OptiPlex 7090, ThinkPad X1..."></div></div>
                <div class="form-row"><div class="form-group"><label>Serial Number</label><input type="text" name="serial_number"></div><div class="form-group"><label>Condition</label><select name="condition"><option>New</option><option>Good</option><option>Fair</option><option>Needs Repair</option><option>Retired</option></select></div></div>
                <div class="form-row-3"><div class="form-group"><label>Quantity</label><input type="number" name="quantity" value="1" min="1"></div><div class="form-group"><label>Unit Cost ($)</label><input type="number" name="cost" step="0.01" placeholder="0.00"></div><div class="form-group"><label>Location</label><select name="location_id"><option value="">— No Location —</option><% (locations||[]).forEach(l => { %><option value="<%= l.id %>"><%= l.name %></option><% }) %></select></div></div>
                <div class="form-row"><div class="form-group"><label>Purchase Date</label><input type="date" name="purchase_date"></div><div class="form-group"><label>Warranty Expires</label><input type="date" name="warranty_expires"></div></div>
                <div class="form-group"><label>Assigned To</label><select name="assigned_to"><option value="">— Unassigned —</option><% users.forEach(u => { %><option value="<%= u.name %>"><%= u.name %><%= u.department ? ' (' + u.department + ')' : '' %><%= u.role ? ' — ' + u.role : '' %></option><% }) %></select></div>
