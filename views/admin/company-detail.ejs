                  <div class="ic-name"><%= t.title %></div>
                  <div class="ic-sub">
                    <% if (t.assigned_to) { %>👤 <%= t.assigned_to %> · <% } %>
                    <% if (t.due_date) { %>📅 <%= t.due_date %> · <% } %>
                    <span class="badge <%= t.priority === 'urgent' ? 'overdue' : t.priority === 'high' ? 'sent' : t.priority === 'low' ? 'inactive' : 'active' %>"><%= t.priority %></span>
                    <span class="badge <%= t.status === 'in-progress' ? 'sent' : 'prospect' %>"><%= t.status %></span>
                  </div>
                  <% if (t.description) { %><div style="font-size:11px;color:#475569;margin-top:3px;"><%= t.description %></div><% } %>
                </div>
                <form method="POST" action="/admin/tasks/<%= t.id %>/delete" style="display:inline">
                  <input type="hidden" name="redirect" value="/admin/companies/<%= company.id %>?tab=tasks">
                  <button type="submit" class="btn-ghost" onclick="return confirm('Delete?')">🗑️</button>
                </form>
              </div>
            <% }) %>
          <% } %>
          <% if (doneTasks.length > 0) { %>
            <div style="font-size:12px;font-weight:700;color:var(--muted);margin:16px 0 8px;text-transform:uppercase;">Done (<%= doneTasks.length %>)</div>
            <% doneTasks.forEach(t => { %>
              <div class="item-card" style="cursor:default;opacity:0.6;">
                <div style="margin-right:10px;margin-top:2px;"><span style="color:var(--success);font-size:18px;">✅</span></div>
                <div class="ic-main"><div class="ic-name" style="text-decoration:line-through;"><%= t.title %></div></div>
                <form method="POST" action="/admin/tasks/<%= t.id %>/delete" style="display:inline">
                  <input type="hidden" name="redirect" value="/admin/companies/<%= company.id %>?tab=tasks">
                  <button type="submit" class="btn-ghost" onclick="return confirm('Delete?')">🗑️</button>
                </form>
              </div>
            <% }) %>
          <% } %>
        <% } %>

        <div class="modal-bg" id="addTaskModal" onclick="if(event.target===this)this.classList.remove('open')">
          <div class="modal">
            <h3>Add Task for <%= company.name %></h3>
            <form method="POST" action="/admin/companies/<%= company.id %>/tasks">
              <div class="form-group"><label>Title *</label><input type="text" name="title" required placeholder="What needs to be done?"></div>
              <div class="form-group"><label>Description</label><textarea name="description" placeholder="Details..."></textarea></div>
              <div class="form-row">
                <div class="form-group"><label>Priority</label><select name="priority"><option value="low">Low</option><option value="medium" selected>Medium</option><option value="high">High</option><option value="urgent">Urgent</option></select></div>
                <div class="form-group"><label>Due Date</label><input type="date" name="due_date"></div>
              </div>
              <div class="form-row">
                <div class="form-group"><label>Assigned To</label><select name="assigned_to"><option value="">— Unassigned —</option><% (allPeople || []).forEach(p => { %><option value="<%= p.name %>"><%= p.name %></option><% }) %></select></div>
                <div class="form-group"><label>Related To</label><select name="related_table"><option value="">— None —</option><option value="servers">Server</option><option value="subscriptions">Subscription</option><option value="assets">Asset</option><option value="inventory">Inventory</option></select></div>
              </div>
              <div class="form-actions"><button type="submit" class="btn btn-primary">Add Task</button><button type="button" class="btn" onclick="document.getElementById('addTaskModal').classList.remove('open')">Cancel</button></div>
            </form>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>
