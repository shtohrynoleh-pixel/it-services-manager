              <div class="ic-main">
                <div class="ic-name"><%= a.title || a.service_name || 'Agreement' %></div>
                <div class="ic-sub">
                  $<%= (a.custom_price || a.base_price || 0).toFixed(2) %>/<%= a.billing_cycle || '—' %>
