              <div style="margin-bottom:14px;">
                <p style="font-size:12px;color:var(--muted);line-height:1.6;margin-bottom:10px;">Upload a CSV file to bulk-import records. First row must be column headers.</p>
                <p style="font-size:11px;color:var(--muted);margin-bottom:8px;"><strong>Required column:</strong> <code>name</code></p>
                <p style="font-size:11px;color:var(--muted);margin-bottom:12px;"><strong>Available columns:</strong> <code><%= cfg.fields ? cfg.fields.join(', ') : '' %></code></p>
                <a href="/admin/companies/<%= company.id %>/<%= tab === 'users' ? 'users' : tab %>/csv-template" style="font-size:11px;">Download blank template</a>
              </div>
