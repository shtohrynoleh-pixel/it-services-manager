                  <form method="POST" action="/admin/invoices/<%= inv.id %>/delete" style="display:inline"><input type="hidden" name="redirect" value="/admin/companies/<%= company.id %>?tab=invoices"><button type="submit" class="btn-ghost" onclick="return confirm('Delete?')">🗑️</button></form>
