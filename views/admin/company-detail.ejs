              </div>
              <div class="form-actions">
                <button type="submit" class="btn btn-primary">Import</button>
                <button type="button" class="btn" onclick="document.getElementById('csvImportModal').classList.remove('open')">Cancel</button>
              </div>
            </form>
          </div>
        </div>

