<%- include('../partials/head') %>
<div class="app-wrap">
  <%- include('../partials/sidebar', { settings, user, page, tab: '' }) %>
  <div class="main">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px;">
        <button class="mob-toggle" onclick="openSidebar()">☰</button>
        <h2><a href="/admin/companies" style="opacity:0.4;text-decoration:none;">🏢</a> → <%= company.name %></h2>
      </div>
      <div style="display:flex;align-items:center;gap:8px;"><span class="badge <%= company.status %>"><%= company.status %></span><%- include('../partials/notif-bell') %></div>
    </div>
    <div class="content">
      <!-- Tabs -->
      <div class="tabs">
        <% ['overview','contacts','users','servers','subscriptions','assets','inventory','agreements','invoices','tasks'].forEach(t => { %>
          <a class="tab <%= tab === t ? 'active' : '' %>" href="/admin/companies/<%= company.id %>?tab=<%= t %>"><%= t.charAt(0).toUpperCase() + t.slice(1) %></a>
        <% }) %>
        <% var m = modules || {}; %>
        <% if (m.tms) { %><a class="tab" href="/admin/companies/<%= company.id %>/tms" style="color:var(--primary);"><i class="ti ti-route"></i> TMS</a><% } %>
        <% if (m.fleet) { %><a class="tab" href="/admin/companies/<%= company.id %>/fleet" style="color:var(--primary);"><i class="ti ti-truck"></i> Fleet</a><% } %>
        <% if (m.eld) { %><a class="tab" href="/admin/companies/<%= company.id %>/eld" style="color:var(--primary);"><i class="ti ti-plug-connected"></i> ELD</a><% } %>
        <% if (m.domains) { %><a class="tab" href="/admin/companies/<%= company.id %>/domains" style="color:var(--primary);"><i class="ti ti-world"></i> Domains</a><% } %>
        <% if (m.files) { %><a class="tab" href="/admin/companies/<%= company.id %>/files" style="color:var(--primary);"><i class="ti ti-folder"></i> Files</a><% } %>
        <% if (m.rdp) { %><a class="tab" href="/admin/companies/<%= company.id %>/rdp" style="color:var(--primary);"><i class="ti ti-remote"></i> RDP</a><% } %>
        <a class="tab" href="/admin/companies/<%= company.id %>/email-security" style="color:var(--primary);"><i class="ti ti-mail"></i> Email</a>
        <a class="tab" href="/admin/companies/<%= company.id %>/modules" style="color:var(--muted);font-size:10px;"><i class="ti ti-settings"></i></a>
      </div>

      <% if (tab === 'overview') { %>
        <!-- Logo -->
        <div class="card" style="display:flex;align-items:center;gap:20px;flex-wrap:wrap;">
          <% if (company.logo) { %>
            <img src="<%= company.logo %>" alt="<%= company.name %>" style="width:80px;height:80px;object-fit:contain;border-radius:12px;border:1px solid var(--border);">
          <% } else { %>
            <div style="width:80px;height:80px;border-radius:12px;background:var(--primary-light);display:flex;align-items:center;justify-content:center;font-size:32px;font-weight:900;color:var(--primary);flex-shrink:0;"><%= company.name.charAt(0).toUpperCase() %></div>
          <% } %>
          <div style="flex:1;min-width:200px;">
            <h3 style="margin-bottom:4px;"><%= company.name %></h3>
            <span class="badge <%= company.status %>"><%= company.status %></span>
          </div>
          <details style="width:100%;"><summary style="cursor:pointer;font-size:12px;font-weight:600;color:var(--primary);">🖼️ Change Logo</summary>
            <form method="POST" action="/admin/companies/<%= company.id %>/logo" style="margin-top:8px;">
              <div class="form-group"><label>Logo URL (paste image link)</label><input type="text" name="logo_url" value="<%= company.logo || '' %>" placeholder="https://example.com/logo.png"></div>
              <button type="submit" class="btn btn-sm btn-primary">Save Logo</button>
            </form>
          </details>
        </div>

        <div class="metrics">
          <%
            var emailCount = users.filter(u => u.email_account).length;
            var phoneCount = users.filter(u => u.phone).length;
            var monthlySubCost = subs.reduce((s,x) => s + ((x.billing_cycle === 'Monthly' ? (x.cost_per_unit||0) * (x.seats||1) : 0)), 0);
            var yearlySubCost = subs.reduce((s,x) => s + ((x.billing_cycle === 'Yearly' ? (x.cost_per_unit||0) * (x.seats||1) : 0)), 0);
            var openTaskCount = tasks.filter(t => t.status !== 'done').length;
          %>
          <a href="/admin/companies/<%= company.id %>?tab=users" class="metric hi" style="text-decoration:none;color:inherit;cursor:pointer;"><div class="m-label">Users</div><div class="m-val pri"><%= users.length %></div></a>
          <a href="/admin/companies/<%= company.id %>?tab=users" class="metric" style="text-decoration:none;color:inherit;cursor:pointer;"><div class="m-label">Emails</div><div class="m-val"><%= emailCount %></div></a>
          <a href="/admin/companies/<%= company.id %>?tab=users" class="metric" style="text-decoration:none;color:inherit;cursor:pointer;"><div class="m-label">Phones</div><div class="m-val"><%= phoneCount %></div></a>
          <a href="/admin/companies/<%= company.id %>?tab=servers" class="metric" style="text-decoration:none;color:inherit;cursor:pointer;"><div class="m-label">Servers</div><div class="m-val"><%= servers.length %></div></a>
        </div>
        <div class="metrics">
          <a href="/admin/companies/<%= company.id %>?tab=subscriptions" class="metric" style="text-decoration:none;color:inherit;cursor:pointer;"><div class="m-label">Subscriptions</div><div class="m-val"><%= subs.length %></div></a>
          <a href="/admin/companies/<%= company.id %>?tab=subscriptions" class="metric ok" style="text-decoration:none;color:inherit;cursor:pointer;"><div class="m-label">Monthly Sub Cost</div><div class="m-val green">$<%= monthlySubCost.toFixed(2) %></div></a>
          <a href="/admin/companies/<%= company.id %>?tab=inventory" class="metric" style="text-decoration:none;color:inherit;cursor:pointer;"><div class="m-label">Equipment</div><div class="m-val"><%= inventory.length %></div><div style="font-size:10px;color:var(--muted);margin-top:2px;">$<%= inventory.reduce((s,x) => s + ((x.cost||0) * (x.quantity||1)), 0).toFixed(2) %></div></a>
          <a href="/admin/companies/<%= company.id %>?tab=tasks" class="metric <%= openTaskCount > 0 ? '' : 'ok' %>" style="text-decoration:none;color:inherit;cursor:pointer;"><div class="m-label">Open Tasks</div><div class="m-val"><%= openTaskCount %></div></a>
        </div>
        <div class="card">
          <h3>📋 Company Info</h3>
          <div class="card-row"><span class="label">Address</span><span class="value"><%= [company.address, company.city, company.state, company.zip].filter(Boolean).join(', ') || '—' %></span></div>
          <div class="card-row"><span class="label">Created</span><span class="value"><%= company.created_at ? company.created_at.split('T')[0] : '—' %></span></div>
          <div class="card-row"><span class="label">Notes</span><span class="value"><%= company.notes || '—' %></span></div>
        </div>
        <% if (contacts.length > 0) { %>
        <div class="card">
          <h3>📞 Primary Contact</h3>
          <% const pc = contacts.find(c => c.is_primary) || contacts[0]; %>
          <div class="card-row"><span class="label">Name</span><span class="value"><%= pc.name %></span></div>
          <div class="card-row"><span class="label">Email</span><span class="value"><%= pc.email || '—' %></span></div>
          <div class="card-row"><span class="label">Phone</span><span class="value"><%= pc.phone || '—' %></span></div>
        </div>
        <% } %>
        <!-- Quick links -->
        <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px;">
          <a href="/admin/companies/<%= company.id %>/files" class="btn btn-sm">📁 Files</a>
          <a href="/admin/companies/<%= company.id %>/email-security" class="btn btn-sm">📧 Email Security</a>
          <a href="/admin/companies/<%= company.id %>/org-chart" class="btn btn-sm">🏛️ Org Chart</a>
          <a href="/admin/policies?company=<%= company.id %>" class="btn btn-sm">🛡️ Security Policies</a>
        </div>

        <!-- Client portal users -->
        <div class="card">
          <h3>🔐 Client Portal Access</h3>
          <p style="font-size:12px;color:var(--muted);margin-bottom:12px;">Grant portal access to company users so they can log in, view data, submit requests, and chat.</p>

          <% if (clientUsers.length > 0) { %>
            <table class="tbl" style="margin-bottom:14px;">
              <thead><tr><th>Username</th><th>Name</th><th>Email</th><th>Active</th><th></th></tr></thead>
              <tbody>
              <% clientUsers.forEach(cu => { %>
                <tr>
                  <td><strong><%= cu.username %></strong></td>
                  <td><%= cu.full_name || '—' %></td>
                  <td><%= cu.email || '—' %></td>
                  <td><span class="badge <%= cu.is_active ? 'active' : 'inactive' %>"><%= cu.is_active ? 'Yes' : 'No' %></span></td>
                  <td style="white-space:nowrap;">
                    <form method="POST" action="/admin/companies/<%= company.id %>/client-users/<%= cu.id %>/delete" style="display:inline;"><button type="submit" class="btn-ghost" onclick="return confirm('Remove portal access for ' + '<%= cu.username %>' + '?')">🗑️</button></form>
                  </td>
                </tr>
              <% }) %>
              </tbody>
            </table>
          <% } else { %>
            <div style="font-size:12px;color:var(--muted);margin-bottom:12px;">No portal accounts yet.</div>
          <% } %>

          <!-- Quick grant from existing company users -->
          <% var usersWithoutAccess = users.filter(u => !clientUsers.find(cu => cu.full_name === u.name || cu.username === (u.email_account || u.email || '').split('@')[0])); %>
          <% if (usersWithoutAccess.length > 0) { %>
            <details style="margin-bottom:12px;" open><summary style="cursor:pointer;font-size:12px;font-weight:700;color:var(--primary);">⚡ Quick Grant — From Existing Team Members (<%= usersWithoutAccess.length %>)</summary>
              <div style="margin-top:8px;">
                <% usersWithoutAccess.forEach(u => { %>
                  <form method="POST" action="/admin/companies/<%= company.id %>/grant-portal-access" style="display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid #f1f5f9;">
                    <input type="hidden" name="company_user_id" value="<%= u.id %>">
                    <div style="flex:1;">
                      <strong style="font-size:12px;"><%= u.name %></strong>
                      <span style="font-size:11px;color:var(--muted);"><%= u.department ? ' · ' + u.department : '' %><%= u.role ? ' · ' + u.role : '' %></span>
                      <div style="font-size:10px;color:var(--muted);"><%= u.email_account || u.email || 'No email' %></div>
                    </div>
                    <div style="display:flex;gap:4px;align-items:center;">
                      <input type="text" name="username" value="<%= (u.email_account || u.email || u.name.toLowerCase().replace(/\s+/g,'.')).split('@')[0] %>" placeholder="Username" style="width:120px;padding:4px 8px;font-size:11px;border:1px solid var(--border);border-radius:6px;" required>
                      <input type="text" name="password" placeholder="Password" style="width:100px;padding:4px 8px;font-size:11px;border:1px solid var(--border);border-radius:6px;" required>
                      <button type="submit" class="btn btn-sm btn-primary" style="white-space:nowrap;">Grant Access</button>
                    </div>
                  </form>
                <% }) %>
              </div>
            </details>
          <% } %>

          <!-- Manual add -->
          <details><summary style="cursor:pointer;font-size:12px;font-weight:600;color:var(--primary);">+ Add Portal Login Manually</summary>
            <form method="POST" action="/admin/companies/<%= company.id %>/client-users" style="margin-top:10px;">
              <div class="form-row">
                <div class="form-group"><label>Username *</label><input type="text" name="username" required></div>
                <div class="form-group"><label>Password *</label><input type="text" name="password" required></div>
              </div>
              <div class="form-row">
                <div class="form-group"><label>Full Name</label><input type="text" name="full_name"></div>
                <div class="form-group"><label>Email</label><input type="email" name="email"></div>
              </div>
              <button type="submit" class="btn btn-primary btn-sm">Create Login</button>
            </form>
          </details>
        </div>
        <div style="margin-top:20px;"><form method="POST" action="/admin/companies/<%= company.id %>/delete" onsubmit="return confirm('DELETE this company and ALL its data? This cannot be undone.')"><button type="submit" class="btn btn-danger btn-sm">🗑️ Delete Company</button></form></div>

      <% } else if (['contacts','users','servers','subscriptions','assets','inventory'].includes(tab)) { %>
        <%
          const tableMap = {
            contacts: { cols: ['Name','Role','Email','Phone'], fields: ['name','role','email','phone'], dbTable: 'contacts', groupField: 'role' },
            users: { cols: ['Name','Email','Phone','Dept','Role','Email Acct'], fields: ['name','email','phone','department','role','email_account'], dbTable: 'company_users', groupField: 'department' },
            servers: { cols: ['Name','Type','IP','OS','Purpose','Active'], fields: ['name','type','ip','os','purpose','is_active'], dbTable: 'servers', groupField: 'type' },
            subscriptions: { cols: ['Name','Vendor','Seats','Cost/Unit','Billing','Renewal'], fields: ['name','vendor','seats','cost_per_unit','billing_cycle','renewal_date'], dbTable: 'subscriptions', groupField: 'billing_cycle' },
            assets: { cols: ['Name','Type','Provider','Expires'], fields: ['name','type','provider','expires_at'], dbTable: 'assets', groupField: 'type' },
            inventory: { cols: ['Name','Type','Qty','Cost','Location','Condition','Assigned To'], fields: ['name','type','quantity','cost','location_name','condition','assigned_to'], dbTable: 'inventory', groupField: 'type', extraGroups: ['location_name','condition','assigned_to'] }
          };
          const cfg = tableMap[tab];
          const allItems = { contacts, users, servers, subscriptions: subs, assets, inventory }[tab] || [];
          // Cost summaries for subscriptions
          var monthlyCost = 0, yearlyCost = 0;
          if (tab === 'subscriptions') {
            allItems.forEach(s => { var c = (s.cost_per_unit||0) * (s.seats||1); if (s.billing_cycle === 'Monthly') monthlyCost += c; else yearlyCost += c; });
          }
        %>
        <% if (imported) { %>
          <div style="background:#d1fae5;color:#065f46;padding:8px 14px;border-radius:8px;font-size:12px;font-weight:600;margin-bottom:12px;">Successfully imported <%= imported %> records.</div>
        <% } %>
        <% if (importError) { %>
          <div style="background:#fee2e2;color:#991b1b;padding:8px 14px;border-radius:8px;font-size:12px;font-weight:600;margin-bottom:12px;">Import error: <%= importError %></div>
        <% } %>

        <div style="display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap;align-items:center;">
          <button class="btn btn-primary btn-sm" onclick="document.getElementById('addItemModal').classList.add('open')">+ Add</button>
          <input type="text" id="searchField" placeholder="🔍 Search <%= tab %>..." oninput="filterTable()" style="flex:1;min-width:150px;max-width:300px;padding:6px 12px;font-size:12px;">
          <% if (cfg.groupField) { %>
            <select id="groupByField" onchange="changeGroupBy()" style="padding:6px 12px;font-size:12px;border:1px solid var(--border);border-radius:8px;">
              <option value="<%= cfg.groupField %>"><%= cfg.groupField.charAt(0).toUpperCase() + cfg.groupField.slice(1).replace('_',' ') %></option>
              <% if (cfg.extraGroups) { cfg.extraGroups.forEach(eg => { %><option value="<%= eg %>"><%= eg.charAt(0).toUpperCase() + eg.slice(1).replace('_name','').replace('_',' ') %></option><% }) } %>
            </select>
            <select id="groupField" onchange="filterTable()" style="padding:6px 12px;font-size:12px;border:1px solid var(--border);border-radius:8px;">
              <option value="">Filter: All</option>
              <% var groupVals = [...new Set(allItems.map(x => x[cfg.groupField]).filter(Boolean))].sort(); %>
              <% groupVals.forEach(g => { %><option value="<%= g %>"><%= g %></option><% }) %>
            </select>
          <% } %>
          <div style="margin-left:auto;display:flex;gap:4px;">
            <a href="/admin/companies/<%= company.id %>/<%= tab === 'users' ? 'users' : tab %>/csv-export" class="btn btn-sm" title="Export CSV">📥 Export</a>
            <a href="/admin/companies/<%= company.id %>/<%= tab === 'users' ? 'users' : tab %>/csv-template" class="btn btn-sm" title="Download blank CSV template">📄 Template</a>
            <button class="btn btn-sm" onclick="document.getElementById('csvImportModal').classList.add('open')" title="Import from CSV">📤 Import</button>
          </div>
        </div>

        <% if (tab === 'subscriptions' && allItems.length > 0) { %>
          <div class="metrics" style="margin-bottom:14px;">
            <div class="metric ok"><div class="m-label">Monthly Cost</div><div class="m-val green">$<%= monthlyCost.toFixed(2) %></div></div>
            <div class="metric"><div class="m-label">Yearly Cost</div><div class="m-val">$<%= yearlyCost.toFixed(2) %></div></div>
            <div class="metric hi"><div class="m-label">Total Subs</div><div class="m-val pri"><%= allItems.length %></div></div>
            <div class="metric"><div class="m-label">Total Seats</div><div class="m-val"><%= allItems.reduce((s,x) => s + (x.seats||0), 0) %></div></div>
          </div>
        <% } %>

        <% if (tab === 'inventory' && allItems.length > 0) { %>
          <%
            var totalQty = allItems.reduce((s,x) => s + (x.quantity||1), 0);
            var totalValue = allItems.reduce((s,x) => s + ((x.cost||0) * (x.quantity||1)), 0);
            var goodCount = allItems.filter(x => x.condition === 'New' || x.condition === 'Good').length;
            var repairCount = allItems.filter(x => x.condition === 'Needs Repair').length;
            var assignedCount = allItems.filter(x => x.assigned_to).length;
          %>
          <div class="metrics" style="margin-bottom:14px;">
            <div class="metric hi"><div class="m-label">Total Items</div><div class="m-val pri"><%= totalQty %></div></div>
            <div class="metric ok"><div class="m-label">Total Value</div><div class="m-val green">$<%= totalValue.toLocaleString('en-US', {minimumFractionDigits:2, maximumFractionDigits:2}) %></div></div>
            <div class="metric"><div class="m-label">Good / New</div><div class="m-val"><%= goodCount %></div></div>
            <div class="metric <%= repairCount > 0 ? 'bad' : '' %>"><div class="m-label">Needs Repair</div><div class="m-val <%= repairCount > 0 ? 'red' : '' %>"><%= repairCount %></div></div>
          </div>
          <div class="metrics" style="margin-bottom:14px;">
            <div class="metric"><div class="m-label">Assigned</div><div class="m-val"><%= assignedCount %></div></div>
            <div class="metric"><div class="m-label">Unassigned</div><div class="m-val"><%= allItems.length - assignedCount %></div></div>
            <div class="metric"><div class="m-label">Locations</div><div class="m-val"><%= (locations||[]).length %></div></div>
            <div class="metric"><div class="m-label">Retired</div><div class="m-val"><%= allItems.filter(x => x.condition === 'Retired').length %></div></div>
          </div>

          <!-- Value by Type breakdown -->
          <div class="card" style="margin-bottom:14px;">
            <h3>💰 Value by Type</h3>
            <%
              var typeGroups = {};
              allItems.forEach(x => {
                var t = x.type || 'Other';
                if (!typeGroups[t]) typeGroups[t] = { count:0, qty:0, value:0 };
                typeGroups[t].count++;
                typeGroups[t].qty += (x.quantity||1);
                typeGroups[t].value += (x.cost||0) * (x.quantity||1);
              });
            %>
            <table class="tbl">
              <thead><tr><th>Type</th><th>Items</th><th>Qty</th><th style="text-align:right;">Value</th></tr></thead>
              <tbody>
              <% Object.keys(typeGroups).sort().forEach(t => { var g = typeGroups[t]; %>
                <tr><td><strong><%= t %></strong></td><td><%= g.count %></td><td><%= g.qty %></td><td style="text-align:right;font-weight:700;color:var(--success);">$<%= g.value.toFixed(2) %></td></tr>
              <% }) %>
              <tr style="border-top:2px solid var(--border);font-weight:800;"><td>Total</td><td><%= allItems.length %></td><td><%= totalQty %></td><td style="text-align:right;color:var(--primary);">$<%= totalValue.toFixed(2) %></td></tr>
              </tbody>
            </table>
          </div>

          <!-- Locations panel -->
          <% if ((locations||[]).length > 0) { %>
          <div class="card" style="margin-bottom:14px;">
            <h3>📍 By Location</h3>
            <%
              var locGroups = {};
              allItems.forEach(x => {
                var ln = x.location_name || 'No Location';
                if (!locGroups[ln]) locGroups[ln] = { count:0, value:0 };
                locGroups[ln].count++;
                locGroups[ln].value += (x.cost||0) * (x.quantity||1);
              });
            %>
            <table class="tbl">
              <thead><tr><th>Location</th><th>Items</th><th style="text-align:right;">Value</th></tr></thead>
              <tbody>
              <% Object.keys(locGroups).sort().forEach(l => { var g = locGroups[l]; %>
                <tr><td><%= l %></td><td><%= g.count %></td><td style="text-align:right;font-weight:600;">$<%= g.value.toFixed(2) %></td></tr>
              <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>

        <% } %>

        <% if (tab === 'inventory') { %>
          <!-- Manage Locations — always visible on inventory tab -->
          <details class="card" style="margin-bottom:14px;" <%= (locations||[]).length === 0 ? 'open' : '' %>>
            <summary style="cursor:pointer;font-weight:700;font-size:14px;">📍 Manage Locations (<%= (locations||[]).length %>)</summary>
            <div style="margin-top:12px;">
              <% if ((locations||[]).length === 0) { %>
                <div style="padding:12px;text-align:center;color:var(--muted);font-size:12px;margin-bottom:12px;">No locations yet. Add your first one below — offices, warehouses, data centers, etc.</div>
              <% } else { %>
                <% (locations||[]).forEach(loc => { %>
                  <div style="display:flex;align-items:center;gap:8px;padding:8px 0;border-bottom:1px solid #f1f5f9;">
                    <div style="width:32px;height:32px;border-radius:8px;background:var(--primary-light);color:var(--primary);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;"><%= loc.type === 'Warehouse' ? '🏭' : loc.type === 'Data Center' ? '🖥️' : loc.type === 'Remote' ? '🌐' : loc.type === 'Storage' ? '📦' : '🏢' %></div>
                    <div style="flex:1;">
                      <strong><%= loc.name %></strong>
                      <span style="font-size:11px;color:var(--muted);"> — <%= loc.type || 'Office' %></span>
                      <% if (loc.address) { %><div style="font-size:11px;color:var(--muted);"><%= loc.address %></div><% } %>
                      <% var locItemCount = allItems.filter(x => x.location_id === loc.id).length; %>
                      <% if (locItemCount > 0) { %><div style="font-size:10px;color:var(--primary);font-weight:600;"><%= locItemCount %> item<%= locItemCount > 1 ? 's' : '' %></div><% } %>
                    </div>
                    <form method="POST" action="/admin/companies/<%= company.id %>/locations/<%= loc.id %>/delete" onsubmit="return confirm('Delete this location? Items will be set to No Location.')" style="display:inline;"><button type="submit" class="btn-ghost" title="Delete">🗑️</button></form>
                  </div>
                <% }) %>
              <% } %>
              <form method="POST" action="/admin/companies/<%= company.id %>/locations" style="margin-top:12px;padding-top:12px;border-top:1px solid var(--border);">
                <div style="font-size:12px;font-weight:700;margin-bottom:8px;">+ Add New Location</div>
                <div class="form-row">
                  <div class="form-group"><label>Name *</label><input type="text" name="name" required placeholder="Main Office, Warehouse A..."></div>
