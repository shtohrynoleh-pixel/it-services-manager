                  <% if (a.sla_response) { %> · SLA: <%= a.sla_response %><% } %>
                  <% if (a.attachment_name) { %> · <i class="ti ti-paperclip" style="font-size:11px;"></i> <%= a.attachment_name %><% } %>
                </div>
              </div>
              <div class="ic-right">
                <span class="badge <%= a.is_active ? 'active' : 'inactive' %>"><%= a.is_active ? 'Active' : 'Inactive' %></span>
              </div>
            </a>
          <% }) %>
        <% } %>
        <div class="modal-bg" id="addAgrModal" onclick="if(event.target===this)this.classList.remove('open')">
          <div class="modal">
            <h3>Add Service Agreement</h3>
