<%- include('../partials/head') %>
<style>
.flow-canvas{display:flex;flex-direction:column;align-items:center;gap:0;padding:20px 10px;}
.flow-node{position:relative;text-align:center;padding:10px 20px;font-size:12px;font-weight:700;color:#fff;min-width:160px;max-width:280px;word-wrap:break-word;line-height:1.4;box-shadow:0 2px 8px rgba(0,0,0,0.1);}
.flow-node.start{background:#10b981;border-radius:24px;padding:12px 24px;}
.flow-node.process{background:#0891b2;border-radius:10px;}
.flow-node.decision{background:#f59e0b;color:#78350f;border-radius:4px;padding:16px 24px;clip-path:polygon(50% 0%,100% 50%,50% 100%,0% 50%);min-height:80px;display:flex;flex-direction:column;align-items:center;justify-content:center;min-width:180px;}
.flow-node.end{background:#ef4444;border-radius:24px;padding:12px 24px;}
.flow-node .fn-type{font-size:8px;opacity:0.7;text-transform:uppercase;letter-spacing:0.5px;display:block;margin-bottom:2px;}
.flow-node .fn-who{font-size:9px;opacity:0.8;margin-top:3px;}
.flow-arrow{width:2px;height:24px;background:#334155;position:relative;margin:0 auto;}
.flow-arrow::after{content:"";position:absolute;bottom:-3px;left:50%;transform:translateX(-50%);border-left:5px solid transparent;border-right:5px solid transparent;border-top:6px solid #334155;}
.flow-desc{font-size:10px;font-weight:400;color:rgba(255,255,255,0.85);margin-top:3px;max-width:200px;}
.flow-decision .fn-desc{max-width:100px;font-size:9px;}
.flow-branch{display:flex;gap:16px;font-size:10px;font-weight:700;color:#64748b;margin:4px 0;}
.flow-branch span{padding:2px 8px;border-radius:4px;}
.flow-branch .yes{background:#d1fae5;color:#065f46;}
.flow-branch .no{background:#fee2e2;color:#991b1b;}
</style>
<div class="app-wrap">
  <%- include('../partials/sidebar', { settings, user, page, tab: '' }) %>
  <div class="main">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px;"><button class="mob-toggle" onclick="openSidebar()">☰</button><h2><a href="/admin/flows" style="opacity:0.4;text-decoration:none;">🔄</a> → <%= flow.title %></h2></div>
      <div style="display:flex;align-items:center;gap:8px;">
        <span class="badge <%= flow.status === 'published' ? 'paid' : 'draft' %>"><%= flow.status %></span>
        <% if (flow.is_template) { %><span class="badge prospect">Template</span><% } %>
        <%- include('../partials/notif-bell') %>
      </div>
    </div>
    <div class="content">
      <!-- Flow Info -->
      <div class="card">
        <h3>🔄 Flow Details</h3>
        <details>
          <summary style="cursor:pointer;font-size:12px;font-weight:600;color:var(--primary);">Edit Details</summary>
          <form method="POST" action="/admin/flows/<%= flow.id %>/edit" style="margin-top:8px;">
            <div class="form-group"><label>Title</label><input type="text" name="title" value="<%= flow.title %>" required></div>
            <div class="form-group"><label>Description</label><textarea name="description" rows="2"><%= flow.description || '' %></textarea></div>
            <div class="form-group"><label>Trigger Event</label><input type="text" name="trigger_event" value="<%= flow.trigger_event || '' %>"></div>
            <div class="form-row">
              <div class="form-group"><label>Category</label><select name="category"><% ['IT Operations','HR-IT','Security','Incident','Change Management','Onboarding','Other'].forEach(c => { %><option <%= flow.category === c ? 'selected' : '' %>><%= c %></option><% }) %></select></div>
              <div class="form-group"><label>Company</label><select name="company_id"><option value="">— Template —</option><% companies.forEach(c => { %><option value="<%= c.id %>" <%= flow.company_id === c.id ? 'selected' : '' %>><%= c.name %></option><% }) %></select></div>
            </div>
            <div class="form-row">
              <div class="form-group"><label>Owner</label><input type="text" name="owner" value="<%= flow.owner || '' %>"></div>
              <div class="form-group"><label>Status</label><select name="status"><% ['draft','published','archived'].forEach(s => { %><option value="<%= s %>" <%= flow.status === s ? 'selected' : '' %>><%= s %></option><% }) %></select></div>
            </div>
            <button type="submit" class="btn btn-sm btn-primary">Save</button>
          </form>
        </details>
        <% if (flow.trigger_event) { %><div style="margin-top:8px;padding:8px 12px;background:var(--accent-light);border-radius:8px;font-size:12px;color:#92400e;">⚡ Trigger: <strong><%= flow.trigger_event %></strong></div><% } %>
      </div>

      <!-- Clone -->
      <div class="card">
        <h3>📦 Clone to Company</h3>
        <form method="POST" action="/admin/flows/<%= flow.id %>/clone" style="display:flex;gap:8px;align-items:flex-end;">
          <div class="form-group" style="flex:1;margin:0;"><select name="company_id"><option value="">— As template —</option><% companies.forEach(c => { %><option value="<%= c.id %>"><%= c.name %></option><% }) %></select></div>
          <button type="submit" class="btn btn-sm btn-primary">Clone</button>
        </form>
      </div>

      <!-- Visual Flowchart -->
      <div class="card">
        <h3>📊 Flowchart (<%= nodes.length %> nodes)</h3>
        <% if (nodes.length === 0) { %>
          <div style="font-size:12px;color:var(--muted);">No nodes yet — add the first node below.</div>
        <% } else { %>
          <div class="flow-canvas">
            <% nodes.forEach((nd, i) => { %>
              <% if (i > 0) { %>
                <div class="flow-arrow"></div>
                <% const prev = nodes[i-1]; if (prev.type === 'decision') { %>
                  <div class="flow-branch"><span class="yes">✓ <%= prev.yes_label || 'Yes' %></span><span class="no">✗ <%= prev.no_label || 'No' %></span></div>
                <% } %>
              <% } %>
              <div class="flow-node <%= nd.type %>">
                <span class="fn-type"><%= nd.type %></span>
                <%= nd.label %>
                <% if (nd.description) { %><div class="flow-desc"><%= nd.description %></div><% } %>
                <% if (nd.responsible) { %><div class="fn-who">👤 <%= nd.responsible %></div><% } %>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>

      <!-- Node List (editable) -->
      <div class="card">
        <h3>📝 Nodes</h3>
        <% nodes.forEach((nd, i) => { %>
          <div class="item-card" style="cursor:default;">
            <div style="display:flex;align-items:center;gap:8px;flex:1;min-width:0;">
              <div style="width:28px;height:28px;border-radius:6px;background:<%= nd.type === 'start' ? '#10b981' : nd.type === 'end' ? '#ef4444' : nd.type === 'decision' ? '#f59e0b' : '#0891b2' %>;color:#fff;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;flex-shrink:0;"><%= i+1 %></div>
              <div><div class="ic-name"><%= nd.label %></div><div class="ic-sub"><%= nd.type %><% if (nd.responsible) { %> · 👤 <%= nd.responsible %><% } %><% if (nd.type === 'decision') { %> · ✓ <%= nd.yes_label || 'Yes' %> / ✗ <%= nd.no_label || 'No' %><% } %></div></div>
            </div>
            <form method="POST" action="/admin/flows/<%= flow.id %>/nodes/<%= nd.id %>/delete" style="flex-shrink:0;"><button type="submit" class="btn-ghost" onclick="return confirm('Delete node?')">🗑️</button></form>
          </div>
        <% }) %>

        <details style="margin-top:12px;">
          <summary style="cursor:pointer;font-size:12px;font-weight:600;color:var(--primary);">+ Add Node</summary>
          <form method="POST" action="/admin/flows/<%= flow.id %>/nodes" style="margin-top:8px;">
            <div class="form-row">
              <div class="form-group"><label>Type *</label><select name="type"><option value="start">🟢 Start</option><option value="process" selected>🔷 Process</option><option value="decision">🔶 Decision</option><option value="end">🔴 End</option></select></div>
              <div class="form-group"><label>Label *</label><input type="text" name="label" required placeholder="What happens at this step"></div>
            </div>
            <div class="form-group"><label>Description</label><textarea name="description" placeholder="Details about this step..."></textarea></div>
            <div class="form-row">
              <div class="form-group"><label>Responsible</label><input type="text" name="responsible" placeholder="Who does this (e.g. IT, HR, Employee)"></div>
              <div class="form-group"><label>Yes Label (for decisions)</label><input type="text" name="yes_label" placeholder="e.g. Approved, Yes, Fix found"></div>
            </div>
            <div class="form-group"><label>No Label (for decisions)</label><input type="text" name="no_label" placeholder="e.g. Rejected, No, Escalate"></div>
            <button type="submit" class="btn btn-sm btn-primary">Add Node</button>
          </form>
        </details>
      </div>

      <div style="margin-top:16px;"><form method="POST" action="/admin/flows/<%= flow.id %>/delete" onsubmit="return confirm('Delete this flow and all nodes?')"><button type="submit" class="btn btn-sm btn-danger">🗑️ Delete Flow</button></form></div>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>
