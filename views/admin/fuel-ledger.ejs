<%- include('../partials/head') %>
<div class="app-wrap">
  <%- include('../partials/sidebar', { settings, user, page, tab: '' }) %>
  <div class="main">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px;"><button class="mob-toggle" onclick="openSidebar()">☰</button><h2><a href="/admin/companies/<%= company.id %>/fuel" style="opacity:0.4;text-decoration:none;"><i class="ti ti-gas-station"></i></a> → <i class="ti ti-file-invoice"></i> Payout Ledger</h2></div>
      <%- include('../partials/notif-bell') %>
    </div>
    <div class="content">
      <!-- Period selector -->
      <div style="display:flex;gap:8px;margin-bottom:14px;align-items:center;flex-wrap:wrap;">
        <select onchange="location.href='/admin/companies/<%= company.id %>/fuel/ledger?period='+this.value" style="padding:6px 12px;font-size:12px;border:1px solid var(--border);border-radius:8px;">
          <% periods.forEach(p => { %><option value="<%= p.id %>" <%= period && period.id === p.id ? 'selected' : '' %>><%= p.period_start %> → <%= p.period_end %> (<%= p.status %>)</option><% }) %>
        </select>
        <% if (period) { %>
          <span style="padding:3px 10px;border-radius:6px;font-size:10px;font-weight:800;text-transform:uppercase;background:<%= period.status==='approved'?'#d1fae5':period.status==='calculated'?'#fef3c7':'#dbeafe' %>;color:<%= period.status==='approved'?'#065f46':period.status==='calculated'?'#92400e':'#1e40af' %>;"><%= period.status %></span>
          <% if (period.status !== 'open') { %><a href="/admin/companies/<%= company.id %>/fuel/ledger/export?period=<%= period.id %>" class="btn btn-sm"><i class="ti ti-download"></i> Export CSV</a><% } %>
        <% } %>
      </div>

      <% if (period && ledgers.length > 0) { %>
        <!-- Summary -->
        <div class="metrics" style="margin-bottom:14px;">
          <div class="metric hi"><div class="m-label">Eligible</div><div class="m-val pri"><%= ledgers.filter(l => l.status === 'eligible').length %>/<%= ledgers.length %></div></div>
          <div class="metric ok"><div class="m-label">Total Payout</div><div class="m-val green">$<%= ledgers.reduce((s,l) => s + (l.driver_payout||0), 0).toFixed(2) %></div></div>
          <div class="metric"><div class="m-label">Total Savings</div><div class="m-val">$<%= ledgers.reduce((s,l) => s + (l.savings_usd||0), 0).toFixed(2) %></div></div>
          <div class="metric"><div class="m-label">Avg MPG</div><div class="m-val"><%= ledgers.filter(l => l.actual_mpg > 0).length > 0 ? (ledgers.filter(l => l.actual_mpg > 0).reduce((s,l) => s + l.actual_mpg, 0) / ledgers.filter(l => l.actual_mpg > 0).length).toFixed(2) : '—' %></div></div>
        </div>

        <!-- Ledger table -->
        <div class="card" style="overflow-x:auto;">
          <table class="tbl">
            <thead><tr><th>Driver</th><th>Group</th><th>Status</th><th>Miles</th><th>MPG</th><th>Baseline</th><th>Target</th><th>Gal Saved</th><th>Savings $</th><th>Driver $</th><th>KPI $</th><th style="font-weight:900;">Payout</th><th></th></tr></thead>
            <tbody>
            <% ledgers.forEach(l => { %>
              <tr style="<%= l.status === 'ineligible' ? 'opacity:0.4;' : '' %>">
                <td><strong><%= l.driver_name %></strong></td>
                <td style="font-size:10px;"><%= l.group_name || '—' %></td>
                <td><span class="badge <%= l.status==='eligible'?'active':'inactive' %>" style="font-size:8px;"><%= l.status %></span></td>
                <td><%= l.total_miles ? Math.round(l.total_miles).toLocaleString() : '—' %></td>
                <td style="font-weight:700;color:<%= l.actual_mpg > l.baseline_mpg ? 'var(--success)' : l.actual_mpg > 0 ? 'var(--danger)' : 'var(--muted)' %>;"><%= l.actual_mpg || '—' %></td>
                <td style="color:var(--muted);"><%= l.baseline_mpg || '—' %></td>
                <td><%= l.target_mpg || '—' %> <span style="font-size:8px;color:var(--muted);"><%= l.target_source === 'driver_override' ? 'OVR' : l.target_source === 'group_policy' ? 'GRP' : '' %></span></td>
                <td><%= l.savings_gallons ? l.savings_gallons.toFixed(1) : '—' %></td>
                <td>$<%= (l.savings_usd||0).toFixed(2) %></td>
                <td>$<%= (l.driver_share_usd||0).toFixed(2) %></td>
                <td><%= l.kpi_earned ? '$' + (l.kpi_bonus_usd||0).toFixed(2) : '—' %></td>
                <td style="font-weight:900;font-size:14px;color:var(--primary);">$<%= (l.driver_payout||0).toFixed(2) %></td>
                <td><button class="btn-ghost" onclick="document.getElementById('explain-<%= l.id %>').classList.add('open')" title="Details"><i class="ti ti-info-circle"></i></button></td>
              </tr>
              <!-- Explanation modal -->
              <div class="modal-bg" id="explain-<%= l.id %>" onclick="if(event.target===this)this.classList.remove('open')">
                <div class="modal" style="max-width:520px;">
                  <h3><%= l.driver_name %> — Calculation</h3>
                  <% try { var exp = JSON.parse(l.explanation_json || '[]'); exp.forEach(line => { %>
                    <div style="padding:3px 0;font-size:11px;border-bottom:1px solid #f8fafc;<%= line.includes('INELIGIBLE') ? 'color:var(--danger);font-weight:700;' : line.includes('DRIVER PAYOUT') ? 'color:var(--primary);font-weight:900;font-size:13px;' : line.includes('EARNED') ? 'color:var(--success);font-weight:700;' : '' %>"><%= line %></div>
                  <% }); } catch(e) {} %>
                  <div class="form-actions"><button type="button" class="btn" onclick="document.getElementById('explain-<%= l.id %>').classList.remove('open')">Close</button></div>
                </div>
              </div>
            <% }) %>
            </tbody>
            <tfoot>
              <tr style="font-weight:900;border-top:2px solid var(--border);">
                <td colspan="7">TOTAL</td>
                <td><%= ledgers.reduce((s,l) => s + (l.savings_gallons||0), 0).toFixed(1) %></td>
                <td>$<%= ledgers.reduce((s,l) => s + (l.savings_usd||0), 0).toFixed(2) %></td>
                <td>$<%= ledgers.reduce((s,l) => s + (l.driver_share_usd||0), 0).toFixed(2) %></td>
                <td>$<%= ledgers.reduce((s,l) => s + (l.kpi_earned ? l.kpi_bonus_usd||0 : 0), 0).toFixed(2) %></td>
                <td style="font-size:16px;color:var(--primary);">$<%= ledgers.reduce((s,l) => s + (l.driver_payout||0), 0).toFixed(2) %></td>
                <td></td>
              </tr>
            </tfoot>
          </table>
        </div>

        <% if (period.status === 'approved' || period.status === 'closed') { %>
          <div style="margin-top:12px;padding:10px;background:#d1fae5;border-radius:8px;font-size:11px;color:#065f46;"><i class="ti ti-lock"></i> This period is <strong><%= period.status %></strong>. Ledger rows are immutable.</div>
        <% } %>
      <% } else { %>
        <div class="empty"><span class="e-icon"><i class="ti ti-file-invoice" style="font-size:40px;"></i></span><div class="e-text"><%= period ? 'No ledger data — run calculation first' : 'Select or create a period' %></div></div>
      <% } %>

      <div style="margin-top:16px;display:flex;gap:8px;">
        <a href="/admin/companies/<%= company.id %>/fuel/periods" class="btn btn-sm">← Periods</a>
        <a href="/admin/companies/<%= company.id %>/fuel" class="btn btn-sm">← Fuel</a>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>
