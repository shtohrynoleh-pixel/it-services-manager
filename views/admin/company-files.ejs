<%- include('../partials/head') %>
<style>
.file-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:10px;margin-bottom:16px;}
.file-item{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:14px;text-align:center;cursor:pointer;transition:all 0.15s;position:relative;}
.file-item:hover{border-color:var(--primary);box-shadow:0 2px 12px rgba(8,145,178,0.08);transform:translateY(-1px);}
.file-item .fi-icon{font-size:32px;margin-bottom:6px;}
.file-item .fi-name{font-size:11px;font-weight:700;word-break:break-word;line-height:1.3;}
.file-item .fi-sub{font-size:9px;color:var(--muted);margin-top:3px;}
.file-item .fi-actions{position:absolute;top:4px;right:4px;display:none;gap:2px;}
.file-item:hover .fi-actions{display:flex;}
.fi-btn{background:var(--card);border:1px solid var(--border);border-radius:4px;width:22px;height:22px;display:flex;align-items:center;justify-content:center;font-size:10px;cursor:pointer;text-decoration:none;color:var(--muted);}
.fi-btn:hover{background:var(--bg);color:var(--primary);}
/* List view */
.file-list .fl-row{display:flex;align-items:center;gap:10px;padding:8px 12px;border-bottom:1px solid #f1f5f9;cursor:pointer;transition:background 0.1s;}
.file-list .fl-row:hover{background:#f0f9ff;}
.fl-icon{font-size:20px;width:28px;text-align:center;flex-shrink:0;}
.fl-name{flex:1;font-size:12px;font-weight:600;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.fl-size{font-size:11px;color:var(--muted);width:70px;text-align:right;flex-shrink:0;}
.fl-date{font-size:10px;color:var(--muted);width:80px;flex-shrink:0;}
.fl-by{font-size:10px;color:var(--muted);width:80px;flex-shrink:0;}
.fl-actions{display:flex;gap:4px;flex-shrink:0;}
/* Storage bar */
.storage-bar{height:8px;background:#e2e8f0;border-radius:4px;overflow:hidden;margin-top:4px;}
.storage-fill{height:100%;border-radius:4px;transition:width 0.3s;}
/* View toggle */
.view-toggle{display:flex;border:1px solid var(--border);border-radius:6px;overflow:hidden;}
.view-toggle button{background:var(--card);border:none;padding:5px 10px;font-size:12px;cursor:pointer;color:var(--muted);}
.view-toggle button.active{background:var(--primary);color:#fff;}
.breadcrumb{display:flex;align-items:center;gap:4px;font-size:12px;margin-bottom:14px;flex-wrap:wrap;}
.breadcrumb a{font-weight:600;}
.breadcrumb span{color:var(--muted);}
.access-list{display:flex;flex-wrap:wrap;gap:6px;margin-top:6px;}
.access-tag{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;background:var(--primary-light);color:var(--primary-dark);border-radius:6px;font-size:10px;font-weight:600;}
</style>
<div class="app-wrap">
  <%- include('../partials/sidebar', { settings, user, page, tab: '' }) %>
  <div class="main">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px;">
        <button class="mob-toggle" onclick="openSidebar()">☰</button>
        <h2><a href="/admin/companies/<%= company.id %>" style="opacity:0.4;text-decoration:none;">🏢</a> → 📁 Files — <%= company.name %></h2>
      </div>
      <%- include('../partials/notif-bell') %>
    </div>
    <div class="content">
      <!-- Storage + Stats -->
      <%
        var quotaMB = (company.storage_quota || 500);
        var usedMB = (totalSize / 1048576).toFixed(1);
        var barColor = usedPct >= 90 ? 'var(--danger)' : usedPct >= 70 ? 'var(--accent)' : 'var(--success)';
      %>
      <div class="card" style="margin-bottom:14px;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
          <div style="font-size:12px;font-weight:700;">Storage: <%= usedMB %> MB / <%= quotaMB %> MB (<%= usedPct %>%)</div>
          <div style="font-size:12px;color:var(--muted);"><%= totalFiles %> files · <%= totalFolders %> folders</div>
        </div>
        <div class="storage-bar"><div class="storage-fill" style="width:<%= Math.min(usedPct,100) %>%;background:<%= barColor %>;"></div></div>
        <details style="margin-top:8px;"><summary style="font-size:11px;color:var(--primary);cursor:pointer;font-weight:600;">Change storage quota</summary>
          <form method="POST" action="/admin/companies/<%= company.id %>/storage-quota" style="display:flex;gap:8px;align-items:flex-end;margin-top:6px;">
            <div class="form-group" style="margin-bottom:0;"><label style="font-size:10px;">Quota (MB)</label><input type="number" name="storage_quota" value="<%= quotaMB %>" min="10" style="width:100px;"></div>
            <button type="submit" class="btn btn-sm btn-primary">Save</button>
          </form>
        </details>
      </div>

      <!-- Breadcrumb -->
      <div class="breadcrumb">
        <a href="/admin/companies/<%= company.id %>/files">📁 Root</a>
        <% breadcrumbs.forEach(b => { %>
          <span>›</span>
          <a href="/admin/companies/<%= company.id %>/files?folder=<%= b.id %>"><%= b.name %></a>
        <% }) %>
      </div>

      <!-- Toolbar -->
      <div style="display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap;align-items:center;">
        <button class="btn btn-primary btn-sm" onclick="document.getElementById('uploadModal').classList.add('open')">📤 Upload</button>
        <button class="btn btn-sm" onclick="document.getElementById('folderModal').classList.add('open')">📁 New Folder</button>
        <% if (currentFolder) { %><button class="btn btn-sm" onclick="document.getElementById('accessModal').classList.add('open')">👥 Access</button><% } %>
        <input type="text" id="fileSearch" placeholder="Search..." oninput="filterFiles()" style="flex:1;min-width:120px;max-width:250px;padding:6px 12px;font-size:12px;">
        <div class="view-toggle">
          <button id="btnGrid" class="active" onclick="setView('grid')">▦</button>
          <button id="btnList" onclick="setView('list')">☰</button>
        </div>
      </div>

      <% if (currentFolder && folderAccess.length > 0) { %>
        <div class="access-list" style="margin-bottom:12px;">
          <% folderAccess.forEach(a => { %><span class="access-tag">👤 <%= a.user_name %> (<%= a.permission %>)<form method="POST" action="/admin/companies/<%= company.id %>/folders/<%= folderId %>/access/<%= a.id %>/delete" style="display:inline;"><button type="submit" style="background:none;border:none;cursor:pointer;color:var(--muted);font-size:10px;">✕</button></form></span><% }) %>
        </div>
      <% } %>

      <%
        function fIcon(name) {
          var ext = (name || '').split('.').pop().toLowerCase();
          if (['pdf'].includes(ext)) return '📕';
          if (['doc','docx'].includes(ext)) return '📘';
          if (['xls','xlsx','csv'].includes(ext)) return '📗';
          if (['ppt','pptx'].includes(ext)) return '📙';
          if (['jpg','jpeg','png','gif','svg','webp'].includes(ext)) return '🖼️';
          if (['zip','rar','7z','tar','gz'].includes(ext)) return '📦';
          if (['txt','log','md'].includes(ext)) return '📄';
          if (['mp4','avi','mov'].includes(ext)) return '🎬';
          return '📎';
        }
        function fSize(s) {
          if (s > 1048576) return (s/1048576).toFixed(1)+' MB';
          if (s > 1024) return (s/1024).toFixed(0)+' KB';
          return s+' B';
        }
      %>

      <% if (folders.length === 0 && files.length === 0 && !currentFolder) { %>
        <div class="empty"><span class="e-icon">📁</span><div class="e-text">No files or folders yet</div><button class="btn btn-primary btn-sm" onclick="document.getElementById('uploadModal').classList.add('open')">📤 Upload First File</button></div>
      <% } else { %>

        <!-- GRID VIEW -->
        <div id="viewGrid" class="file-grid">
          <% if (currentFolder) { %>
            <a href="/admin/companies/<%= company.id %>/files<%= currentFolder.parent_id ? '?folder=' + currentFolder.parent_id : '' %>" class="file-item" style="text-decoration:none;color:inherit;"><div class="fi-icon">⬆️</div><div class="fi-name">..</div></a>
          <% } %>
          <% folders.forEach(f => { %>
            <div class="file-item" data-search="<%= f.name.toLowerCase() %>" onclick="location.href='/admin/companies/<%= company.id %>/files?folder=<%= f.id %>'">
              <div class="fi-actions">
                <form method="POST" action="/admin/companies/<%= company.id %>/folders/<%= f.id %>/delete" onclick="event.stopPropagation()"><input type="hidden" name="parent_id" value="<%= folderId || '' %>"><button type="submit" class="fi-btn" onclick="return confirm('Delete folder?')" title="Delete">🗑️</button></form>
              </div>
              <div class="fi-icon">📁</div><div class="fi-name"><%= f.name %></div><div class="fi-sub"><%= f.created_by || '' %></div>
            </div>
          <% }) %>
          <% files.forEach(f => { %>
            <div class="file-item" data-search="<%= f.original_name.toLowerCase() %>" onclick="location.href='/admin/companies/<%= company.id %>/files/<%= f.id %>/download'">
              <div class="fi-actions">
                <button class="fi-btn" onclick="event.stopPropagation();openMoveModal(<%= f.id %>,'<%= f.original_name.replace(/'/g,"\\'") %>')" title="Move">📂</button>
                <a href="/admin/companies/<%= company.id %>/files/<%= f.id %>/download" class="fi-btn" onclick="event.stopPropagation()" title="Download">📥</a>
                <form method="POST" action="/admin/companies/<%= company.id %>/files/<%= f.id %>/delete" onclick="event.stopPropagation()" style="display:inline;"><input type="hidden" name="folder_id" value="<%= folderId || '' %>"><button type="submit" class="fi-btn" onclick="return confirm('Delete?')" title="Delete" style="color:var(--danger);">🗑️</button></form>
              </div>
              <div class="fi-icon"><%= fIcon(f.original_name) %></div><div class="fi-name"><%= f.original_name %></div><div class="fi-sub"><%= fSize(f.size) %></div>
            </div>
          <% }) %>
        </div>

        <!-- LIST VIEW -->
        <div id="viewList" class="file-list" style="display:none;background:var(--card);border:1px solid var(--border);border-radius:10px;overflow:hidden;">
          <div style="display:flex;padding:8px 12px;font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;border-bottom:2px solid var(--border);background:var(--bg);">
            <div style="width:28px;"></div><div style="flex:1;padding-left:10px;">Name</div><div style="width:70px;text-align:right;">Size</div><div style="width:80px;">Uploaded</div><div style="width:80px;">By</div><div style="width:90px;"></div>
          </div>
          <% if (currentFolder) { %>
            <a href="/admin/companies/<%= company.id %>/files<%= currentFolder.parent_id ? '?folder=' + currentFolder.parent_id : '' %>" class="fl-row" style="text-decoration:none;color:inherit;">
              <div class="fl-icon">⬆️</div><div class="fl-name">..</div><div class="fl-size"></div><div class="fl-date"></div><div class="fl-by"></div><div class="fl-actions"></div>
            </a>
          <% } %>
          <% folders.forEach(f => { %>
            <div class="fl-row" data-search="<%= f.name.toLowerCase() %>" onclick="location.href='/admin/companies/<%= company.id %>/files?folder=<%= f.id %>'">
              <div class="fl-icon">📁</div><div class="fl-name"><%= f.name %></div><div class="fl-size">—</div><div class="fl-date"><%= f.created_at ? f.created_at.split('T')[0] : '' %></div><div class="fl-by"><%= f.created_by || '' %></div>
              <div class="fl-actions">
                <form method="POST" action="/admin/companies/<%= company.id %>/folders/<%= f.id %>/delete" onclick="event.stopPropagation()"><input type="hidden" name="parent_id" value="<%= folderId || '' %>"><button type="submit" class="fi-btn" onclick="return confirm('Delete folder?')">🗑️</button></form>
              </div>
            </div>
          <% }) %>
          <% files.forEach(f => { %>
            <div class="fl-row" data-search="<%= f.original_name.toLowerCase() %>" onclick="location.href='/admin/companies/<%= company.id %>/files/<%= f.id %>/download'">
              <div class="fl-icon"><%= fIcon(f.original_name) %></div><div class="fl-name"><%= f.original_name %></div><div class="fl-size"><%= fSize(f.size) %></div><div class="fl-date"><%= f.created_at ? f.created_at.split('T')[0] : '' %></div><div class="fl-by"><%= f.uploaded_by || '' %></div>
              <div class="fl-actions">
                <button class="fi-btn" onclick="event.stopPropagation();openMoveModal(<%= f.id %>,'<%= f.original_name.replace(/'/g,"\\'") %>')" title="Move">📂</button>
                <a href="/admin/companies/<%= company.id %>/files/<%= f.id %>/download" class="fi-btn" onclick="event.stopPropagation()">📥</a>
                <form method="POST" action="/admin/companies/<%= company.id %>/files/<%= f.id %>/delete" onclick="event.stopPropagation()" style="display:inline;"><input type="hidden" name="folder_id" value="<%= folderId || '' %>"><button type="submit" class="fi-btn" onclick="return confirm('Delete?')" style="color:var(--danger);">🗑️</button></form>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>

      <!-- Upload Modal -->
      <div class="modal-bg" id="uploadModal" onclick="if(event.target===this)this.classList.remove('open')">
        <div class="modal">
          <h3>📤 Upload File</h3>
          <% if (usedPct >= 100) { %>
            <div style="background:var(--danger-light);color:#991b1b;padding:12px;border-radius:8px;margin-bottom:12px;font-size:12px;font-weight:600;">Storage full! Ask your admin to increase the quota.</div>
          <% } %>
          <form method="POST" action="/admin/companies/<%= company.id %>/files/upload" enctype="multipart/form-data">
            <input type="hidden" name="folder_id" value="<%= folderId || '' %>">
            <div class="form-group"><label>File (max 50MB)</label><input type="file" name="file" required style="padding:8px;"></div>
            <% if (currentFolder) { %><div style="font-size:11px;color:var(--muted);margin-bottom:8px;">Uploading to: <strong><%= breadcrumbs.map(b => b.name).join(' / ') %></strong></div><% } %>
            <div class="form-actions"><button type="submit" class="btn btn-primary" <%= usedPct >= 100 ? 'disabled' : '' %>>Upload</button><button type="button" class="btn" onclick="document.getElementById('uploadModal').classList.remove('open')">Cancel</button></div>
          </form>
        </div>
      </div>

      <!-- New Folder Modal -->
      <div class="modal-bg" id="folderModal" onclick="if(event.target===this)this.classList.remove('open')">
        <div class="modal">
          <h3>📁 New Folder</h3>
          <form method="POST" action="/admin/companies/<%= company.id %>/folders">
            <input type="hidden" name="parent_id" value="<%= folderId || '' %>">
            <div class="form-group"><label>Name *</label><input type="text" name="name" required placeholder="Contracts, Invoices, IT Docs..."></div>
            <div class="form-actions"><button type="submit" class="btn btn-primary">Create</button><button type="button" class="btn" onclick="document.getElementById('folderModal').classList.remove('open')">Cancel</button></div>
          </form>
        </div>
      </div>

      <!-- Move File Modal -->
      <div class="modal-bg" id="moveModal" onclick="if(event.target===this)this.classList.remove('open')">
        <div class="modal">
          <h3>📂 Move File</h3>
          <div id="moveFileName" style="font-size:12px;color:var(--muted);margin-bottom:12px;"></div>
          <form id="moveForm" method="POST" action="">
            <input type="hidden" name="redirect" value="/admin/companies/<%= company.id %>/files<%= folderId ? '?folder=' + folderId : '' %>">
            <div class="form-group">
              <label>Move to folder</label>
              <select name="folder_id">
                <option value="">📁 Root</option>
                <% allFolders.forEach(af => { %>
                  <option value="<%= af.id %>" <%= af.id === (folderId ? parseInt(folderId) : null) ? 'disabled' : '' %>><%= af.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-actions"><button type="submit" class="btn btn-primary">Move</button><button type="button" class="btn" onclick="document.getElementById('moveModal').classList.remove('open')">Cancel</button></div>
          </form>
        </div>
      </div>

      <!-- Access Modal -->
      <% if (currentFolder) { %>
      <div class="modal-bg" id="accessModal" onclick="if(event.target===this)this.classList.remove('open')">
        <div class="modal">
          <h3>👥 Folder Access — <%= currentFolder.name %></h3>
          <% if (folderAccess.length > 0) { %>
            <% folderAccess.forEach(a => { %>
              <div style="display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid #f1f5f9;">
                <div style="flex:1;font-size:12px;font-weight:600;"><%= a.user_name %></div>
                <span class="badge <%= a.permission === 'edit' ? 'active' : 'draft' %>"><%= a.permission %></span>
                <form method="POST" action="/admin/companies/<%= company.id %>/folders/<%= folderId %>/access/<%= a.id %>/delete" style="display:inline;"><button type="submit" class="fi-btn" style="color:var(--danger);">✕</button></form>
              </div>
            <% }) %>
          <% } else { %><div style="font-size:12px;color:var(--muted);margin-bottom:12px;">No restrictions — add users to control access.</div><% } %>
          <form method="POST" action="/admin/companies/<%= company.id %>/folders/<%= folderId %>/access" style="margin-top:12px;border-top:1px solid var(--border);padding-top:12px;">
            <div class="form-row">
              <div class="form-group"><label>User</label><select name="user_name" required><option value="">—</option><% companyUsers.forEach(u => { %><option><%= u.name %></option><% }) %></select></div>
              <div class="form-group"><label>Permission</label><select name="permission"><option value="view">View</option><option value="edit">Edit</option><option value="admin">Full</option></select></div>
            </div>
            <button type="submit" class="btn btn-sm btn-primary">Grant Access</button>
          </form>
          <div class="form-actions"><button type="button" class="btn" onclick="document.getElementById('accessModal').classList.remove('open')">Close</button></div>
        </div>
      </div>
      <% } %>

      <div style="margin-top:16px;"><a href="/admin/companies/<%= company.id %>" class="btn btn-sm">← Back to <%= company.name %></a></div>

      <script>
      function setView(v){
        document.getElementById('viewGrid').style.display=v==='grid'?'':'none';
        document.getElementById('viewList').style.display=v==='list'?'':'none';
        document.getElementById('btnGrid').classList.toggle('active',v==='grid');
        document.getElementById('btnList').classList.toggle('active',v==='list');
        try{localStorage.setItem('fileView',v);}catch(e){}
      }
      // Restore view
      try{var sv=localStorage.getItem('fileView');if(sv)setView(sv);}catch(e){}

      function filterFiles(){
        var q=(document.getElementById('fileSearch').value||'').toLowerCase();
        document.querySelectorAll('[data-search]').forEach(function(el){
          el.style.display=(!q||el.dataset.search.indexOf(q)>=0)?'':'none';
        });
      }

      function openMoveModal(fileId, fileName){
        document.getElementById('moveFileName').textContent='Moving: '+fileName;
        document.getElementById('moveForm').action='/admin/companies/<%= company.id %>/files/'+fileId+'/move';
        document.getElementById('moveModal').classList.add('open');
      }
      </script>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>
