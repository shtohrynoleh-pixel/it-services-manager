<%- include('../partials/head') %>
<div class="app-wrap">
  <%- include('../partials/sidebar', { settings, user, page, tab: '' }) %>
  <div class="main">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px;"><button class="mob-toggle" onclick="openSidebar()">☰</button><h2><a href="/admin/services" style="opacity:0.4;text-decoration:none;">⚙️</a> → Edit Service</h2></div>
      <%- include('../partials/notif-bell') %>
    </div>
    <div class="content">
      <div class="card">
        <h3>Edit Service</h3>
        <form method="POST" action="/admin/services/<%= svc.id %>/edit">
          <div class="form-group"><label>Service Name *</label><input type="text" name="name" value="<%= svc.name %>" required></div>
          <div class="form-group"><label>Description</label><textarea name="description" rows="5"><%= svc.description || '' %></textarea></div>
          <div class="form-row-3">
            <div class="form-group"><label>Category</label><select name="category"><% ['Managed IT','Networking','Email','Server','Backup','Security','Cloud','Hardware','Subscription','Consulting','Web','Communication','HR-IT','Other'].forEach(c => { %><option <%= svc.category === c ? 'selected' : '' %>><%= c %></option><% }) %></select></div>
            <div class="form-group"><label>Base Price ($)</label><input type="number" name="base_price" step="0.01" value="<%= svc.base_price || 0 %>"></div>
            <div class="form-group"><label>Price Type</label><select name="price_type"><% ['monthly','yearly','one-time','hourly','per-user'].forEach(p => { %><option value="<%= p %>" <%= svc.price_type === p ? 'selected' : '' %>><%= p %></option><% }) %></select></div>
          </div>
          <div style="display:flex;gap:20px;margin-top:8px;flex-wrap:wrap;">
            <div class="form-check"><input type="checkbox" name="is_public" value="1" <%= svc.is_public ? 'checked' : '' %>> Show on services list</div>
            <div class="form-check"><input type="checkbox" name="show_on_landing" value="1" <%= svc.show_on_landing ? 'checked' : '' %>> Show on landing page</div>
            <div class="form-check"><input type="checkbox" name="is_active" value="1" <%= svc.is_active ? 'checked' : '' %>> Active</div>
          </div>
          <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a href="/admin/services" class="btn">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>
