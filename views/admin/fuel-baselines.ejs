<%- include('../partials/head') %>
<div class="app-wrap">
  <%- include('../partials/sidebar', { settings, user, page, tab: '' }) %>
  <div class="main">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px;"><button class="mob-toggle" onclick="openSidebar()">☰</button><h2><a href="/admin/companies/<%= company.id %>/fuel" style="opacity:0.4;text-decoration:none;"><i class="ti ti-gas-station"></i></a> → <i class="ti ti-chart-dots-3"></i> Baselines</h2></div>
      <%- include('../partials/notif-bell') %>
    </div>
    <div class="content">
      <!-- Recompute controls -->
      <div class="card" style="margin-bottom:14px;">
        <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;">
          <div><h3 style="margin-bottom:2px;"><i class="ti ti-calculator"></i> Compute Baselines</h3><div style="font-size:11px;color:var(--muted);">Window: <%= (config.baseline_window_days||90) %> days (from config)</div></div>
          <div style="display:flex;gap:6px;">
            <form method="POST" action="/admin/companies/<%= company.id %>/fuel/baselines/compute"><input type="hidden" name="group_id" value="all"><button type="submit" class="btn btn-primary btn-sm"><i class="ti ti-refresh"></i> Recompute All Groups</button></form>
          </div>
        </div>
      </div>

      <!-- Current baselines per group -->
      <% if (snapshots.length > 0) { %>
        <div class="metrics" style="margin-bottom:14px;">
          <% snapshots.forEach(s => { %>
            <div class="metric hi"><div class="m-label"><%= s.group_name || 'Group #'+s.group_id %></div><div class="m-val pri"><%= s.baseline_mpg %> <span style="font-size:12px;">MPG</span></div></div>
          <% }) %>
        </div>
        <div class="card">
          <h3><i class="ti ti-target"></i> Current Baselines</h3>
          <table class="tbl">
            <thead><tr><th>Group</th><th>Baseline MPG</th><th>Method</th><th>Window</th><th>Miles</th><th>Gallons</th><th>Trucks</th><th>Records</th><th>Computed</th><th></th></tr></thead>
            <tbody>
            <% snapshots.forEach(s => { %>
              <tr>
                <td><strong><%= s.group_name || '—' %></strong></td>
                <td style="font-weight:900;color:var(--primary);font-size:16px;"><%= s.baseline_mpg %></td>
                <td><span class="badge draft" style="font-size:8px;"><%= s.method %></span></td>
                <td><%= s.period_start %> → <%= s.period_end %></td>
                <td><%= Math.round(s.total_miles).toLocaleString() %></td>
                <td><%= s.total_gallons ? s.total_gallons.toFixed(1) : '—' %></td>
                <td><%= s.vehicle_count %></td>
                <td><%= s.measurement_count %></td>
                <td style="font-size:10px;color:var(--muted);"><%= s.computed_at ? String(s.computed_at).replace('T',' ').substring(0,16) : '' %><br>by <%= s.computed_by || '—' %></td>
                <td><form method="POST" action="/admin/companies/<%= company.id %>/fuel/baselines/compute"><input type="hidden" name="group_id" value="<%= s.group_id %>"><button type="submit" class="btn btn-sm"><i class="ti ti-refresh"></i></button></form></td>
              </tr>
            <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="card" style="text-align:center;padding:32px;"><i class="ti ti-chart-dots-3" style="font-size:40px;color:var(--muted);display:block;margin-bottom:8px;"></i><div style="font-weight:700;">No baselines computed yet</div><div style="font-size:12px;color:var(--muted);">Add vehicles to groups, sync measurement data, then click "Recompute All".</div></div>
      <% } %>

      <!-- Snapshot history -->
      <% if (allSnapshots.length > 0) { %>
        <details class="card">
          <summary style="cursor:pointer;font-weight:800;">Snapshot History (<%= allSnapshots.length %>)</summary>
          <table class="tbl" style="margin-top:10px;">
            <thead><tr><th>Group</th><th>MPG</th><th>Method</th><th>Period</th><th>Miles</th><th>Current</th><th>Computed</th></tr></thead>
            <tbody>
            <% allSnapshots.forEach(s => { %>
              <tr style="<%= s.is_current ? '' : 'opacity:0.5;' %>">
                <td><%= s.group_name || '—' %></td>
                <td style="font-weight:700;"><%= s.baseline_mpg %></td>
                <td style="font-size:10px;"><%= s.method %></td>
                <td style="font-size:10px;"><%= s.period_start %> → <%= s.period_end %></td>
                <td><%= Math.round(s.total_miles).toLocaleString() %></td>
                <td><%= s.is_current ? '✅' : '' %></td>
                <td style="font-size:10px;"><%= s.computed_at ? String(s.computed_at).replace('T',' ').substring(0,16) : '' %></td>
              </tr>
            <% }) %>
            </tbody>
          </table>
        </details>
      <% } %>

      <div style="margin-top:16px;"><a href="/admin/companies/<%= company.id %>/fuel" class="btn btn-sm">← Back to Fuel</a></div>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>
