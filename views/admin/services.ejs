<%- include('../partials/head') %>
<div class="app-wrap">
  <%- include('../partials/sidebar', { settings, user, page, tab: '' }) %>
  <div class="main">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px;"><button class="mob-toggle" onclick="openSidebar()">☰</button><h2>⚙️ Services Catalog</h2></div>
      <div style="display:flex;align-items:center;gap:8px;"><button class="btn btn-primary btn-sm" onclick="document.getElementById('addSvcModal').classList.add('open')">+ Add Service</button><%- include('../partials/notif-bell') %></div>
    </div>
    <div class="content">
      <p style="font-size:12px;color:var(--muted);margin-bottom:16px;">Public services are visible to clients at <a href="/public/services" target="_blank">/public/services</a></p>
      <% if (services.length === 0) { %>
        <div class="empty"><span class="e-icon">⚙️</span><div class="e-text">No services defined yet</div><button class="btn btn-primary" onclick="document.getElementById('addSvcModal').classList.add('open')">+ Add First Service</button></div>
      <% } else { %>
        <% services.forEach(s => { %>
          <div class="card">
            <h3><%= s.name %> <span class="badge <%= s.is_public ? 'active' : 'inactive' %>"><%= s.is_public ? 'Public' : 'Private' %></span><% if (s.show_on_landing) { %> <span class="badge prospect">Landing</span><% } %><% if (!s.is_active) { %> <span class="badge inactive">Disabled</span><% } %></h3>
            <div style="font-size:12px;color:#475569;margin-bottom:10px;line-height:1.6;white-space:pre-wrap;"><%= s.description || 'No description' %></div>
            <div class="card-row"><span class="label">Price</span><span class="value" style="font-size:16px;color:var(--primary);font-weight:800;">$<%= (s.base_price||0).toFixed(2) %> <span style="font-size:11px;color:var(--muted);font-weight:400;">/ <%= s.price_type %></span></span></div>
            <div class="card-row"><span class="label">Category</span><span class="value"><span class="badge active"><%= s.category || '—' %></span></span></div>
            <div style="margin-top:10px;display:flex;gap:6px;"><a href="/admin/services/<%= s.id %>/edit" class="btn btn-sm">✏️ Edit</a><form method="POST" action="/admin/services/<%= s.id %>/delete" style="display:inline" onsubmit="return confirm('Delete this service?')"><button type="submit" class="btn btn-sm btn-danger">🗑️ Delete</button></form></div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</div>
<div class="modal-bg" id="addSvcModal" onclick="if(event.target===this)this.classList.remove('open')">
  <div class="modal">
    <h3>Add Service</h3>
    <form method="POST" action="/admin/services">
      <div class="form-group"><label>Service Name *</label><input type="text" name="name" required placeholder="Managed IT Support"></div>
      <div class="form-group"><label>Description</label><textarea name="description" placeholder="What does this service include?"></textarea></div>
      <div class="form-row-3">
        <div class="form-group"><label>Category</label><select name="category"><option>Managed IT</option><option>Email</option><option>Server</option><option>Subscription</option><option>Consulting</option><option>Hardware</option><option>Security</option><option>Other</option></select></div>
        <div class="form-group"><label>Base Price</label><input type="number" name="base_price" step="0.01" placeholder="500.00"></div>
        <div class="form-group"><label>Price Type</label><select name="price_type"><option value="monthly">Monthly</option><option value="yearly">Yearly</option><option value="one-time">One-time</option><option value="hourly">Hourly</option><option value="per-user">Per User</option></select></div>
      </div>
      <div style="display:flex;gap:16px;flex-wrap:wrap;">
        <div class="form-check"><input type="checkbox" name="is_public" value="1" checked> Show on services list</div>
        <div class="form-check"><input type="checkbox" name="show_on_landing" value="1"> Show on landing page</div>
      </div>
      <div class="form-actions"><button type="submit" class="btn btn-primary">Save Service</button><button type="button" class="btn" onclick="document.getElementById('addSvcModal').classList.remove('open')">Cancel</button></div>
    </form>
  </div>
</div>
<%- include('../partials/foot') %>
