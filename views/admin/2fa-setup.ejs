<%- include('../partials/head') %>
<div class="app-wrap">
  <%- include('../partials/sidebar', { settings, user, page, tab: '' }) %>
  <div class="main">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px;"><button class="mob-toggle" onclick="openSidebar()">☰</button><h2>🔐 Two-Factor Authentication</h2></div>
      <%- include('../partials/notif-bell') %>
    </div>
    <div class="content">

      <% if (isEnabled) { %>
        <!-- Already enabled -->
        <div class="card" style="text-align:center;">
          <div style="font-size:48px;margin-bottom:12px;">✅</div>
          <h3 style="color:var(--success);margin-bottom:8px;">2FA is Enabled</h3>
          <p style="font-size:13px;color:var(--muted);margin-bottom:20px;">Your account is protected with two-factor authentication via Google Authenticator.</p>

          <% if (error) { %>
            <div style="background:var(--danger-light);color:#991b1b;padding:10px 14px;border-radius:8px;font-size:12px;font-weight:600;margin-bottom:16px;"><%= error %></div>
          <% } %>

          <div style="background:#fee2e2;border:1px solid #fca5a5;border-radius:12px;padding:20px;margin-bottom:16px;">
            <div style="font-weight:700;font-size:14px;color:#991b1b;margin-bottom:8px;">🔓 Disable Two-Factor Authentication</div>
            <p style="font-size:12px;color:#991b1b;margin-bottom:12px;">To disable 2FA, enter your current 6-digit code from Google Authenticator to confirm it's you.</p>
            <form method="POST" action="/admin/settings/2fa-disable" style="display:flex;gap:8px;align-items:flex-end;">
              <div style="flex:1;">
                <input type="text" name="token" required
                  placeholder="000000"
                  maxlength="6"
                  pattern="[0-9]{6}"
                  inputmode="numeric"
                  autocomplete="one-time-code"
                  style="width:100%;padding:10px;font-size:18px;font-weight:900;text-align:center;letter-spacing:6px;font-family:monospace;">
              </div>
              <button type="submit" class="btn btn-sm btn-danger" style="padding:10px 18px;">Disable 2FA</button>
            </form>
          </div>

          <a href="/admin/settings" class="btn btn-sm">← Back to Settings</a>
        </div>

      <% } else { %>
        <!-- Setup flow -->
        <div class="card">
          <h3>📱 Set Up Google Authenticator</h3>
          <p style="font-size:13px;color:var(--muted);margin-bottom:16px;">Follow these steps to secure your account with 2FA:</p>

          <!-- Step 1 -->
          <div style="display:flex;gap:14px;margin-bottom:20px;padding:16px;background:#f8fafc;border-radius:12px;border:1px solid var(--border);">
            <div style="width:32px;height:32px;border-radius:50%;background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:900;flex-shrink:0;">1</div>
            <div>
              <div style="font-weight:700;margin-bottom:4px;">Install Google Authenticator</div>
              <div style="font-size:12px;color:var(--muted);line-height:1.6;">
                Download from <a href="https://play.google.com/store/apps/details?id=com.google.android.apps.authenticator2" target="_blank">Google Play</a> or
                <a href="https://apps.apple.com/app/google-authenticator/id388497605" target="_blank">App Store</a>.
                You can also use Authy, Microsoft Authenticator, or any TOTP app.
              </div>
            </div>
          </div>

          <!-- Step 2 -->
          <div style="display:flex;gap:14px;margin-bottom:20px;padding:16px;background:#f8fafc;border-radius:12px;border:1px solid var(--border);">
            <div style="width:32px;height:32px;border-radius:50%;background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:900;flex-shrink:0;">2</div>
            <div style="flex:1;">
              <div style="font-weight:700;margin-bottom:8px;">Scan this QR Code</div>
              <div style="text-align:center;margin:12px 0;">
                <% if (qrDataUrl) { %>
                  <img src="<%= qrDataUrl %>" alt="QR Code" style="width:200px;height:200px;border:4px solid var(--border);border-radius:12px;">
                <% } else { %>
                  <div style="color:var(--danger);font-size:12px;">QR code generation failed</div>
                <% } %>
              </div>
              <div style="font-size:11px;color:var(--muted);margin-top:8px;">
                Can't scan? Enter this code manually:<br>
                <code style="display:inline-block;margin-top:6px;padding:8px 14px;background:#1e293b;color:#22d3ee;border-radius:8px;font-size:13px;letter-spacing:2px;font-weight:700;user-select:all;word-break:break-all;"><%= secret %></code>
              </div>
            </div>
          </div>

          <!-- Step 3 -->
          <div style="display:flex;gap:14px;padding:16px;background:#f8fafc;border-radius:12px;border:1px solid var(--border);">
            <div style="width:32px;height:32px;border-radius:50%;background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:900;flex-shrink:0;">3</div>
            <div style="flex:1;">
              <div style="font-weight:700;margin-bottom:8px;">Enter the 6-digit code to verify</div>
              <% if (error) { %>
                <div style="background:var(--danger-light);color:#991b1b;padding:8px 12px;border-radius:8px;font-size:12px;font-weight:600;margin-bottom:12px;"><%= error %></div>
              <% } %>
              <form method="POST" action="/admin/settings/2fa-enable" style="display:flex;gap:8px;align-items:flex-end;">
                <div style="flex:1;">
                  <input type="text" name="token" required autofocus
                    placeholder="000000"
                    maxlength="6"
                    pattern="[0-9]{6}"
                    inputmode="numeric"
                    autocomplete="one-time-code"
                    style="width:100%;padding:12px;font-size:22px;font-weight:900;text-align:center;letter-spacing:8px;font-family:monospace;">
                </div>
                <button type="submit" class="btn btn-primary" style="padding:12px 24px;white-space:nowrap;">✅ Enable 2FA</button>
              </form>
            </div>
          </div>
        </div>

        <!-- Warning -->
        <div class="card" style="background:var(--accent-light);border-color:var(--accent);">
          <h3 style="color:#92400e;">⚠️ Important</h3>
          <div style="font-size:12px;color:#92400e;line-height:1.7;">
            <strong>Save your secret key somewhere safe.</strong> If you lose access to your authenticator app, you will need this key to recover your account.
            Without it, you will be locked out permanently.<br><br>
            Secret: <code style="background:#fff;padding:2px 8px;border-radius:4px;font-weight:700;"><%= secret %></code>
          </div>
        </div>

        <div style="margin-top:12px;"><a href="/admin/settings" class="btn btn-sm">← Back to Settings</a></div>
      <% } %>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>
