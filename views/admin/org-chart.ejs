<%- include('../partials/head') %>
<style>
.org-dept{margin-bottom:20px;}
.org-dept-title{font-size:14px;font-weight:800;color:var(--primary-dark);padding:10px 16px;background:linear-gradient(135deg,#ecfeff,#cffafe);border-radius:10px 10px 0 0;border:1px solid var(--border);border-bottom:none;}
.org-dept-body{border:1px solid var(--border);border-radius:0 0 10px 10px;padding:8px;}
.org-user{display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:8px;transition:background 0.12s;text-decoration:none;color:inherit;}
.org-user:hover{background:#f0fdfa;text-decoration:none;}
.org-avatar{width:36px;height:36px;border-radius:50%;background:var(--primary-light);display:flex;align-items:center;justify-content:center;font-weight:800;color:var(--primary);font-size:14px;flex-shrink:0;}
.org-avatar img{width:100%;height:100%;border-radius:50%;object-fit:cover;}
.org-name{font-weight:700;font-size:13px;}
.org-role{font-size:11px;color:var(--muted);}
.org-indent{margin-left:32px;border-left:2px solid var(--border);padding-left:12px;}
.org-email{font-size:10px;color:var(--primary);}
</style>
<div class="app-wrap">
  <%- include('../partials/sidebar', { settings, user, page, tab: '' }) %>
  <div class="main">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px;"><button class="mob-toggle" onclick="openSidebar()">☰</button><h2><a href="/admin/companies/<%= company.id %>" style="opacity:0.4;text-decoration:none;">🏢</a> → Org Chart</h2></div>
      <div style="display:flex;align-items:center;gap:8px;"><a href="/admin/companies/<%= company.id %>?tab=users" class="btn btn-sm">👥 Users List</a><%- include('../partials/notif-bell') %></div>
    </div>
    <div class="content">
      <% if (company.logo) { %>
        <div style="text-align:center;margin-bottom:16px;"><img src="<%= company.logo %>" style="width:60px;height:60px;border-radius:12px;object-fit:contain;border:1px solid var(--border);"></div>
      <% } %>
      <h3 style="text-align:center;margin-bottom:20px;"><%= company.name %> — Organization Chart</h3>

      <div class="metrics">
        <div class="metric hi"><div class="m-label">Total</div><div class="m-val pri"><%= users.length %></div></div>
        <div class="metric"><div class="m-label">Departments</div><div class="m-val"><%= [...new Set(users.map(u => u.department).filter(Boolean))].length %></div></div>
        <div class="metric"><div class="m-label">With Email</div><div class="m-val"><%= users.filter(u => u.email_account).length %></div></div>
        <div class="metric"><div class="m-label">With Phone</div><div class="m-val"><%= users.filter(u => u.phone).length %></div></div>
      </div>

      <%
        // Group by department
        const userDepts = {};
        const noDept = [];
        users.forEach(u => {
          if (u.department) {
            if (!userDepts[u.department]) userDepts[u.department] = [];
            userDepts[u.department].push(u);
          } else {
            noDept.push(u);
          }
        });

        // Sort departments by the predefined order
        const deptOrder = {};
        depts.forEach((d, i) => { deptOrder[d.name] = d.sort_order || i; });
        const sortedDepts = Object.keys(userDepts).sort((a, b) => (deptOrder[a] || 99) - (deptOrder[b] || 99));

        // Helper to render a user row
        function renderUser(u) {
          let h = '<a href="/admin/companies/' + company.id + '/users/' + u.id + '/profile" class="org-user">';
          h += '<div class="org-avatar">';
          if (u.photo_url) h += '<img src="' + u.photo_url + '">';
          else h += u.name.charAt(0).toUpperCase();
          h += '</div><div>';
          h += '<div class="org-name">' + u.name;
          if (u.title) h += ' <span style="font-weight:400;color:var(--muted);">— ' + u.title + '</span>';
          h += '</div>';
          h += '<div class="org-role">' + (u.role || '') + (u.email_account ? ' · <span class="org-email">' + u.email_account + '</span>' : '') + (u.phone ? ' · ' + u.phone : '') + '</div>';
          h += '</div></a>';
          // Direct reports
          const reports = users.filter(r => r.manager_id === u.id);
          if (reports.length > 0) {
            h += '<div class="org-indent">';
            reports.forEach(r => { h += renderUser(r); });
            h += '</div>';
          }
          return h;
        }
      %>

      <% sortedDepts.forEach(dept => { %>
        <div class="org-dept">
          <div class="org-dept-title"><%= dept %> (<%= userDepts[dept].length %>)</div>
          <div class="org-dept-body">
            <% const topLevel = userDepts[dept].filter(u => !u.manager_id || !userDepts[dept].find(m => m.id === u.manager_id)); %>
            <% topLevel.forEach(u => { %>
              <%- renderUser(u) %>
            <% }) %>
          </div>
        </div>
      <% }) %>

      <% if (noDept.length > 0) { %>
        <div class="org-dept">
          <div class="org-dept-title" style="background:#f1f5f9;">No Department (<%= noDept.length %>)</div>
          <div class="org-dept-body">
            <% noDept.forEach(u => { %>
              <%- renderUser(u) %>
            <% }) %>
          </div>
        </div>
      <% } %>

      <% if (users.length === 0) { %>
        <div class="empty"><span class="e-icon">👥</span><div class="e-text">No users added to this company yet</div><a href="/admin/companies/<%= company.id %>?tab=users" class="btn btn-primary btn-sm">+ Add Users</a></div>
      <% } %>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>
