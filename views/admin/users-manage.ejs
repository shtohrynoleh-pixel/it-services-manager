<%- include('../partials/head') %>
<div class="app-wrap">
  <%- include('../partials/sidebar', { settings, user, page, tab: '' }) %>
  <div class="main">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px;"><button class="mob-toggle" onclick="openSidebar()">☰</button><h2>👤 User Management</h2></div>
      <%- include('../partials/notif-bell') %>
    </div>
    <div class="content">
      <div class="card">
        <h3>Login Accounts</h3>
        <p style="font-size:12px;color:var(--muted);margin-bottom:14px;">Manage admin and client login accounts. Send password reset links via email.</p>
        <input type="text" id="searchUsers" placeholder="Search users..." oninput="filterUsers()" style="margin-bottom:12px;padding:6px 12px;font-size:12px;width:100%;max-width:300px;">
        <div style="overflow-x:auto;">
        <table class="tbl" id="usersTable">
          <thead><tr><th>Username</th><th>Full Name</th><th>Role</th><th>Company</th><th>Email</th><th>Active</th><th>Actions</th></tr></thead>
          <tbody>
          <% allUsers.forEach(u => { %>
            <tr data-search="<%= [u.username,u.full_name,u.role,u.company_name,u.email].filter(Boolean).join(' ').toLowerCase() %>">
              <td><strong><%= u.username %></strong></td>
              <td><%= u.full_name || '—' %></td>
              <td><span class="badge <%= u.role === 'admin' ? 'overdue' : 'active' %>"><%= u.role %></span></td>
              <td><%= u.company_name || '—' %></td>
              <td><%= u.email || '—' %></td>
              <td><span class="badge <%= u.is_active ? 'active' : 'inactive' %>"><%= u.is_active ? 'Yes' : 'No' %></span></td>
              <td style="white-space:nowrap;">
                <% if (u.email) { %>
                  <form method="POST" action="/admin/users/<%= u.id %>/send-reset" style="display:inline" onsubmit="return confirm('Send password reset email to <%= u.email %>?')">
                    <button type="submit" class="btn btn-sm" title="Send reset link">📧 Reset</button>
                  </form>
                <% } else { %>
                  <span style="font-size:10px;color:var(--muted);">No email</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
          </tbody>
        </table>
        </div>
      </div>
      <script>
      function filterUsers(){
        var q = document.getElementById('searchUsers').value.toLowerCase();
        document.querySelectorAll('#usersTable tbody tr').forEach(function(r){
          r.style.display = !q || r.dataset.search.indexOf(q) >= 0 ? '' : 'none';
        });
      }
      </script>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>
