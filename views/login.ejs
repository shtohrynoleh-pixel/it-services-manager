<%- include('partials/head') %>
<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#f0fdfa,#ecfeff,#cffafe);padding:20px;">
  <div style="background:#fff;border-radius:16px;padding:40px;max-width:420px;width:100%;box-shadow:0 8px 40px rgba(8,145,178,0.08);">
    <div style="text-align:center;margin-bottom:24px;">
      <% if (typeof settings !== 'undefined' && settings && settings.business_logo) { %>
        <img src="<%= settings.business_logo %>" style="max-height:48px;margin-bottom:8px;">
      <% } else { %>
        <div style="font-size:48px;margin-bottom:8px;">🖥️</div>
      <% } %>
      <h1 style="font-size:22px;font-weight:800;color:var(--primary-dark);"><%= (typeof settings !== 'undefined' && settings && settings.business_name) ? settings.business_name : 'IT Services Manager' %></h1>
      <p style="font-size:13px;color:var(--muted);">Sign in to your account</p>
    </div>

    <% if (error) { %>
      <div style="background:var(--danger-light);color:#991b1b;padding:10px 14px;border-radius:8px;font-size:12px;font-weight:600;margin-bottom:16px;"><%= error %></div>
    <% } %>

    <form method="POST" action="/login">
      <div class="form-group">
        <label>Username</label>
        <input type="text" name="username" placeholder="Enter your username" required autofocus>
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" placeholder="Enter your password" required>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:12px;">Sign In</button>
    </form>
    <div style="text-align:center;margin-top:16px;"><a href="/" style="font-size:12px;color:var(--muted);">← Back to Home</a></div>
  </div>
</div>
<%- include('partials/foot') %>
