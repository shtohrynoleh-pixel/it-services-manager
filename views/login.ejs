<%- include('partials/head') %>
<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#f0fdfa,#ecfeff,#cffafe);padding:20px;">
  <div style="background:#fff;border-radius:16px;padding:40px;max-width:420px;width:100%;box-shadow:0 8px 40px rgba(8,145,178,0.08);">
    <div style="text-align:center;margin-bottom:24px;">
      <div style="font-size:48px;margin-bottom:8px;">🖥️</div>
      <h1 style="font-size:22px;font-weight:800;color:var(--primary-dark);">IT Services Manager</h1>
      <p style="font-size:13px;color:var(--muted);">Sign in to manage your services</p>
    </div>

    <% if (error) { %>
      <div style="background:var(--danger-light);color:#991b1b;padding:10px 14px;border-radius:8px;font-size:12px;font-weight:600;margin-bottom:16px;"><%= error %></div>
    <% } %>

    <!-- Tabs -->
    <div style="display:flex;gap:4px;background:#f1f5f9;border-radius:8px;padding:3px;margin-bottom:20px;">
      <button type="button" class="login-tab" id="tabAdmin" onclick="showTab('admin')" style="flex:1;padding:8px;border:none;border-radius:6px;font-family:inherit;font-size:12px;font-weight:700;cursor:pointer;background:var(--primary);color:#fff;">🔐 Admin</button>
      <button type="button" class="login-tab" id="tabClient" onclick="showTab('client')" style="flex:1;padding:8px;border:none;border-radius:6px;font-family:inherit;font-size:12px;font-weight:700;cursor:pointer;background:transparent;color:var(--muted);">👤 Client</button>
    </div>

    <!-- Admin form -->
    <form id="formAdmin" method="POST" action="/login">
      <input type="hidden" name="login_type" value="admin">
      <div class="form-group">
        <label>Username</label>
        <input type="text" name="username" placeholder="admin" required>
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" placeholder="Enter password" required>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:12px;">Sign In as Admin</button>
      <div style="text-align:center;font-size:11px;color:var(--muted);margin-top:10px;">Default: admin / admin</div>
    </form>

    <!-- Client form -->
    <form id="formClient" method="POST" action="/login" style="display:none;">
      <input type="hidden" name="login_type" value="client">
      <div class="form-group">
        <label>Company</label>
        <select name="company_id">
          <% if (companies.length === 0) { %>
            <option value="">No companies available</option>
          <% } %>
          <% companies.forEach(c => { %>
            <option value="<%= c.id %>"><%= c.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label>Username</label>
        <input type="text" name="username" placeholder="Your username" required>
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" placeholder="Your password" required>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:12px;">Sign In as Client</button>
    </form>
  </div>
</div>
<script>
function showTab(t){
  document.getElementById('formAdmin').style.display=t==='admin'?'block':'none';
  document.getElementById('formClient').style.display=t==='client'?'block':'none';
  document.getElementById('tabAdmin').style.background=t==='admin'?'var(--primary)':'transparent';
  document.getElementById('tabAdmin').style.color=t==='admin'?'#fff':'var(--muted)';
  document.getElementById('tabClient').style.background=t==='client'?'var(--primary)':'transparent';
  document.getElementById('tabClient').style.color=t==='client'?'#fff':'var(--muted)';
}
</script>
<%- include('partials/foot') %>
