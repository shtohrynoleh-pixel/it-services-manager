<%- include('partials/head') %>
<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#f0fdfa,#ecfeff,#cffafe);padding:20px;">
  <div style="background:#fff;border-radius:16px;padding:40px;max-width:420px;width:100%;box-shadow:0 8px 40px rgba(8,145,178,0.08);">
    <div style="text-align:center;margin-bottom:24px;">
      <div style="font-size:48px;margin-bottom:8px;">🔐</div>
      <h2 style="font-size:20px;font-weight:800;margin-bottom:4px;">Reset Password</h2>
    </div>

    <% if (typeof success !== 'undefined' && success) { %>
      <div style="background:#d1fae5;color:#065f46;padding:14px;border-radius:10px;text-align:center;margin-bottom:16px;">
        <div style="font-size:24px;margin-bottom:8px;">✅</div>
        <div style="font-weight:700;">Password reset successful!</div>
        <div style="font-size:12px;margin-top:4px;">You can now log in with your new password.</div>
      </div>
      <div style="text-align:center;"><a href="/login" style="font-weight:700;">← Go to Login</a></div>
    <% } else if (!token) { %>
      <div style="background:#fee2e2;color:#991b1b;padding:14px;border-radius:10px;text-align:center;">
        <div style="font-size:24px;margin-bottom:8px;">⚠️</div>
        <div style="font-weight:700;"><%= error || 'Invalid or expired reset link.' %></div>
        <div style="font-size:12px;margin-top:4px;">Please request a new password reset from your administrator.</div>
      </div>
      <div style="text-align:center;margin-top:16px;"><a href="/login" style="font-weight:700;">← Go to Login</a></div>
    <% } else { %>
      <% if (error) { %>
        <div style="background:#fee2e2;color:#991b1b;padding:10px 14px;border-radius:8px;font-size:12px;font-weight:600;margin-bottom:16px;"><%= error %></div>
      <% } %>
      <form method="POST" action="/reset-password">
        <input type="hidden" name="token" value="<%= token %>">
        <div style="margin-bottom:14px;">
          <label style="display:block;font-size:12px;font-weight:600;color:#475569;margin-bottom:4px;">New Password</label>
          <input type="password" name="new_password" required minlength="4" placeholder="Minimum 4 characters" style="width:100%;padding:10px 14px;border:1px solid #e2e8f0;border-radius:8px;font-size:14px;outline:none;">
        </div>
        <button type="submit" style="width:100%;padding:12px;background:#0891b2;color:#fff;border:none;border-radius:8px;font-size:14px;font-weight:700;cursor:pointer;">Set New Password</button>
      </form>
    <% } %>
  </div>
</div>
<%- include('partials/foot') %>
