<%- include('partials/head') %>
<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#f0fdfa,#ecfeff,#cffafe);padding:20px;">
  <div style="background:#fff;border-radius:16px;padding:40px;max-width:380px;width:100%;box-shadow:0 8px 40px rgba(8,145,178,0.08);text-align:center;">
    <div style="font-size:48px;margin-bottom:12px;">🔐</div>
    <h1 style="font-size:20px;font-weight:800;color:var(--primary-dark);margin-bottom:4px;">Two-Factor Authentication</h1>
    <p style="font-size:13px;color:var(--muted);margin-bottom:20px;">Enter the 6-digit code from your Google Authenticator app</p>

    <% if (error) { %>
      <div style="background:var(--danger-light);color:#991b1b;padding:10px 14px;border-radius:8px;font-size:12px;font-weight:600;margin-bottom:16px;"><%= error %></div>
    <% } %>

    <p style="font-size:12px;color:var(--muted);margin-bottom:16px;">Logging in as <strong><%= username %></strong></p>

    <form method="POST" action="/2fa">
      <div style="margin-bottom:16px;">
        <input type="text" name="token" required autofocus
          placeholder="000000"
          maxlength="6"
          pattern="[0-9]{6}"
          inputmode="numeric"
          autocomplete="one-time-code"
          style="width:100%;padding:16px;font-size:28px;font-weight:900;text-align:center;letter-spacing:12px;border:2px solid var(--border);border-radius:12px;font-family:monospace;outline:none;transition:border 0.2s;"
          onfocus="this.style.borderColor='var(--primary)'"
          onblur="this.style.borderColor='var(--border)'"
        >
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:14px;font-size:15px;">Verify</button>
    </form>

    <div style="margin-top:16px;">
      <a href="/login" style="font-size:12px;color:var(--muted);">← Back to login</a>
    </div>
  </div>
</div>
<%- include('partials/foot') %>
