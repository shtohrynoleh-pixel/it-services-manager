# === IT Services Manager — Environment Variables ===
# Copy this file to .env and fill in your values
# NEVER commit .env to git — it contains secrets

# Session secret (change to a random string)
SESSION_SECRET=change-this-to-a-random-string-at-least-32-chars

# Port
PORT=3000

# === GMAIL SMTP (for email alerts) ===
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification
# 3. Go to App Passwords: https://myaccount.google.com/apppasswords
# 4. Create an App Password for "Mail" on "Other (IT Services Manager)"
# 5. Copy the 16-character password below (no spaces)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# === TWILIO (for SMS alerts) ===
# 1. Sign up at https://www.twilio.com
# 2. Get your Account SID and Auth Token from the dashboard
# 3. Get a Twilio phone number
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_FROM_NUMBER=+1234567890

# === ALERT RECIPIENTS ===
# Comma-separated email addresses to receive monitoring alerts
ALERT_EMAILS=admin@example.com

# Comma-separated phone numbers (with country code) for SMS alerts
ALERT_PHONES=+1234567890
